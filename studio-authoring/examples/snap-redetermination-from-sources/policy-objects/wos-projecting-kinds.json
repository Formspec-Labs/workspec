    {
      "id": "pol-decision-table-eligibility",
      "kind": "DecisionRule",
      "lifecycleState": "approved",
      "originClass": "source",
      "body": {
        "form": "table",
        "inputs": [
          { "name": "householdSize", "dataElementRef": "pol-data-household-size", "dataType": "integer" },
          { "name": "monthlyGrossIncome", "dataElementRef": "pol-data-household-income", "dataType": "money" }
        ],
        "outputs": [
          { "name": "eligibility", "target": "pol-outcome-eligibility-determination", "targetKind": "decision-output" }
        ],
        "rows": [
          { "id": 1, "when": { "householdSize": "== 1", "monthlyGrossIncome": "<= 1473" }, "then": { "eligibility": "eligible" }, "sourceCitation": { "sourceVersion": "src-state-tx-snap-manual-ch8", "sectionAnchor": "§8.4 row 1" } },
          { "id": 2, "when": { "householdSize": "== 2", "monthlyGrossIncome": "<= 1984" }, "then": { "eligibility": "eligible" }, "sourceCitation": { "sourceVersion": "src-state-tx-snap-manual-ch8", "sectionAnchor": "§8.4 row 2" } },
          { "id": 3, "when": { "householdSize": "== 3", "monthlyGrossIncome": "<= 2495" }, "then": { "eligibility": "eligible" }, "sourceCitation": { "sourceVersion": "src-state-tx-snap-manual-ch8", "sectionAnchor": "§8.4 row 3" } },
          { "id": 4, "when": { "householdSize": ">= 4", "monthlyGrossIncome": "<= computed: 2495 + (householdSize - 3) * 511" }, "then": { "eligibility": "eligible" }, "sourceCitation": { "sourceVersion": "src-state-tx-snap-manual-ch8", "sectionAnchor": "§8.4 row 4+" } },
          { "id": 5, "when": { "householdSize": "*", "monthlyGrossIncome": "*" }, "then": { "eligibility": "not-eligible" } }
        ],
        "hitPolicy": "first-match",
        "completenessRequirement": "all-inputs-covered",
        "fallback": { "eligibility": "manual-review" }
      },
      "mappingRef": "map-pol-decision-table-eligibility",
      "mappingState": "mapsToWos",
      "wosTarget": "$.lifecycle.transitions[?(@.id=='intake-to-determination')].guard"
    },
