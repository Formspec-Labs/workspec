{
  "$comment": "StudioBinding collection materializing the 3 binding refs from workflow-intent.json (bind-svc-fed-income-verify, bind-evt-application-submitted, bind-pe-fraud-screen). Each individual binding carries the $wosStudioBinding marker; the wrapper carries workspace context.",
  "workspaceId": "ws-snap-redetermination-tx-2026",
  "bindings": [
    {
      "$wosStudioBinding": "1.0",
      "id": "bind-svc-fed-income-verify",
      "workspaceId": "ws-snap-redetermination-tx-2026",
      "kind": "ServiceBinding",
      "lifecycleState": "approved",
      "originClass": "approved-interpretation",
      "mappingState": "mapsToWos",
      "wosTarget": "$.bindings[?(@.id=='bind-svc-fed-income-verify')]",
      "exercisedByScenarios": ["scn-snap-redet-happy-path", "scn-snap-redet-adverse-with-appeal"],
      "body": {
        "operationKind": "openapi",
        "apiSpecRef": "fed-broker-2026.openapi.json",
        "operationRef": "POST /eligibility/income-verify",
        "inputBindings": [
          { "caseFilePath": "household.income.monthlyGross", "requestPath": "$.income" },
          { "caseFilePath": "applicantId", "requestPath": "$.applicantId" }
        ],
        "outputBindings": [
          { "responsePath": "$.matchResult", "caseFilePath": "incomeVerify.result" },
          { "responsePath": "$.discrepancyAmount", "caseFilePath": "incomeVerify.discrepancy" }
        ]
      }
    },
    {
      "$wosStudioBinding": "1.0",
      "id": "bind-evt-application-submitted",
      "workspaceId": "ws-snap-redetermination-tx-2026",
      "kind": "EventBinding",
      "lifecycleState": "approved",
      "originClass": "approved-interpretation",
      "mappingState": "mapsToWos",
      "wosTarget": "$.bindings[?(@.id=='bind-evt-application-submitted')]",
      "exercisedByScenarios": ["scn-snap-redet-happy-path"],
      "body": {
        "eventName": "application.submitted",
        "direction": "consume",
        "cloudEventsExtensions": {
          "woscausationeventid": "${prior.eventId}",
          "woscorrelationkey": "${case.id}"
        }
      }
    },
    {
      "$wosStudioBinding": "1.0",
      "id": "bind-pe-fraud-screen",
      "workspaceId": "ws-snap-redetermination-tx-2026",
      "kind": "PolicyEngineBinding",
      "lifecycleState": "approved",
      "originClass": "approved-interpretation",
      "mappingState": "mapsToWos",
      "wosTarget": "$.bindings[?(@.id=='bind-pe-fraud-screen')]",
      "exercisedByScenarios": ["scn-snap-redet-happy-path", "scn-snap-redet-adverse-with-appeal"],
      "body": {
        "engineKind": "opa",
        "endpoint": "https://policy.dhs.state.tx.us/v1/data/snap/fraud-screening",
        "decisionMapping": { "permit": "permit", "deny": "deny" },
        "reasonsMapping": {
          "code-12": "Income spike anomaly",
          "code-17": "Document forgery flag"
        }
      }
    }
  ]
}
