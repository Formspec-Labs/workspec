{
  "binding": "formspec",
  "id": "SIG-015-signing-intent-mismatch",
  "rule": "SIG-RT",
  "description": "Signing-intent mismatch between Signature Profile step and Formspec authored signature emits SignatureAdmissionFailed(evidence_divergence) and keeps the signing task active.",
  "documents": {
    "kernel": "../../../../fixtures/kernel/signature-runtime.json",
    "signatureProfile": "../../../../fixtures/profiles/signature-runtime-sequential.json"
  },
  "event_sequence": [
    {
      "event": "start",
      "actor": "applicant"
    },
    {
      "event": "submit",
      "task_submission": {
        "task_ref": "applicantTask",
        "response": {
          "status": "completed",
          "definitionUrl": "urn:test:formspec:signature",
          "definitionVersion": "1.0.0",
          "data": {
            "signerId": "applicant",
            "signatureProvider": "formspec",
            "ceremonyId": "ceremony-sequential",
            "signature": {
              "acceptedAt": "2026-04-22T12:00:00Z",
              "affirmed": true,
              "documentHash": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
            }
          },
          "id": "resp-sig-001-sequential-single-signer-applicantTask",
          "authoredSignatures": [
            {
              "signatureId": "sig-sig-001-sequential-single-signer-applicantTask",
              "documentId": "application",
              "signingIntent": "urn:wos:signing-intent:approval",
              "signatureValue": "urn:test:signature:SIG-001-sequential-single-signer:applicantTask",
              "signerId": "applicant",
              "signerName": "Applicant",
              "signedAt": "2026-04-22T12:00:00Z",
              "consentAccepted": true,
              "consentTextRef": "urn:test:consent:esign",
              "consentVersion": "1.0.0",
              "affirmationText": "I certify this signing act.",
              "signedPayload": {
                "canonicalization": "formspec-response-signing-v1",
                "digestAlgorithm": "sha-256",
                "digest": "39cc22282ffcb5a632635803d838c2517527684533ceb5ae8d2614b050683856",
                "responseId": "resp-sig-001-sequential-single-signer-applicantTask",
                "definitionUrl": "urn:test:formspec:signature",
                "definitionVersion": "1.0.0"
              },
              "documentHash": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
              "documentHashAlgorithm": "sha-256",
              "signatureProvider": "formspec",
              "ceremonyId": "ceremony-sequential"
            }
          ]
        }
      }
    }
  ],
  "expected_transitions": [
    {
      "from": "draft",
      "target": "signing",
      "event": "start"
    }
  ],
  "expected_provenance": [
    {
      "recordKind": "signatureAdmissionFailed",
      "data": {
        "reason": "evidence_divergence",
        "failureContext": {
          "field": "signingIntent",
          "expected": "urn:wos:signing-intent:applicant-signature",
          "actual": "urn:wos:signing-intent:approval"
        },
        "evidenceBindings": {
          "signingIntent": "urn:wos:signing-intent:approval"
        }
      }
    }
  ],
  "expected_errors": []
}
