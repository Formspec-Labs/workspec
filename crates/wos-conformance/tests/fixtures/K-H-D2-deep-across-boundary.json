{
  "binding": "formspec",
  "id": "K-H-D2-deep-across-boundary",
  "rule": "K-H",
  "description": "Deep history across-boundary at depth 2: compound state 'review' has historyState=deep. After progressing into 'inProgress.advancedPhase', two interrupt-resume cycles verify that history is captured and cleared on each exit (producing two historyCleared provenance records) and that deep restore consistently returns to 'advancedPhase'. A final 'complete' event fires from 'advancedPhase', proving deep restore held across both cycles. Under shallow, 'complete' would be unmatched since re-entry goes to 'subPhase'.",
  "documents": {
    "kernel": "inline"
  },
  "inline_documents": {
    "kernel": {
      "$wosWorkflow": "1.0",
      "url": "urn:test:history-deep-d2-boundary",
      "version": "1.0.0",
      "title": "History Deep Depth-2 Across-Boundary Test",
      "description": "Kernel for testing deep history across-boundary behavior at depth 2",
      "status": "active",
      "impactLevel": "operational",
      "actors": [
        {
          "id": "worker",
          "type": "human",
          "description": "Test actor"
        }
      ],
      "lifecycle": {
        "initialState": "open",
        "states": {
          "open": {
            "type": "atomic",
            "transitions": [
              {
                "event": "start",
                "target": "review"
              }
            ]
          },
          "review": {
            "type": "compound",
            "historyState": "deep",
            "initialState": "inProgress",
            "states": {
              "inProgress": {
                "type": "compound",
                "initialState": "subPhase",
                "states": {
                  "subPhase": {
                    "type": "atomic",
                    "transitions": [
                      {
                        "event": "nextPhase",
                        "target": "advancedPhase"
                      }
                    ]
                  },
                  "advancedPhase": {
                    "type": "atomic",
                    "transitions": [
                      {
                        "event": "complete",
                        "target": "done"
                      }
                    ]
                  }
                }
              },
              "done": {
                "type": "final"
              }
            },
            "transitions": [
              {
                "event": "interrupt",
                "target": "interrupted"
              }
            ]
          },
          "interrupted": {
            "type": "atomic",
            "transitions": [
              {
                "event": "resume",
                "target": "review"
              }
            ]
          }
        }
      },
      "caseFile": {
        "fields": {}
      },
      "execution": {
        "workflowTimeout": "P90D",
        "defaultTaskTimeout": "P7D",
        "instanceVersioning": "pinned"
      }
    }
  },
  "initial_case_state": {},
  "event_sequence": [
    {
      "event": "start",
      "actor": "worker"
    },
    {
      "event": "nextPhase",
      "actor": "worker"
    },
    {
      "event": "interrupt",
      "actor": "worker"
    },
    {
      "event": "resume",
      "actor": "worker"
    },
    {
      "event": "interrupt",
      "actor": "worker"
    },
    {
      "event": "resume",
      "actor": "worker"
    },
    {
      "event": "complete",
      "actor": "worker"
    }
  ],
  "expected_transitions": [
    {
      "from": "open",
      "to": "review",
      "event": "start"
    },
    {
      "from": "subPhase",
      "to": "advancedPhase",
      "event": "nextPhase"
    },
    {
      "from": "review",
      "to": "interrupted",
      "event": "interrupt"
    },
    {
      "from": "interrupted",
      "to": "review",
      "event": "resume"
    },
    {
      "from": "review",
      "to": "interrupted",
      "event": "interrupt"
    },
    {
      "from": "interrupted",
      "to": "review",
      "event": "resume"
    },
    {
      "from": "advancedPhase",
      "to": "done",
      "event": "complete"
    }
  ],
  "expected_provenance": [
    {
      "recordKind": "historyCleared",
      "data": {
        "state": "review"
      }
    }
  ]
}