{
  "id": "AI-006-agent-provenance-fields",
  "rule": "AI-006",
  "batch": 10,
  "description": "Agent provenance MUST include model identifier, version, confidence, input summary (AI S3.7).",
  "documents": {
    "kernel": "../../../../fixtures/kernel/deontic-enforcement.json",
    "ai": "../../../../fixtures/ai/deontic-enforcement-ai.json"
  },
  "initial_case_state": {
    "income": 50000
  },
  "event_sequence": [
    {
      "event": "determined",
      "actor": "eligibilityAgent",
      "data": {
        "output": {
          "income": 50000,
          "determination": "eligible",
          "reasonCodes": [
            "R1"
          ],
          "evidenceCitations": [
            "doc1"
          ],
          "confidenceReport": {
            "overall": 0.9
          }
        },
        "confidenceReport": {
          "overall": 0.92,
          "modelNative": 0.92,
          "calibrated": true
        }
      }
    }
  ],
  "expected_transitions": [
    {
      "from": "pendingDetermination",
      "to": "reviewComplete",
      "event": "determined"
    }
  ],
  "expected_provenance": [
    {
      "record_kind": "agentOutput",
      "data": {
        "modelIdentifier": "test-model",
        "modelVersion": "1.0",
        "confidence": 0.92,
        "inputSummaryPresent": true
      }
    }
  ]
}