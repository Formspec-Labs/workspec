{
  "binding": "formspec",
  "id": "S15-001-task-draft-prefill",
  "rule": "S15",
  "description": "Task creation through the real FormspecBinding produces TaskCreated and TaskPresented provenance. Prefill data mirrors the initial case state via FixtureFormspecProcessor.",
  "documents": { "kernel": "inline" },
  "inline_documents": {
    "kernel": {
      "$wosKernel": "1.0",
      "url": "urn:test:s15-task-lifecycle",
      "version": "1.0.0",
      "title": "S15 Task Lifecycle Test",
      "description": "Kernel for S15 conformance fixtures testing FormspecBinding task lifecycle",
      "status": "active",
      "impactLevel": "operational",
      "actors": [
        { "id": "reviewer", "type": "human", "description": "Review actor" }
      ],
      "lifecycle": {
        "initialState": "open",
        "states": {
          "open": {
            "type": "atomic",
            "transitions": [{ "event": "start", "target": "review" }]
          },
          "review": {
            "type": "atomic",
            "onEntry": [{
              "action": "createTask",
              "taskRef": "reviewForm",
              "assignTo": "reviewer",
              "contractRef": "reviewContract",
              "responseMappingRef": "urn:mapping:response",
              "completionEvent": "review.completed",
              "failureEvent": "review.failed"
            }],
            "transitions": [
              { "event": "review.completed", "target": "approved" },
              { "event": "review.failed", "target": "rejected" }
            ]
          },
          "approved": { "type": "final" },
          "rejected": { "type": "final" }
        }
      },
      "contracts": {
        "reviewContract": {
          "binding": "formspec",
          "ref": "urn:formspec:review:1.0.0"
        }
      },
      "caseFile": { "fields": {} },
      "execution": {
        "workflowTimeout": "P90D",
        "defaultTaskTimeout": "P7D",
        "instanceVersioning": "pinned"
      }
    }
  },
  "initial_case_state": { "seed": 42 },
  "event_sequence": [
    { "event": "start", "actor": "reviewer" }
  ],
  "expected_transitions": [
    { "from": "open", "to": "review", "event": "start" }
  ],
  "expected_provenance": [
    { "recordKind": "taskCreated" },
    { "recordKind": "taskPresented" }
  ]
}
