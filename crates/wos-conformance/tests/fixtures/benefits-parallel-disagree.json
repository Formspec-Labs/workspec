{
  "id": "K-BA-002-parallel-reviewers-disagree",
  "rule": "K-PARALLEL-001",
  "description": "Reviewers disagree; $join fires to reconciliation then determination then denied",
  "documents": {
    "kernel": "../../../../fixtures/kernel/benefits-adjudication.json"
  },
  "initial_case_state": {
    "application": {
      "isComplete": true
    },
    "verification": {
      "status": "verified"
    },
    "reviewA": {
      "decision": "eligible"
    },
    "reviewB": {
      "decision": "ineligible"
    }
  },
  "event_sequence": [
    {
      "event": "applicationComplete",
      "actor": "intakeWorker"
    },
    {
      "event": "verificationComplete",
      "actor": "verificationSystem"
    },
    {
      "event": "reviewAComplete",
      "actor": "caseworkerA"
    },
    {
      "event": "reviewBComplete",
      "actor": "caseworkerB"
    },
    {
      "event": "reconciled",
      "actor": "supervisor"
    },
    {
      "event": "denied",
      "actor": "supervisor"
    }
  ],
  "expected_transitions": [
    {
      "from": "intake",
      "target": "incomeVerification",
      "event": "applicationComplete"
    },
    {
      "from": "incomeVerification",
      "target": "eligibilityReview",
      "event": "verificationComplete"
    },
    {
      "from": "pendingReviewA",
      "target": "reviewADone",
      "event": "reviewAComplete"
    },
    {
      "from": "pendingReviewB",
      "target": "reviewBDone",
      "event": "reviewBComplete"
    },
    {
      "from": "eligibilityReview",
      "target": "reconciliation",
      "event": "$join"
    },
    {
      "from": "reconciliation",
      "target": "determination",
      "event": "reconciled"
    },
    {
      "from": "determination",
      "target": "adverseNotice",
      "event": "denied"
    }
  ]
}