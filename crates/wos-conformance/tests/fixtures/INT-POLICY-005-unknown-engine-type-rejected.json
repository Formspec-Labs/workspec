{
  "id": "INT-POLICY-005-unknown-engine-type-rejected",
  "rule": "INT-POLICY",
  "description": "A policy-engine binding with an unrecognised engineType (not 'opa', 'cedar', or 'canonical') MUST be rejected with a RuntimeError. The error message must identify the unknown engine type. This verifies that the permissive wildcard fallback is gone and unknown engines fail fast.",
