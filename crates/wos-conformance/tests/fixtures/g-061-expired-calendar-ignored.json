{
  "id": "G-061-expired-calendar-ignored",
  "rule": "G-061",
  "description": "Processor MUST ignore an expired calendar and fall back to wall-clock time (BC S8.1). When a Business Calendar sidecar has an expirationDate in the past, SLA evaluation uses wall-clock days.",
  "documents": {
    "kernel": "../../../../fixtures/kernel/hold-resume-lifecycle.json",
    "governance": "../../../../fixtures/governance/hold-resume-governance.json",
    "businessCalendar": "../../../../fixtures/sidecars/benefits-business-calendar.json"
  },
  "initial_case_state": {},
  "event_sequence": [
    { "event": "needInfo", "actor": "caseworker" },
    {
      "event": "slaCheck",
      "actor": "system",
      "data": {
        "calendarExpired": true,
        "expirationDate": "2025-12-31"
      }
    }
  ],
  "expected_transitions": [
    { "from": "processing", "to": "pendingResponse", "event": "needInfo" }
  ],
  "expected_provenance": [
    { "record_kind": "calendarIgnored", "data": { "reason": "expired", "fallback": "wall-clock" } }
  ]
}
