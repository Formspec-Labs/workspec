{
  "binding": "formspec",
  "id": "SIG-019-tampered-signature-method",
  "rule": "SIG-RT",
  "description": "Authored signature whose signatureMethod has been byte-modified is currently admitted with primitiveVerification.status = deferredPendingHelper because the Formspec signing primitive is not yet executed at the binding (FORMSPEC-SIGN-HELPER-001 unshipped). When the signing helper lands and the binding actually verifies signatureValue/signatureMethod, this fixture flips into a Failed rejection vector and admission MUST block.",
  "documents": {
    "kernel": "../../../../fixtures/kernel/signature-runtime.json",
    "signatureProfile": "../../../../fixtures/profiles/signature-runtime-sequential.json"
  },
  "event_sequence": [
    {
      "event": "start",
      "actor": "applicant"
    },
    {
      "event": "submit",
      "task_submission": {
        "task_ref": "applicantTask",
        "response": {
          "status": "completed",
          "definitionUrl": "urn:test:formspec:signature",
          "definitionVersion": "1.0.0",
          "data": {
            "signerId": "applicant",
            "signatureProvider": "formspec",
            "ceremonyId": "ceremony-sequential",
            "signature": {
              "acceptedAt": "2026-04-22T12:00:00Z",
