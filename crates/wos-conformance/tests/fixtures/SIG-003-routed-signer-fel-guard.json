{
  "binding": "formspec",
  "id": "SIG-003-routed-signer-fel-guard",
  "rule": "SIG-RT",
  "description": "Routed signer path selected by FEL guard emits SignatureAffirmation.",
  "documents": {
    "kernel": "../../../../fixtures/kernel/signature-runtime.json",
    "signatureProfile": "../../../../fixtures/profiles/signature-runtime-routed.json"
  },
  "initial_case_state": { "routeApplicant": true },
  "event_sequence": [
    { "event": "start", "actor": "applicant" },
    {
      "event": "submit",
      "task_submission": {
        "task_ref": "applicantTask",
        "response": {
          "status": "completed",
          "definitionUrl": "urn:test:formspec:signature",
          "definitionVersion": "1.0.0",
          "data": {
            "signerId": "applicant",
            "signatureProvider": "formspec",
            "ceremonyId": "ceremony-routed",
            "signature": {
              "acceptedAt": "2026-04-22T12:03:00Z",
              "affirmed": true,
              "documentHash": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
            }
          }
        }
      }
    }
  ],
  "expected_transitions": [
    { "from": "draft", "to": "signing", "event": "start" },
    { "from": "signing", "to": "complete", "event": "signature.completed" }
  ],
  "expected_provenance": [
    { "recordKind": "signatureAffirmation", "data": { "roleId": "applicantSigner" } }
  ]
}
