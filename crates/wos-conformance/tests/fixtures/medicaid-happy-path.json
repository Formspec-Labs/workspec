{
  "id": "K-MR-001-happy-path",
  "rule": "K-COMPOUND-001",
  "description": "Medicaid intake through compound eligibilityReview to activeBenefits",
  "documents": {
    "kernel": "../../../../fixtures/kernel/medicaid-redetermination.json"
  },
  "initial_case_state": {
    "application": {
      "isComplete": true
    },
    "currentCycle": 0
  },
  "event_sequence": [
    {
      "event": "applicationComplete",
      "actor": "caseworker"
    },
    {
      "event": "verificationComplete",
      "actor": "verificationSystem"
    },
    {
      "event": "determinationComplete",
      "actor": "caseworker"
    },
    {
      "event": "eligible",
      "actor": "caseworker"
    }
  ],
  "expected_transitions": [
    {
      "from": "intake",
      "target": "eligibilityReview",
      "event": "applicationComplete"
    },
    {
      "from": "incomeVerification",
      "target": "caseworkerReview",
      "event": "verificationComplete"
    },
    {
      "from": "caseworkerReview",
      "target": "reviewComplete",
      "event": "determinationComplete"
    },
    {
      "from": "eligibilityReview",
      "target": "activeBenefits",
      "event": "eligible"
    }
  ]
}