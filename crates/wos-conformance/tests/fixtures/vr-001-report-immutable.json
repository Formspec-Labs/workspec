{
  "id": "VR-001-report-immutable",
  "rule": "VR-001",
  "description": "Verification report is immutable once produced (VerifReport S1). Attempting to modify a produced verification report is a violation.",
  "documents": {
    "kernel": "../../../../fixtures/kernel/dcr-zone.json",
    "advanced": "../../../../fixtures/advanced/dcr-zone-governance.json"
  },
  "initial_case_state": {},
  "event_sequence": [
    {
      "event": "$verificationReportProduced",
      "actor": "system",
      "data": {
        "reportId": "VR-2026-001",
        "timestamp": "2026-04-10T12:00:00Z"
      }
    },
    {
      "event": "$verificationReportModified",
      "actor": "system",
      "data": {
        "reportId": "VR-2026-001",
        "modification": {
          "field": "results[0].result",
          "from": "proven-safe",
          "target": "proven-unsafe"
        }
      }
    }
  ],
  "expected_transitions": [],
  "expected_provenance": [
    {
      "record_kind": "verificationReportProduced",
      "data": {
        "reportId": "VR-2026-001",
        "immutable": true
      }
    },
    {
      "record_kind": "immutabilityViolation",
      "data": {
        "reportId": "VR-2026-001",
        "reason": "modification-after-production"
      }
    }
  ]
}