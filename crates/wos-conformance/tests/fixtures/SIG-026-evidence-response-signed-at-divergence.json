    {
      "recordKind": "signatureAdmissionFailed",
      "data": {
        "reason": "evidence_divergence",
        "failureContext": {
          "field": "response.signature.acceptedAt",
          "expected": "2026-05-08T11:00:00Z",
          "actual": "2026-05-08T10:00:00Z"
