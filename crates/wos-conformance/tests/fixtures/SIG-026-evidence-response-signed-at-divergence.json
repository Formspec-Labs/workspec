{
  "binding": "formspec",
  "id": "SIG-026-evidence-response-signed-at-divergence",
  "rule": "SIG-RT",
  "description": "Response carries a consent-path signedAt that disagrees with the verified evidence's signed_at; runtime emits SignatureAdmissionFailed(evidence_divergence) so SignatureAffirmation provenance and the x-wos-signature-completions completion entry cannot disagree (review F4).",
  "documents": {
    "kernel": "../../../../fixtures/kernel/signature-runtime.json",
    "signatureProfile": "../../../../fixtures/profiles/signature-runtime-sequential.json"
  },
  "event_sequence": [
    {
      "event": "start",
      "actor": "applicant"
    },
    {
      "event": "submit",
      "task_submission": {
        "task_ref": "applicantTask",
        "response": {
          "status": "completed",
          "definitionUrl": "urn:test:formspec:signature",
          "definitionVersion": "1.0.0",
          "data": {
            "signerId": "applicant",
            "signatureProvider": "formspec",
            "ceremonyId": "ceremony-sig-026",
            "signature": {
              "acceptedAt": "2026-05-08T10:00:00Z",
              "affirmed": true,
              "documentHash": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
            }
          },
          "id": "resp-sig-026-evidence-response-signed-at-divergence-applicantTask",
          "authoredSignatures": [
            {
              "signatureId": "sig-sig-026-evidence-response-signed-at-divergence-applicantTask",
              "documentId": "application",
              "signingIntent": "urn:wos:signing-intent:applicant-signature",
              "signatureValue": "urn:test:signature:SIG-026-evidence-response-signed-at-divergence:applicantTask",
              "signatureMethod": "provider-managed",
              "signerId": "applicant",
              "signerName": "Applicant",
              "signedAt": "2026-05-08T11:00:00Z",
              "consentAccepted": true,
              "consentTextRef": "urn:test:consent:esign",
              "consentVersion": "1.0.0",
              "affirmationText": "I certify this signing act.",
              "signedPayload": {
                "canonicalization": "formspec-response-signing-v1",
                "digestAlgorithm": "sha-256",
                "digest": "bdac150ecfa641bbbc0ce2c78fa888d70ab7053a8c34b6d5d8100452b53b2741",
                "responseId": "resp-sig-026-evidence-response-signed-at-divergence-applicantTask",
                "definitionUrl": "urn:test:formspec:signature",
                "definitionVersion": "1.0.0"
              },
              "documentHash": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
              "documentHashAlgorithm": "sha-256",
              "signatureProvider": "formspec",
              "ceremonyId": "ceremony-sig-026"
            }
          ]
        }
      }
