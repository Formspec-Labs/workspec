{
  "binding": "formspec",
  "id": "K-H-D2-shallow-after-parallel-exit",
  "rule": "K-H",
  "description": "Shallow history at depth 2 with a parallel region: compound state 'review' has historyState=shallow and contains a parallel state 'taskGroup'. After advancing region A from 'aWorking' to 'aAdvanced', an interruption exits 'review'. Re-entry via resume should shallow-restore to 'taskGroup', which then re-initializes both regions to their initialStates ('aWorking', 'bWorking') — not the advanced state.",
  "documents": { "kernel": "inline" },
  "inline_documents": {
    "kernel": {
      "$wosKernel": "1.0",
      "url": "urn:test:history-shallow-d2-parallel",
      "version": "1.0.0",
      "title": "History Shallow Depth-2 Parallel Exit Test",
      "description": "Kernel for testing shallow history capture on parallel-region exit at depth 2",
      "status": "active",
      "impactLevel": "operational",
      "actors": [{ "id": "worker", "type": "human", "description": "Test actor" }],
      "lifecycle": {
        "initialState": "open",
        "states": {
          "open": {
            "type": "atomic",
            "transitions": [{ "event": "start", "target": "review" }]
          },
          "review": {
            "type": "compound",
            "historyState": "shallow",
            "initialState": "taskGroup",
            "states": {
              "taskGroup": {
                "type": "parallel",
                "regions": {
                  "regionA": {
                    "initialState": "aWorking",
                    "states": {
                      "aWorking": { "type": "atomic", "transitions": [{ "event": "advanceA", "target": "aAdvanced" }] },
                      "aAdvanced": { "type": "atomic" }
                    }
                  },
                  "regionB": {
                    "initialState": "bWorking",
                    "states": {
                      "bWorking": { "type": "atomic" }
                    }
                  }
                }
              }
            },
            "transitions": [
              { "event": "interrupt", "target": "interrupted" },
              { "event": "resume", "target": "review" }
            ]
          },
          "interrupted": {
            "type": "atomic",
            "transitions": [{ "event": "resume", "target": "review" }]
          }
        }
      },
      "caseFile": { "fields": {} },
      "execution": { "workflowTimeout": "P90D", "defaultTaskTimeout": "P7D", "instanceVersioning": "pinned" }
    }
  },
  "initial_case_state": {},
  "event_sequence": [
    { "event": "start", "actor": "worker" },
    { "event": "advanceA", "actor": "worker" },
    { "event": "interrupt", "actor": "worker" },
    { "event": "resume", "actor": "worker" },
    { "event": "advanceA", "actor": "worker" }
  ],
  "expected_transitions": [
    { "from": "open", "to": "review", "event": "start" },
    { "from": "aWorking", "to": "aAdvanced", "event": "advanceA" },
    { "from": "review", "to": "interrupted", "event": "interrupt" },
    { "from": "interrupted", "to": "review", "event": "resume" },
    { "from": "aWorking", "to": "aAdvanced", "event": "advanceA" }
  ],
  "expected_provenance": [
    { "recordKind": "historyCleared", "data": { "state": "review" } }
  ]
}
