{
  "id": "K-039-compensation-reverse-order",
  "rule": "K-039",
  "description": "Compensation in reverse of forward completion order (LCD S5.4). If steps completed A->B->C, compensation runs C->B->A.",
  "documents": {
    "kernel": "../../../../fixtures/kernel/compensation.json"
  },
  "initial_case_state": {},
  "event_sequence": [
    { "event": "advance", "actor": "operator" },
    { "event": "advance", "actor": "operator" },
    { "event": "fail", "actor": "system" }
  ],
  "expected_transitions": [
    { "from": "stepA", "to": "stepB", "event": "advance" },
    { "from": "stepB", "to": "stepC", "event": "advance" },
    { "from": "stepC", "to": "compensating", "event": "fail" }
  ],
  "expected_provenance": [
    { "record_kind": "compensationExecuted", "data": { "order": ["stepC", "stepB", "stepA"] } }
  ]
}
