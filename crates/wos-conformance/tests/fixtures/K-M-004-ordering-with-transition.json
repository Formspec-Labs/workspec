{
  "binding": "formspec",
  "id": "K-M-004-ordering-with-transition",
  "rule": "K-M",
  "description": "When a setData onEntry action fires and a task with a completionEvent is created in the same state, the provenance stream must read: CaseStateMutation \u2192 MilestoneFired \u2192 TaskCreated \u2192 (later) StateTransition. This verifies the pinned ordering: durable data write, then milestone fired, then reactive transitions drained. The expected_provenance field uses any-match semantics and cannot enforce ordering between entries; the ordering assertion is implemented as an inline Rust test in kernel_conformance.rs that checks absolute indices.",
  "documents": {
    "kernel": "inline"
  },
  "inline_documents": {
    "kernel": {
      "$wosWorkflow": "1.0",
      "url": "urn:test:milestone-ordering",
      "version": "1.0.0",
      "title": "Milestone Ordering With Transition",
      "status": "active",
      "impactLevel": "operational",
      "actors": [
        {
          "id": "reviewer",
          "type": "human",
          "description": "Review actor"
        }
      ],
      "lifecycle": {
        "initialState": "open",
        "states": {
          "open": {
            "type": "atomic",
            "transitions": [
              {
                "event": "start",
                "target": "review"
              }
            ]
          },
          "review": {
            "type": "atomic",
            "onEntry": [
              {
                "action": "setData",
                "path": "caseFile.inReview",
                "value": true
              },
              {
                "action": "createTask",
                "taskRef": "reviewForm",
                "assignTo": "reviewer",
                "contractRef": "reviewContract",
                "completionEvent": "review.completed",
                "failureEvent": "review.failed"
              }
            ],
            "transitions": [
              {
                "event": "review.completed",
                "target": "approved"
              },
              {
                "event": "review.failed",
                "target": "rejected"
              }
            ]
          },
          "approved": {
            "type": "final"
          },
          "rejected": {
            "type": "final"
          }
        },
        "milestones": {
          "reviewStarted": {
            "condition": "caseFile.inReview == true",
            "description": "Review has started"
          }
        }
      },
      "contracts": {
        "reviewContract": {
          "binding": "formspec",
          "ref": "urn:formspec:review:1.0.0"
        }
      },
      "caseFile": {
        "fields": {
          "inReview": {
            "type": "boolean"
          }
        }
      },
      "execution": {
        "workflowTimeout": "P90D",
        "defaultTaskTimeout": "P7D",
        "instanceVersioning": "pinned"
      }
    }
  },
  "initial_case_state": {
    "inReview": false
  },
  "event_sequence": [
    {
      "event": "start",
      "actor": "reviewer"
    },
    {
      "event": "submit",
      "actor": "reviewer",
      "task_submission": {
        "task_ref": "reviewForm",
        "response": {
          "status": "completed",
          "definitionUrl": "urn:formspec:review:1.0.0",
          "definitionVersion": "1.0.0",
          "data": {}
        }
      }
    }
  ],
  "expected_transitions": [
    {
      "from": "open",
      "to": "review",
      "event": "start"
    },
    {
      "from": "review",
      "to": "approved",
      "event": "review.completed"
    }
  ],
  "expected_provenance": [
    {
      "recordKind": "caseStateMutation"
    },
    {
      "recordKind": "milestoneFired",
      "data": {
        "milestoneId": "reviewStarted"
      }
    },
    {
      "recordKind": "taskCreated"
    },
    {
      "recordKind": "stateTransition"
    }
  ]
}