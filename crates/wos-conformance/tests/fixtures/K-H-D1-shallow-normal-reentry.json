{
  "binding": "formspec",
  "id": "K-H-D1-shallow-normal-reentry",
  "rule": "K-H",
  "description": "Shallow history at depth 1: compound state 'review' has historyState=shallow. After entering substate 'review.inProgress', an interruption exits to 'interrupted'. Re-entering 'review' should restore to 'inProgress' (the direct active substate) rather than the initialState.",
  "documents": {
    "kernel": "inline"
  },
  "inline_documents": {
    "kernel": {
      "$wosWorkflow": "1.0",
      "url": "urn:test:history-shallow-d1",
      "version": "1.0.0",
      "title": "History Shallow Depth-1 Test",
      "description": "Kernel for testing shallow history state re-entry at depth 1",
      "status": "active",
      "impactLevel": "operational",
      "actors": [
        {
          "id": "worker",
          "type": "human",
          "description": "Test actor"
        }
      ],
      "lifecycle": {
        "initialState": "open",
        "states": {
          "open": {
            "type": "atomic",
            "transitions": [
              {
                "event": "start",
                "target": "review"
              }
            ]
          },
          "review": {
            "type": "compound",
            "historyState": "shallow",
            "initialState": "pending",
            "states": {
              "pending": {
                "type": "atomic",
                "transitions": [
                  {
                    "event": "begin",
                    "target": "inProgress"
                  }
                ]
              },
              "inProgress": {
                "type": "atomic",
                "transitions": [
                  {
                    "event": "complete",
                    "target": "done"
                  }
                ]
              },
              "done": {
                "type": "final"
              }
            },
            "transitions": [
              {
                "event": "interrupt",
                "target": "interrupted"
              },
              {
                "event": "resume",
                "target": "review"
              }
            ]
          },
          "interrupted": {
            "type": "atomic",
            "transitions": [
              {
                "event": "resume",
                "target": "review"
              }
            ]
          }
        }
      },
      "caseFile": {
        "fields": {}
      },
      "execution": {
        "workflowTimeout": "P90D",
        "defaultTaskTimeout": "P7D",
        "instanceVersioning": "pinned"
      }
    }
  },
  "initial_case_state": {},
  "event_sequence": [
    {
      "event": "start",
      "actor": "worker"
    },
    {
      "event": "begin",
      "actor": "worker"
    },
    {
      "event": "interrupt",
      "actor": "worker"
    },
    {
      "event": "resume",
      "actor": "worker"
    }
  ],
  "expected_transitions": [
    {
      "from": "open",
      "target": "review",
      "event": "start"
    },
    {
      "from": "pending",
      "target": "inProgress",
      "event": "begin"
    },
    {
      "from": "review",
      "target": "interrupted",
      "event": "interrupt"
    },
    {
      "from": "interrupted",
      "target": "review",
      "event": "resume"
    }
  ],
  "expected_provenance": [
    {
      "recordKind": "historyCleared",
      "data": {
        "state": "review"
      }
    }
  ]
}