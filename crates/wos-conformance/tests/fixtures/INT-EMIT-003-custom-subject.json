{
  "id": "INT-EMIT-003-custom-subject",
  "rule": "INT-EMIT",
  "description": "When a binding declares an explicit 'subject' extension field, the event-emit handler uses it verbatim instead of the default {processId}:{bindingId}:{invocationId} format. This verifies that bindings can override the default subject template for custom routing or correlation requirements.",
  "documents": {
    "kernel": "inline",
    "integration": "inline"
  },
  "inline_documents": {
    "kernel": {
      "$wosWorkflow": "1.0",
      "url": "urn:test:INT-EMIT-003",
      "version": "1.0.0",
      "title": "INT-EMIT-003 Custom Subject Override",
      "status": "active",
      "impactLevel": "operational",
      "actors": [
        {
          "id": "operator",
          "type": "human",
          "description": "Workflow operator"
        }
      ],
      "lifecycle": {
        "initialState": "open",
        "states": {
          "open": {
            "type": "atomic",
            "transitions": [
              {
                "event": "notify",
                "target": "done",
                "actions": [
                  {
                    "action": "invokeService",
                    "serviceRef": "customSubjectBus"
                  }
                ]
              }
            ]
          },
          "done": {
            "type": "final"
          }
        }
      },
      "caseFile": {
        "fields": {}
      },
      "execution": {
        "workflowTimeout": "P90D",
        "defaultTaskTimeout": "P7D",
        "instanceVersioning": "pinned"
      }
    },
    "integration": {
      "$wosWorkflow": "1.0",
      "url": "https://example.test/migrated-fixture",
      "version": "1.0.0",
      "title": "Migrated Fixture",
      "impactLevel": "operational",
      "actors": [
        {
          "id": "system",
          "type": "system"
        }
      ],
      "lifecycle": {
        "initialState": "start",
        "states": {
          "start": {
            "type": "atomic",
            "transitions": [
              {
                "target": "done"
              }
            ]
          },
          "done": {
            "type": "final"
          }
        }
      },
      "bindings": {
        "targetWorkflow": {
          "url": "urn:test:INT-EMIT-003",
          "compatibleVersions": ">=1.0.0 <2.0.0"
        },
        "bindings": {
          "customSubjectBus": {
            "type": "event-emit",
            "description": "Emit with an explicit subject override",
            "source": "urn:wos:runtime",
            "eventType": "com.example.custom.notify",
            "subject": "custom/subject/override"
          }
        }
      }
    }
  },
  "initial_case_state": {},
  "event_sequence": [
    {
      "event": "notify",
      "actor": "operator"
    }
  ],
  "expected_transitions": [
    {
      "from": "open",
      "target": "done",
      "event": "notify"
    }
  ],
  "expected_provenance": [
    {
      "recordKind": "eventEmitted",
      "data": {
        "subject": "custom/subject/override"
      }
    }
  ]
}