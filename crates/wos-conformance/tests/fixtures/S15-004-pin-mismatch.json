{
  "binding": "formspec",
  "id": "S15-004-pin-mismatch",
  "rule": "S15",
  "description": "Task submission with wrong definition version in the envelope. FormspecBinding reports pin_match: false. Task fails with validationFailed, failureEvent fires.",
  "documents": {
    "kernel": "inline"
  },
  "inline_documents": {
    "kernel": {
      "$wosWorkflow": "1.0",
      "url": "urn:test:s15-task-lifecycle",
      "version": "1.0.0",
      "title": "S15 Task Lifecycle Test",
      "description": "Kernel for S15 conformance fixtures testing FormspecBinding task lifecycle",
      "status": "active",
      "impactLevel": "operational",
      "actors": [
        {
          "id": "reviewer",
          "type": "human",
          "description": "Review actor"
        }
      ],
      "lifecycle": {
        "initialState": "open",
        "states": {
          "open": {
            "type": "atomic",
            "transitions": [
              {
                "event": "start",
                "target": "review"
              }
            ]
          },
          "review": {
            "type": "atomic",
            "onEntry": [
              {
                "action": "createTask",
                "taskRef": "reviewForm",
                "assignTo": "reviewer",
                "contractRef": "reviewContract",
                "responseMappingRef": "urn:mapping:response",
                "completionEvent": "review.completed",
                "failureEvent": "review.failed"
              }
            ],
            "transitions": [
              {
                "event": "review.completed",
                "target": "approved"
              },
              {
                "event": "review.failed",
                "target": "rejected"
              }
            ]
          },
          "approved": {
            "type": "final"
          },
          "rejected": {
            "type": "final"
          }
        }
      },
      "contracts": {
        "reviewContract": {
          "binding": "formspec",
          "ref": "urn:formspec:review:1.0.0"
        }
      },
      "caseFile": {
        "fields": {}
      },
      "execution": {
        "workflowTimeout": "P90D",
        "defaultTaskTimeout": "P7D",
        "instanceVersioning": "pinned"
      }
    }
  },
  "initial_case_state": {},
  "event_sequence": [
    {
      "event": "start",
      "actor": "reviewer"
    },
    {
      "event": "submit",
      "actor": "reviewer",
      "task_submission": {
        "task_ref": "reviewForm",
        "response": {
          "status": "completed",
          "definitionUrl": "urn:formspec:review:1.0.0",
          "definitionVersion": "2.0.0",
          "data": {
            "approved": true
          }
        }
      }
    }
  ],
  "expected_transitions": [
    {
      "from": "open",
      "to": "review",
      "event": "start"
    },
    {
      "from": "review",
      "to": "rejected",
      "event": "review.failed"
    }
  ],
  "expected_provenance": [
    {
      "recordKind": "taskCreated"
    },
    {
      "recordKind": "taskPresented"
    },
    {
      "recordKind": "taskResponseSubmitted"
    },
    {
      "recordKind": "taskFailed"
    }
  ]
}