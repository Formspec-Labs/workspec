{
  "id": "K-024-persist-before-advance",
  "rule": "K-024",
  "description": "Non-deterministic output MUST persist before advancing state (Kernel S9.1, G3). The invokeService result is persisted as a step result before the lifecycle transitions.",
  "documents": {
    "kernel": "../../../../fixtures/kernel/durability.json"
  },
  "initial_case_state": {},
  "event_sequence": [
    {
      "event": "submit",
      "actor": "operator"
    },
    {
      "event": "verified",
      "actor": "verificationSystem",
      "data": {
        "serviceOutput": {
          "result": "pass",
          "score": 92
        }
      }
    }
  ],
  "expected_transitions": [
    {
      "from": "intake",
      "target": "review",
      "event": "submit"
    },
    {
      "from": "pendingReview",
      "target": "reviewComplete",
      "event": "verified"
    }
  ],
  "expected_provenance": [
    {
      "record_kind": "stepResultPersisted",
      "data": {
        "idempotencyKey": "${instance.id}-verify",
        "persistedBeforeAdvance": true
      }
    }
  ]
}