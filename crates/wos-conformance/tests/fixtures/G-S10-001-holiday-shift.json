{
  "id": "G-S10-001-holiday-shift",
  "rule": "G-S10",
  "description": "Business calendar skips a fixed holiday when the naive SLA deadline lands on it. Timer duration P3D from epoch (1970-01-01, Thursday) reaches Sunday 1970-01-04; the calendar snaps it past the weekend AND past Monday 1970-01-05 (fixed holiday) to Tuesday 1970-01-06 09:00 UTC. Clock advances P5DT9H to reach that moment, firing the timer and transitioning to done.",
  "documents": {
    "kernel": "inline",
    "businessCalendar": "inline"
  },
  "inline_documents": {
    "kernel": {
      "$wosWorkflow": "1.0",
      "url": "urn:test:bc-holiday-shift",
      "version": "1.0.0",
      "title": "BC S10-001 Holiday Shift",
      "status": "active",
      "impactLevel": "operational",
      "actors": [
        {
          "id": "system",
          "type": "system",
          "description": "System actor"
        }
      ],
      "lifecycle": {
        "initialState": "pending",
        "states": {
          "pending": {
            "type": "atomic",
            "onEntry": [
              {
                "action": "startTimer",
                "timerId": "slaTimer",
                "duration": "P3D",
                "event": "$timeout.slaTimer"
              }
            ],
            "transitions": [
              {
                "event": "$timeout.slaTimer",
                "target": "done"
              }
            ]
          },
          "done": {
            "type": "final"
          }
        }
      },
      "caseFile": {
        "fields": {}
      },
      "execution": {
        "workflowTimeout": "P90D",
        "defaultTaskTimeout": "P7D",
        "instanceVersioning": "pinned"
      }
    },
    "businessCalendar": {
      "$wosDelivery": "1.0",
      "targetWorkflow": "urn:test:bc-holiday-shift",
      "calendar": {
        "version": "test-v1.0",
        "timezone": "UTC",
        "workWeek": [
          "monday",
          "tuesday",
          "wednesday",
          "thursday",
          "friday"
        ],
        "holidays": [
          {
            "name": "Test Holiday Monday",
            "date": "1970-01-05"
          }
        ],
        "operatingHours": {
          "start": "09:00",
          "end": "17:00"
        }
      }
    }
  },
  "initial_case_state": {},
  "event_sequence": [
    {
      "event": "noop",
      "actor": "system",
      "delay": "P5DT9H"
    }
  ],
  "expected_transitions": [
    {
      "from": "pending",
      "target": "done",
      "event": "$timeout.slaTimer"
    }
  ],
  "expected_provenance": [
    {
      "record_kind": "timerCreated",
      "data": {
        "timerId": "slaTimer",
        "calendarVersion": "test-v1.0"
      }
    },
    {
      "record_kind": "timerFired",
      "data": {
        "timerId": "slaTimer"
      }
    }
  ]
}