  "documents": {
    "kernel": "../../../../fixtures/kernel/hold-resume-lifecycle.json",
    "governance": "../../../../fixtures/governance/hold-resume-governance.json"
  },
  "initial_case_state": {},
  "event_sequence": [
    { "event": "needInfo", "actor": "caseworker" },
    { "event": "applicantResponse", "actor": "applicant" }
  ],
  "expected_transitions": [
    { "from": "processing", "to": "pendingResponse", "event": "needInfo" },
    { "from": "pendingResponse", "to": "processing", "event": "applicantResponse" }
  ],
  "expected_provenance": [
    { "record_kind": "timerCreated", "data": { "timerId": "holdTimer" } },
    { "record_kind": "timerCancelled", "data": { "timerId": "holdTimer" } }
  ]
