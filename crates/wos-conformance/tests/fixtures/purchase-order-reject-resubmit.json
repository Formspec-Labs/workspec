{
  "id": "K-PO-003-reject-resubmit",
  "rule": "K-LIFECYCLE-001",
  "description": "Purchase order rejected, then resubmitted, then approved",
  "documents": {
    "kernel": "../../../../fixtures/kernel/purchase-order-approval.json"
  },
  "initial_case_state": {
    "amount": 10000,
    "orderId": "ORD-2026-003",
    "vendor": "Supplier X"
  },
  "event_sequence": [
    { "event": "reject", "actor": "approver" },
    { "event": "resubmit", "actor": "requester" },
    { "event": "approve", "actor": "approver" },
    { "event": "orderProcessed", "actor": "procurementSystem" }
  ],
  "expected_transitions": [
    { "from": "submitted", "to": "rejected", "event": "reject" },
    { "from": "rejected", "to": "submitted", "event": "resubmit" },
    { "from": "submitted", "to": "approved", "event": "approve" },
    { "from": "approved", "to": "completed", "event": "orderProcessed" }
  ]
}
