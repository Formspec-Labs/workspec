{
  "id": "K-PO-003-reject-resubmit",
  "rule": "K-LIFECYCLE-001",
  "description": "Purchase order rejected, then resubmitted, then approved",
  "documents": {
    "kernel": "../../../../fixtures/kernel/purchase-order-approval.json"
  },
  "initial_case_state": {
    "amount": 10000,
    "orderId": "ORD-2026-003",
    "vendor": "Supplier X"
  },
  "event_sequence": [
    {
      "event": "reject",
      "actor": "approver"
    },
    {
      "event": "resubmit",
      "actor": "requester"
    },
    {
      "event": "approve",
      "actor": "approver"
    },
    {
      "event": "orderProcessed",
      "actor": "procurementSystem"
    }
  ],
  "expected_transitions": [
    {
      "from": "submitted",
      "target": "rejected",
      "event": "reject"
    },
    {
      "from": "rejected",
      "target": "submitted",
      "event": "resubmit"
    },
    {
      "from": "submitted",
      "target": "approved",
      "event": "approve"
    },
    {
      "from": "approved",
      "target": "completed",
      "event": "orderProcessed"
    }
  ]
}