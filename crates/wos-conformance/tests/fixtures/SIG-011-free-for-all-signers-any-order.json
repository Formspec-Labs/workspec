{
  "binding": "formspec",
  "id": "SIG-011-free-for-all-signers-any-order",
  "rule": "SIG-RT",
  "description": "Free-for-all signers can complete in any order; completion waits for every selected required signature.",
  "documents": {
    "kernel": "../../../../fixtures/kernel/signature-runtime.json",
    "signatureProfile": "../../../../fixtures/profiles/signature-runtime-free-for-all.json"
  },
  "event_sequence": [
    { "event": "start", "actor": "agency" },
    {
      "event": "submit",
      "task_submission": {
        "task_ref": "agencyTask",
        "response": {
          "status": "completed",
          "definitionUrl": "urn:test:formspec:signature",
          "definitionVersion": "1.0.0",
          "data": {
            "signerId": "agency",
            "identityBinding": { "method": "credential", "assuranceLevel": "high" },
            "signatureProvider": "formspec",
            "ceremonyId": "ceremony-agency-free",
            "signature": {
              "acceptedAt": "2026-04-22T12:01:00Z",
              "affirmed": true,
              "documentHash": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
            }
          }
        }
      }
    },
    {
      "event": "submit",
      "task_submission": {
        "task_ref": "applicantTask",
        "response": {
          "status": "completed",
          "definitionUrl": "urn:test:formspec:signature",
          "definitionVersion": "1.0.0",
          "data": {
            "signerId": "applicant",
            "identityBinding": { "method": "email-otp", "assuranceLevel": "standard" },
            "signatureProvider": "formspec",
            "ceremonyId": "ceremony-applicant-free",
            "signature": {
              "acceptedAt": "2026-04-22T12:02:00Z",
              "affirmed": true,
              "documentHash": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
            }
          }
        }
      }
    }
  ],
  "expected_transitions": [
    { "from": "draft", "to": "signing", "event": "start" },
    { "from": "signing", "to": "complete", "event": "signature.completed" }
  ],
  "expected_provenance": [
    { "recordKind": "signatureAffirmation", "data": { "roleId": "agencyApprover" } },
    { "recordKind": "signatureAffirmation", "data": { "roleId": "applicantSigner" } }
  ]
}
