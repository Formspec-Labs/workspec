{
  "id": "K-026-idempotency-dedup",
  "rule": "K-026",
  "description": "IdempotencyKey MUST deduplicate invocations (Kernel S9.3). The first event with a key proceeds normally; sending the same key again produces dedup provenance and the duplicate is ignored.",
  "documents": {
    "kernel": "../../../../fixtures/kernel/durability.json"
  },
  "initial_case_state": {},
  "event_sequence": [
    {
      "event": "submit",
      "actor": "operator"
    },
    {
      "event": "verified",
      "actor": "verificationSystem",
      "data": {
        "idempotencyKey": "test-dedup-key"
      }
    },
    {
      "event": "verified",
      "actor": "verificationSystem",
      "data": {
        "idempotencyKey": "test-dedup-key"
      }
    }
  ],
  "expected_transitions": [
    {
      "from": "intake",
      "target": "review",
      "event": "submit"
    },
    {
      "from": "pendingReview",
      "target": "reviewComplete",
      "event": "verified"
    }
  ],
  "expected_provenance": [
    {
      "record_kind": "idempotencyDedup",
      "data": {
        "key": "test-dedup-key",
        "duplicateIgnored": true
      }
    }
  ]
}