{
  "binding": "formspec",
  "id": "K-H-D2-shallow-normal-reentry",
  "rule": "K-H",
  "description": "Shallow history at depth 2: compound state 'review' has historyState=shallow. After progressing into 'inProgress.advancedPhase', an interruption exits to 'interrupted'. Re-entering 'review' via resume must shallow-restore only the depth-1 substate 'inProgress', which then re-enters its own initialState 'subPhase' — NOT 'advancedPhase'. A subsequent 'nextPhase' event succeeds from 'subPhase', proving shallow restore. Under deep restore, the machine would already be at 'advancedPhase' and 'nextPhase' would be unmatched.",
  "documents": { "kernel": "inline" },
  "inline_documents": {
    "kernel": {
      "$wosKernel": "1.0",
      "url": "urn:test:history-shallow-d2",
      "version": "1.0.0",
      "title": "History Shallow Depth-2 Test",
      "description": "Kernel for testing shallow history state re-entry at depth 2",
      "status": "active",
      "impactLevel": "operational",
      "actors": [{ "id": "worker", "type": "human", "description": "Test actor" }],
      "lifecycle": {
        "initialState": "open",
        "states": {
          "open": {
            "type": "atomic",
            "transitions": [{ "event": "start", "target": "review" }]
          },
          "review": {
            "type": "compound",
            "historyState": "shallow",
            "initialState": "inProgress",
            "states": {
              "inProgress": {
                "type": "compound",
                "initialState": "subPhase",
                "states": {
                  "subPhase": {
                    "type": "atomic",
                    "transitions": [{ "event": "nextPhase", "target": "advancedPhase" }]
                  },
                  "advancedPhase": {
                    "type": "atomic",
                    "transitions": [{ "event": "complete", "target": "done" }]
                  }
                }
              },
              "done": { "type": "final" }
            },
            "transitions": [
              { "event": "interrupt", "target": "interrupted" }
            ]
          },
          "interrupted": {
            "type": "atomic",
            "transitions": [{ "event": "resume", "target": "review" }]
          }
        }
      },
      "caseFile": { "fields": {} },
      "execution": { "workflowTimeout": "P90D", "defaultTaskTimeout": "P7D", "instanceVersioning": "pinned" }
    }
  },
  "initial_case_state": {},
  "event_sequence": [
    { "event": "start", "actor": "worker" },
    { "event": "nextPhase", "actor": "worker" },
    { "event": "interrupt", "actor": "worker" },
    { "event": "resume", "actor": "worker" },
    { "event": "nextPhase", "actor": "worker" }
  ],
  "expected_transitions": [
    { "from": "open", "to": "review", "event": "start" },
    { "from": "subPhase", "to": "advancedPhase", "event": "nextPhase" },
    { "from": "review", "to": "interrupted", "event": "interrupt" },
    { "from": "interrupted", "to": "review", "event": "resume" },
    { "from": "subPhase", "to": "advancedPhase", "event": "nextPhase" }
  ],
  "expected_provenance": [
    { "recordKind": "historyCleared", "data": { "state": "review" } }
  ]
}
