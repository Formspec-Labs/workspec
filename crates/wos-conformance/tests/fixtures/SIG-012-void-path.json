{
  "binding": "formspec",
  "id": "SIG-012-void-path",
  "rule": "SIG-RT",
  "description": "Authorized void records reason evidence and cancels the active signature task set without emitting completion.",
  "documents": {
    "kernel": "../../../../fixtures/kernel/signature-runtime.json",
    "signatureProfile": "../../../../fixtures/profiles/signature-runtime-sequential.json"
  },
  "event_sequence": [
    {
      "event": "start",
      "actor": "caseworker"
    },
    {
      "event": "submit",
      "task_submission": {
        "task_ref": "adminTask",
        "response": {
          "status": "voided",
          "definitionUrl": "urn:test:formspec:signature",
          "definitionVersion": "1.0.0",
          "data": {
            "reason": "Application withdrawn before signature."
          }
        }
      }
    }
  ],
  "expected_transitions": [
    {
      "from": "draft",
      "target": "signing",
      "event": "start"
    }
  ],
  "expected_provenance": [
    {
      "recordKind": "taskDismissed",
      "data": {
        "details": {
          "signatureStatus": "voided",
          "cancelledTaskCount": 5
        }
      }
    }
  ]
}
