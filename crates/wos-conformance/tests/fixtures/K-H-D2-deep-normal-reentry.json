{
  "binding": "formspec",
  "id": "K-H-D2-deep-normal-reentry",
  "rule": "K-H",
  "description": "Deep history at depth 2: compound state 'review' has historyState=deep. After progressing into 'inProgress.advancedPhase' (a sibling of inProgress.initialState), an interruption exits to 'interrupted'. Re-entering 'review' via resume must deep-restore to 'advancedPhase' directly. A subsequent 'complete' event succeeds only from 'advancedPhase' — if shallow were used instead, re-entry would land at 'subPhase' (inProgress.initialState) and 'complete' would be unmatched.",
  "documents": { "kernel": "inline" },
  "inline_documents": {
    "kernel": {
      "$wosKernel": "1.0",
      "url": "urn:test:history-deep-d2",
      "version": "1.0.0",
      "title": "History Deep Depth-2 Test",
      "description": "Kernel for testing deep history state re-entry at depth 2",
      "status": "active",
      "impactLevel": "operational",
      "actors": [{ "id": "worker", "type": "human", "description": "Test actor" }],
      "lifecycle": {
        "initialState": "open",
        "states": {
          "open": {
            "type": "atomic",
            "transitions": [{ "event": "start", "target": "review" }]
          },
          "review": {
            "type": "compound",
            "historyState": "deep",
            "initialState": "inProgress",
            "states": {
              "inProgress": {
                "type": "compound",
                "initialState": "subPhase",
                "states": {
                  "subPhase": {
                    "type": "atomic",
                    "transitions": [{ "event": "nextPhase", "target": "advancedPhase" }]
                  },
                  "advancedPhase": {
                    "type": "atomic",
                    "transitions": [{ "event": "complete", "target": "done" }]
                  }
                }
              },
              "done": { "type": "final" }
            },
            "transitions": [
              { "event": "interrupt", "target": "interrupted" }
            ]
          },
          "interrupted": {
            "type": "atomic",
            "transitions": [{ "event": "resume", "target": "review" }]
          }
        }
      },
      "caseFile": { "fields": {} },
      "execution": { "workflowTimeout": "P90D", "defaultTaskTimeout": "P7D", "instanceVersioning": "pinned" }
    }
  },
  "initial_case_state": {},
  "event_sequence": [
    { "event": "start", "actor": "worker" },
    { "event": "nextPhase", "actor": "worker" },
    { "event": "interrupt", "actor": "worker" },
    { "event": "resume", "actor": "worker" },
    { "event": "complete", "actor": "worker" }
  ],
  "expected_transitions": [
    { "from": "open", "to": "review", "event": "start" },
    { "from": "subPhase", "to": "advancedPhase", "event": "nextPhase" },
    { "from": "review", "to": "interrupted", "event": "interrupt" },
    { "from": "interrupted", "to": "review", "event": "resume" },
    { "from": "advancedPhase", "to": "done", "event": "complete" }
  ],
  "expected_provenance": [
    { "recordKind": "historyCleared", "data": { "state": "review" } }
  ]
}
