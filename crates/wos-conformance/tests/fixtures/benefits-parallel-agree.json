{
  "id": "K-BA-001-parallel-reviewers-agree",
  "rule": "K-PARALLEL-001",
  "description": "Both reviewers agree on eligible; $join fires to determination, then approved to benefitsActive",
  "documents": {
    "kernel": "../../../../fixtures/kernel/benefits-adjudication.json"
  },
  "initial_case_state": {
    "application": {
      "isComplete": true
    },
    "verification": {
      "status": "verified"
    },
    "reviewA": {
      "decision": "eligible"
    },
    "reviewB": {
      "decision": "eligible"
    }
  },
  "event_sequence": [
    {
      "event": "applicationComplete",
      "actor": "intakeWorker"
    },
    {
      "event": "verificationComplete",
      "actor": "verificationSystem"
    },
    {
      "event": "reviewAComplete",
      "actor": "caseworkerA"
    },
    {
      "event": "reviewBComplete",
      "actor": "caseworkerB"
    },
    {
      "event": "approved",
      "actor": "supervisor"
    }
  ],
  "expected_transitions": [
    {
      "from": "intake",
      "target": "incomeVerification",
      "event": "applicationComplete"
    },
    {
      "from": "incomeVerification",
      "target": "eligibilityReview",
      "event": "verificationComplete"
    },
    {
      "from": "pendingReviewA",
      "target": "reviewADone",
      "event": "reviewAComplete"
    },
    {
      "from": "pendingReviewB",
      "target": "reviewBDone",
      "event": "reviewBComplete"
    },
    {
      "from": "eligibilityReview",
      "target": "determination",
      "event": "$join"
    },
    {
      "from": "determination",
      "target": "benefitsActive",
      "event": "approved"
    }
  ]
}