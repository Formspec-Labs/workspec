              },
              "documentHash": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
              "documentHashAlgorithm": "sha-256",
              "signatureProvider": "formspec",
              "ceremonyId": "ceremony-sig-029"
