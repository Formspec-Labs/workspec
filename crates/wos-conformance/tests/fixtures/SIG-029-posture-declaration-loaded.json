              "documentId": "application",
              "signingIntent": "urn:wos:signing-intent:applicant-signature",
              "signatureValue": "0oRYSKMBJwRQAAAAAAAAAAAAAAAAAAAAADoAAQADeCx1cm46Zm9ybXNwZWM6c2lnLW1ldGhvZDplZDI1NTE5LWNvc2Utc2lnbjFAMaD2WEAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
              "signerId": "applicant",
              "signerName": "Applicant",
              "signedAt": "2026-05-08T12:00:00Z",
              "consentAccepted": true,
