{
  "id": "K-011-determinism",
  "rule": "K-011",
  "description": "Same document and same event sequence must produce the same state transitions on every run. Feed 'approve' with amount=3000 (under the $50k guard) to the purchase order workflow. Expects submitted→approved deterministically.",
  "documents": {
    "kernel": "fixtures/kernel/purchase-order-approval.json"
  },
  "initial_case_state": {
    "amount": 3000,
    "orderId": "PO-2026-001",
    "vendor": "Acme Corp"
  },
  "event_sequence": [
    {
      "event": "approve",
      "actor": "approver",
      "data": {
        "amount": 3000,
        "orderId": "PO-2026-001",
        "vendor": "Acme Corp"
      }
    }
  ],
  "expected_transitions": [
    {
      "from": "submitted",
      "to": "approved",
      "event": "approve"
    }
  ],
  "expected_provenance": [
    {
      "type": "stateTransition",
      "from": "submitted",
      "to": "approved",
      "actorId": "approver"
    }
  ],
  "expected_errors": []
}
