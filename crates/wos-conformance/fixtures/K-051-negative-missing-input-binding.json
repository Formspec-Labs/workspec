{
  "id": "K-051-negative-missing-input-binding",
  "rule": "K-051",
  "description": "Negative case: DecisionTableGuard.inputBindings is missing an entry for a declared table input. The table declares two inputs (income + householdSize); the guard binds only `income`. Per Kernel §4.5.1, every declared input MUST have a binding; the lint MUST emit K-051.",
  "documents": {
    "kernel": "inline"
  },
  "inline_documents": {
    "kernel": {
      "$wosWorkflow": "1.0",
      "$schema": "https://wos-spec.org/schemas/workflow/1.0",
      "url": "https://test.example/workflows/k-051-missing-binding",
      "version": "1.0.0",
      "title": "K-051 Negative — Missing inputBinding",
      "description": "Guard binds `income` only; table also declares `householdSize`. K-051 fires.",
      "status": "active",
      "impactLevel": "operational",
      "actors": [{ "id": "caseworker", "type": "human", "description": "Caseworker" }],
      "lifecycle": {
        "initialState": "intake",
        "states": {
          "intake": {
            "type": "atomic",
            "transitions": [
              {
                "event": "submit",
                "target": "approved",
                "guard": {
                  "kind": "decisionTable",
                  "ref": "eligibilityTable",
                  "outputColumn": "eligible",
                  "inputBindings": { "income": "caseFile.income" }
                }
              }
            ]
          },
          "approved": { "type": "final" }
        }
      },
      "decisionTables": [
        {
          "id": "eligibilityTable",
          "inputs": [
            { "name": "income", "type": "number" },
            { "name": "householdSize", "type": "integer" }
          ],
          "outputs": [{ "name": "eligible", "type": "boolean" }],
          "rows": [{ "id": "r1", "inputCells": ["income <= 1473", "householdSize == 1"], "outputCells": ["true"] }],
          "hitPolicy": "first"
        }
      ],
      "caseFile": { "fields": {} },
      "execution": {
        "workflowTimeout": "P30D",
        "defaultTaskTimeout": "P7D",
        "instanceVersioning": "pinned"
      }
    }
  },
  "event_sequence": [],
  "expected_transitions": [],
  "expected_provenance": [],
  "expected_errors": [
    "K-051: DecisionTableGuard at lifecycle.states.intake.transitions[0].guard is missing inputBindings entry for declared input 'householdSize' (table 'eligibilityTable')"
  ]
}
