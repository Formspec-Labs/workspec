{
  "id": "AI-AUTO-002-drift-alert-demotion",
  "rule": "AI-AUTO-002",
  "description": "Drift-alert-triggered demotion path: when a drift alert fires (per the DriftMonitor's alertThresholds with action=demoteToAssistive), the runtime MUST (1) emit driftReclassification provenance, (2) emit autonomyDemotion provenance with trigger='drift-alert', and (3) reroute the event through escalation so the kernel routes to the human-review state. Pairs with AI-028 (humanOverride-triggered demotion), AC-001 (calibration-expiry cap), and AI-AUTO-001 (escalation-expiry revocation) to close the autonomy-lifecycle revocation matrix (AI S5.5; DriftMonitor AlertThreshold\u2192DemotionRule binding).",
  "documents": {
    "kernel": "fixtures/kernel/autonomy-caps.json",
    "ai": "fixtures/ai/autonomy-caps-ai.json",
    "agent-config": "fixtures/ai/autonomy-caps-agent-config.json",
    "drift-monitor": "inline"
  },
  "inline_documents": {
    "drift-monitor": {
      "$wosWorkflow": "1.0",
      "version": "1.0.0",
      "url": "https://example.test/migrated-fixture",
      "title": "Migrated Fixture",
      "impactLevel": "operational",
      "actors": [
        {
          "id": "system",
          "type": "system"
        }
      ],
      "lifecycle": {
        "initialState": "start",
        "states": {
          "start": {
            "type": "atomic",
            "transitions": [
              {
                "target": "done"
              }
            ]
          },
          "done": {
            "type": "final"
          }
        }
      },
      "agents": {
        "targetWorkflow": "https://test.wos-spec.org/workflows/autonomy-caps",
        "monitors": [
          {
            "agentRef": "triageAgent",
            "evaluationWindow": "P30D",
            "metrics": [
              {
                "name": "extractionAccuracy",
                "method": "accuracy",
                "threshold": 0.85
              }
            ],
            "alertThresholds": [
              {
                "condition": "extractionAccuracy < 0.85",
                "severity": "critical",
                "action": "demoteToAssistive",
                "policyRef": "demoteOnLowAccuracyOrViolation"
              }
            ]
          }
        ]
      }
    }
  },
  "initial_case_state": {},
  "event_sequence": [
    {
      "event": "triaged",
      "actor": "triageAgent",
      "data": {
        "output": {
          "action": "categorize",
          "category": "benefits"
        },
        "driftAlert": {
          "type": "extractionAccuracy",
          "severity": "critical",
          "policyRef": "demoteOnLowAccuracyOrViolation"
        },
        "triggerDemotion": "drift-alert"
      }
    }
  ],
  "expected_transitions": [
    {
      "from": "triage",
      "target": "humanTriage",
      "event": "escalated"
    }
  ],
  "expected_provenance": [
    {
      "recordKind": "autonomyDemotion",
      "data": {
        "agentId": "triageAgent",
        "from": "autonomous",
        "target": "assistive",
        "trigger": "drift-alert",
        "effectiveAt": "next-invocation",
        "policyRef": "demoteOnLowAccuracyOrViolation",
        "demotionRuleId": "demoteOnLowAccuracyOrViolation"
      }
    },
    {
      "recordKind": "driftReclassification",
      "data": {
        "originalClassification": "assistive",
        "reclassifiedTo": "determination"
      }
    }
  ],
  "expected_errors": []
}