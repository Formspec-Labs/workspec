{
  "id": "K-FOREACH-BODY-001-iteration-body-actions",
  "rule": "K-FOREACH-001",
  "description": "ForEach with body.onEntry actions: per Sub-PR D-3, the body's onEntry actions execute once per iteration, attributed to the synthetic lifecycle state `<foreach-state>:body`. This fixture iterates over three attachments and uses a setData action in body.onEntry to write a heartbeat field on each iteration. After the loop, the foreach state's anonymous outgoing transition fires with synthetic event `$foreachComplete` and the workflow lands on `completed`. Three OnEntry provenance records and three caseStateMutation records (all attributed to `processAttachments:body`) are expected. body.onExit actions and outputPath / mergeStrategy writes remain Sub-PR D-4.",
  "documents": {
    "kernel": "inline"
  },
  "inline_documents": {
    "kernel": {
      "$wosWorkflow": "1.0",
      "url": "https://test.wos-spec.org/workflows/foreach-body-actions",
      "version": "1.0.0",
      "title": "ForEach Body Actions — Per-Iteration Mutation",
      "impactLevel": "operational",
      "actors": [
        {
          "id": "system",
          "type": "system"
        }
      ],
      "caseFile": {
        "fields": {
          "attachments": {
            "type": "array"
          },
          "heartbeat": {
            "type": "string"
          }
        }
      },
      "lifecycle": {
        "initialState": "intake",
        "states": {
          "intake": {
            "type": "atomic",
            "transitions": [
              {
                "event": {
                  "kind": "message",
                  "name": "submitted"
                },
                "target": "processAttachments"
              }
            ]
          },
          "processAttachments": {
            "type": "foreach",
            "collection": "caseFile.attachments",
            "itemVariable": "currentAttachment",
            "indexVariable": "currentIndex",
            "body": {
              "type": "atomic",
              "onEntry": [
                {
                  "action": "setData",
                  "path": "caseFile.heartbeat",
                  "value": "iterating"
                }
              ]
            },
            "transitions": [
              {
                "target": "completed"
              }
            ]
          },
          "completed": {
            "type": "final"
          }
        }
      }
    }
  },
  "initial_case_state": {
    "attachments": [
      {"id": "a1", "name": "passport.pdf"},
      {"id": "a2", "name": "lease.pdf"},
      {"id": "a3", "name": "income.pdf"}
    ]
  },
  "event_sequence": [
    {
      "event": "submitted",
      "actor": "system"
    }
  ],
  "expected_transitions": [
    {
      "from": "intake",
      "target": "processAttachments",
      "event": "submitted"
    },
    {
      "from": "processAttachments",
      "target": "completed",
      "event": "$foreachComplete"
    }
  ],
  "expected_provenance": [
    {
      "recordKind": "foreachIterationStarted",
      "data": {
        "foreachState": "processAttachments",
        "index": 0
      }
    },
    {
      "recordKind": "onEntry",
      "toState": "processAttachments:body",
      "data": {
        "actionType": "setData"
      }
    },
    {
      "recordKind": "caseStateMutation",
      "toState": "processAttachments:body"
    },
    {
      "recordKind": "foreachIterationCompleted",
      "data": {
        "foreachState": "processAttachments",
        "index": 0
      }
    },
    {
      "recordKind": "foreachIterationStarted",
      "data": {
        "foreachState": "processAttachments",
        "index": 2
      }
    },
    {
      "recordKind": "foreachCompleted",
      "data": {
        "foreachState": "processAttachments",
        "iterations": 3,
        "broke": false
      }
    }
  ],
  "expected_errors": []
}
