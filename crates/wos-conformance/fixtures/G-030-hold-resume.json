{
  "id": "G-030-hold-resume",
  "rule": "G-030",
  "description": "On entering a hold state the processor must start a timer; when the resume trigger arrives before the timer fires, the timer must be cancelled. Uses medicaid-redetermination: advance to pendingApplicantResponse (hold state, starts 'applicantResponseDeadline' timer with P30D), then fire 'applicantResponse' to trigger resume. Expects the timer cancellation provenance record.",
  "documents": {
    "kernel": "fixtures/kernel/medicaid-redetermination.json"
  },
  "initial_case_state": {
    "application": {
      "isComplete": true
    },
    "verification": {
      "status": "verified"
    },
    "eligibility": {
      "decision": "eligible"
    }
  },
  "event_sequence": [
    {
      "event": "applicationComplete",
      "actor": "caseworker",
      "data": {
        "application": {
          "isComplete": true
        }
      }
    },
    {
      "event": "verificationComplete",
      "actor": "verificationSystem",
      "data": {
        "verification": {
          "status": "verified"
        }
      }
    },
    {
      "event": "determinationComplete",
      "actor": "caseworker",
      "data": {
        "eligibility": {
          "decision": "eligible"
        }
      }
    },
    {
      "event": "eligible",
      "actor": "caseworker",
      "data": {}
    },
    {
      "event": "$timeout.state",
      "actor": "system",
      "data": {}
    },
    {
      "event": "redeterminationSubmitted",
      "actor": "applicant",
      "data": {}
    },
    {
      "event": "verificationComplete",
      "actor": "verificationSystem",
      "data": {
        "verification": {
          "status": "verified"
        }
      }
    },
    {
      "event": "determinationComplete",
      "actor": "caseworker",
      "data": {}
    },
    {
      "event": "eligible",
      "actor": "caseworker",
      "data": {}
    },
    {
      "event": "$timeout.state",
      "actor": "system",
      "description": "12-month cycle expires \u2014 enters redeterminationDue",
      "data": {}
    },
    {
      "event": "$timeout.state",
      "actor": "system",
      "description": "30-day redetermination notice window expires \u2014 enters pendingApplicantResponse (hold state)",
      "data": {}
    },
    {
      "event": "applicantResponse",
      "actor": "applicant",
      "data": {
        "application": {
          "isComplete": true
        }
      }
    }
  ],
  "expected_transitions": [
    {
      "from": "intake",
      "target": "eligibilityReview",
      "event": "applicationComplete"
    },
    {
      "from": "incomeVerification",
      "target": "caseworkerReview",
      "event": "verificationComplete"
    },
    {
      "from": "caseworkerReview",
      "target": "reviewComplete",
      "event": "determinationComplete"
    },
    {
      "from": "eligibilityReview",
      "target": "activeBenefits",
      "event": "eligible"
    },
    {
      "from": "activeBenefits",
      "target": "redeterminationDue",
      "event": "$timeout.state"
    },
    {
      "from": "redeterminationDue",
      "target": "eligibilityReview",
      "event": "redeterminationSubmitted"
    },
    {
      "from": "incomeVerification",
      "target": "caseworkerReview",
      "event": "verificationComplete"
    },
    {
      "from": "caseworkerReview",
      "target": "reviewComplete",
      "event": "determinationComplete"
    },
    {
      "from": "eligibilityReview",
      "target": "activeBenefits",
      "event": "eligible"
    },
    {
      "from": "activeBenefits",
      "target": "redeterminationDue",
      "event": "$timeout.state"
    },
    {
      "from": "redeterminationDue",
      "target": "pendingApplicantResponse",
      "event": "$timeout.state"
    },
    {
      "from": "pendingApplicantResponse",
      "target": "intake",
      "event": "applicantResponse"
    }
  ],
  "expected_provenance": [
    {
      "recordKind": "timerCreated",
      "data": {
        "timerId": "applicantResponseDeadline",
        "duration": "P30D"
      }
    },
    {
      "recordKind": "timerCancelled",
      "data": {
        "timerId": "applicantResponseDeadline"
      }
    },
    {
      "recordKind": "stateTransition",
      "fromState": "pendingApplicantResponse",
      "toState": "intake",
      "actorId": "applicant"
    }
  ],
  "expected_errors": []
}