{
  "id": "G-030-hold-resume",
  "rule": "G-030",
  "description": "On entering a hold state the processor must start a timer; when the resume trigger arrives before the timer fires, the timer must be cancelled. Uses medicaid-redetermination: advance to pendingApplicantResponse (hold state, starts 'applicantResponseDeadline' timer with P30D), then fire 'applicantResponse' to trigger resume. Expects the timer cancellation provenance record.",
  "documents": {
    "kernel": "fixtures/kernel/medicaid-redetermination.json"
  },
  "initial_case_state": {
    "application": { "isComplete": true },
    "verification": { "status": "verified" },
    "eligibility": { "decision": "eligible" }
  },
  "event_sequence": [
    {
      "event": "applicationComplete",
      "actor": "caseworker",
      "data": {
        "application": { "isComplete": true }
      }
    },
    {
      "event": "verificationComplete",
      "actor": "verificationSystem",
      "data": {
        "verification": { "status": "verified" }
      }
    },
    {
      "event": "determinationComplete",
      "actor": "caseworker",
      "data": {
        "eligibility": { "decision": "eligible" }
      }
    },
    {
      "event": "eligible",
      "actor": "caseworker",
      "data": {}
    },
    {
      "event": "$timeout.state",
      "actor": "system",
      "data": {}
    },
    {
      "event": "redeterminationSubmitted",
      "actor": "applicant",
      "data": {}
    },
    {
      "event": "verificationComplete",
      "actor": "verificationSystem",
      "data": {
        "verification": { "status": "verified" }
      }
    },
    {
      "event": "determinationComplete",
      "actor": "caseworker",
      "data": {}
    },
    {
      "event": "eligible",
      "actor": "caseworker",
      "data": {}
    },
    {
      "event": "$timeout.state",
      "actor": "system",
      "description": "12-month cycle expires — enters redeterminationDue",
      "data": {}
    },
    {
      "event": "$timeout.state",
      "actor": "system",
      "description": "30-day redetermination notice window expires — enters pendingApplicantResponse (hold state)",
      "data": {}
    },
    {
      "event": "applicantResponse",
      "actor": "applicant",
      "data": {
        "application": { "isComplete": true }
      }
    }
  ],
  "expected_transitions": [
    { "from": "intake", "to": "eligibilityReview", "event": "applicationComplete" },
    { "from": "incomeVerification", "to": "caseworkerReview", "event": "verificationComplete" },
    { "from": "caseworkerReview", "to": "reviewComplete", "event": "determinationComplete" },
    { "from": "eligibilityReview", "to": "activeBenefits", "event": "eligible" },
    { "from": "activeBenefits", "to": "redeterminationDue", "event": "$timeout.state" },
    { "from": "redeterminationDue", "to": "eligibilityReview", "event": "redeterminationSubmitted" },
    { "from": "incomeVerification", "to": "caseworkerReview", "event": "verificationComplete" },
    { "from": "caseworkerReview", "to": "reviewComplete", "event": "determinationComplete" },
    { "from": "eligibilityReview", "to": "activeBenefits", "event": "eligible" },
    { "from": "activeBenefits", "to": "redeterminationDue", "event": "$timeout.state" },
    { "from": "redeterminationDue", "to": "pendingApplicantResponse", "event": "$timeout.state" },
    { "from": "pendingApplicantResponse", "to": "intake", "event": "applicantResponse" }
  ],
  "expected_provenance": [
    {
      "recordKind": "timerCreated",
      "data": { "timerId": "applicantResponseDeadline", "duration": "P30D" }
    },
    {
      "recordKind": "timerCancelled",
      "data": { "timerId": "applicantResponseDeadline" }
    },
    {
      "recordKind": "stateTransition",
      "fromState": "pendingApplicantResponse",
      "toState": "intake",
      "actorId": "applicant"
    }
  ],
  "expected_errors": []
}
