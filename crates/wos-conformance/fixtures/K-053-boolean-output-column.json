{
  "id": "K-053-boolean-output-column",
  "rule": "K-053",
  "description": "Positive case: a transition guard's DecisionTableGuard.outputColumn references a `boolean`-typed output column on the table; input cells evaluate to boolean; hitPolicy is `first` (not `collect`). All Kernel \u00a74.5.1.4 cell-shape constraints are satisfied. Lint MUST NOT emit K-053.",
  "documents": {
    "kernel": "inline"
  },
  "inline_documents": {
    "kernel": {
      "$wosWorkflow": "1.0",
      "$schema": "https://wos-spec.org/schemas/workflow/1.0",
      "url": "https://test.example/workflows/k-053-positive",
      "version": "1.0.0",
      "title": "K-053 Positive \u2014 Boolean output column",
      "status": "active",
      "impactLevel": "operational",
      "actors": [
        {
          "id": "caseworker",
          "type": "human",
          "description": "Caseworker"
        }
      ],
      "lifecycle": {
        "initialState": "intake",
        "states": {
          "intake": {
            "type": "atomic",
            "transitions": [
              {
                "event": "submit",
                "target": "approved",
                "guard": {
                  "kind": "decisionTable",
                  "ref": "eligibilityTable",
                  "outputColumn": "eligible",
                  "inputBindings": {
                    "income": "caseFile.income"
                  }
                }
              }
            ]
          },
          "approved": {
            "type": "final"
          }
        }
      },
      "decisionTables": [
        {
          "id": "eligibilityTable",
          "inputs": [
            {
              "name": "income",
              "type": "number"
            }
          ],
          "outputs": [
            {
              "name": "eligible",
              "type": "boolean"
            }
          ],
          "rows": [
            {
              "id": "r1",
              "inputCells": [
                "income <= 1473"
              ],
              "outputCells": [
                "true"
              ]
            },
            {
              "id": "rDefault",
              "inputCells": [],
              "outputCells": [
                "false"
              ]
            }
          ],
          "hitPolicy": "first"
        }
      ],
      "caseFile": {
        "fields": {}
      },
      "execution": {
        "workflowTimeout": "P30D",
        "defaultTaskTimeout": "P7D",
        "instanceVersioning": "pinned"
      }
    }
  },
  "event_sequence": [],
  "expected_transitions": [],
  "expected_provenance": [],
  "expected_errors": []
}
