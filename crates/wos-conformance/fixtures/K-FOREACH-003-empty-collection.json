{
  "id": "K-FOREACH-003-empty-collection",
  "rule": "K-FOREACH-001",
  "description": "ForEach over an empty collection: when the FEL `collection` expression evaluates to [], no iterations happen and the foreach state's outgoing transitions fire immediately. This fixture exercises the empty-iterator fast path the evaluator implements today (full non-empty iteration is Sub-PR D-2). Schema validity + transition reachability are the assertions.",
  "documents": {
    "kernel": "inline"
  },
  "inline_documents": {
    "kernel": {
      "$wosWorkflow": "1.0",
      "url": "https://test.wos-spec.org/workflows/foreach-empty",
      "version": "1.0.0",
      "title": "ForEach Iteration — Empty Collection",
      "impactLevel": "operational",
      "actors": [
        {
          "id": "system",
          "type": "system"
        }
      ],
      "caseFile": {
        "fields": {
          "attachments": {
            "type": "array"
          }
        }
      },
      "lifecycle": {
        "initialState": "intake",
        "states": {
          "intake": {
            "type": "atomic",
            "transitions": [
              {
                "event": {
                  "kind": "message",
                  "name": "submitted"
                },
                "target": "processAttachments"
              }
            ]
          },
          "processAttachments": {
            "type": "foreach",
            "collection": "caseFile.attachments",
            "body": {
              "type": "atomic"
            },
            "transitions": [
              {
                "target": "completed"
              }
            ]
          },
          "completed": {
            "type": "final"
          }
        }
      }
    }
  },
  "initial_case_state": {
    "attachments": []
  },
  "event_sequence": [
    {
      "event": "submitted",
      "actor": "system"
    }
  ],
  "expected_transitions": [
    {
      "from": "intake",
      "target": "processAttachments",
      "event": "submitted"
    }
  ],
  "expected_provenance": [],
  "expected_errors": []
}
