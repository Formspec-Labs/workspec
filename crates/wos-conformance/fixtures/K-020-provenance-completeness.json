{
  "id": "K-020-provenance-completeness",
  "rule": "K-020",
  "description": "Every state transition and case mutation must produce a Facts-tier provenance record. Walk the purchase order through its full happy path: submit → approve (amount=3000, guard passes) → orderProcessed. Expect a provenance record for each state transition and each setData mutation.",
  "documents": {
    "kernel": "fixtures/kernel/purchase-order-approval.json"
  },
  "initial_case_state": {
    "amount": 3000,
    "orderId": "PO-2026-042",
    "vendor": "Office Supplies Inc"
  },
  "event_sequence": [
    {
      "event": "approve",
      "actor": "approver",
      "data": {
        "amount": 3000,
        "orderId": "PO-2026-042",
        "vendor": "Office Supplies Inc",
        "actorId": "approver"
      }
    },
    {
      "event": "orderProcessed",
      "actor": "procurementSystem",
      "data": {
        "processingRef": "PROC-2026-042"
      }
    }
  ],
  "expected_transitions": [
    {
      "from": "submitted",
      "to": "approved",
      "event": "approve"
    },
    {
      "from": "approved",
      "to": "completed",
      "event": "orderProcessed"
    }
  ],
  "expected_provenance": [
    {
      "recordKind": "stateTransition",
      "fromState": "submitted",
      "toState": "approved",
      "actorId": "approver"
    },
    {
      "recordKind": "caseStateMutation",
      "data": { "path": "caseFile.approvedBy" }
    },
    {
      "recordKind": "caseStateMutation",
      "data": { "path": "caseFile.approvedAt" }
    },
    {
      "recordKind": "stateTransition",
      "fromState": "approved",
      "toState": "completed",
      "actorId": "procurementSystem"
    }
  ],
  "expected_errors": []
}
