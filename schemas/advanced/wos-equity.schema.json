{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wos-spec.org/schemas/equity/1.0",
  "title": "WOS Equity Config",
  "description": "A WOS Equity Config sidecar document. Provides detailed equity monitoring configuration -- protected category definitions, disparity calculation methods, reporting schedules, remediation triggers. Equity monitoring applies to human AND AI decisions.",
  "type": "object",
  "required": ["$wosEquityConfig", "targetWorkflow"],
  "patternProperties": {
    "^x-": {
      "$comment": "Vendor extensions per Kernel spec §10.6 (extensions escape hatch)"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$wosEquityConfig": {
      "type": "string",
      "const": "1.0",
      "description": "WOS Equity Config specification version. MUST be '1.0'.",
      "examples": ["1.0"],
      "x-lm": {
        "critical": true,
        "intent": "Document type marker for WOS Equity Config sidecar"
      }
    },
    "$schema": { "$ref": "#/$defs/JsonSchemaUri" },
    "targetWorkflow": {
      "type": "string",
      "format": "uri",
      "description": "URI of the WOS Kernel Document this config targets. Follows the same targetWorkflow binding pattern as Layer 1 and Layer 2 sidecars.",
      "examples": ["https://agency.gov/workflows/benefits-adjudication"],
      "x-lm": { "critical": true, "intent": "Binds this sidecar to the monitored workflow" }
    },
    "version": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "protectedCategories": {
      "type": "array",
      "items": { "$ref": "#/$defs/ProtectedCategory" },
      "description": "Demographic or categorical groupings for equity monitoring."
    },
    "disparityMethods": {
      "type": "array",
      "items": { "$ref": "#/$defs/DisparityMethod" },
      "description": "Statistical methods for computing disparity."
    },
    "reportingSchedule": {
      "$ref": "#/$defs/ReportingSchedule",
      "description": "Automated equity reporting configuration."
    },
    "remediationTriggers": {
      "type": "array",
      "items": { "$ref": "#/$defs/RemediationTrigger" },
      "description": "Conditions that trigger structured remediation review."
    },
    "extensions": { "$ref": "#/$defs/ExtensionsMap" }
  },
  "$defs": {
    "ProtectedCategory": {
      "type": "object",
      "required": ["id", "groupByPath"],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1, "examples": ["geographicRegion", "ageGroup"] },
        "groupByPath": { "type": "string", "minLength": 1, "description": "Case file path for grouping.", "examples": ["caseFile.application.geographicRegion"] },
        "description": { "type": "string" },
        "groups": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Expected group values for validation."
        }
      }
    },
    "DisparityMethod": {
      "type": "object",
      "required": ["id", "method"],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "method": {
          "type": "string",
          "enum": ["rateDifference", "rateRatio", "standardizedDifference", "chi2"],
          "description": "Statistical method for disparity calculation."
        },
        "description": { "type": "string" }
      }
    },
    "ReportingSchedule": {
      "type": "object",
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "frequency": { "type": "string", "description": "ISO 8601 duration.", "examples": ["P30D", "P7D"] },
        "recipientRoles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "examples": [["equityOfficer", "programDirector"]]
        },
        "includeHistoricalTrend": { "type": "boolean", "default": true }
      }
    },
    "RemediationTrigger": {
      "type": "object",
      "required": ["condition", "action"],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "condition": { "type": "string", "minLength": 1, "description": "Condition expression.", "examples": ["disparity > 0.20 for 2 consecutive periods"] },
        "action": {
          "type": "string",
          "enum": ["review", "audit", "suspend", "notify"],
          "description": "Action to take."
        },
        "notifyRoles": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "description": { "type": "string" }
      }
    }
  ,
    "ExtensionsMap": {
      "type": "object",
      "description": "Vendor extension data attached to this node. All keys MUST start with 'x-' (see Kernel §10.6). The reserved namespace 'x-wos-*' is for WOS Working Group use only; third-party extensions MUST use a unique vendor prefix (e.g., 'x-acme-', 'x-vendor-'). Processors MUST ignore unknown extension keys to preserve forward compatibility. Extension values are unconstrained — any JSON value is valid, but authors are encouraged to document the shape in their vendor spec.",
      "examples": [
        { "x-acme-audit-ref": "AUD-2026-001" },
        { "x-vendor-tier": "gold", "x-vendor-region": "us-east" }
      ],
      "propertyNames": { "pattern": "^x-" },
      "additionalProperties": {}
    },
    "JsonSchemaUri": {
      "type": "string",
      "format": "uri",
      "description": "Optional JSON Schema URI enabling editor validation and autocompletion. When present, editors (VS Code, IntelliJ, etc.) validate the document against this schema. Omit in production documents; the authoritative schema URI is derived from the document type marker (e.g., '$wosKernel': '1.0'). Used for author-time tooling only — runtime processors MUST ignore this field.",
      "examples": [
        "https://wos-spec.org/schemas/kernel/wos-kernel.schema.json",
        "https://wos-spec.org/schemas/governance/wos-workflow-governance.schema.json"
      ]
    }
  }
}
