{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wos-spec.org/schemas/provenance-log/1.0",
  "title": "WOS Provenance Log",
  "description": "Append-only audit log produced by WOS runtime execution. Per ADR 0063 §2.3 this is a runtime artifact (not author-time), emitted by processors, never hand-authored. The required `$wosProvenanceLog` marker gives runtime artifacts the same identity discipline as author-time documents and lets the lint parser detect them uniformly. Wraps every persisted record kind: state-transition records (Kernel §8), case-file snapshots (Kernel §8 — required when transitionTags includes 'determination'), capability-invocation records (AI Integration §3.3.1), signature-affirmation records (Signature Profile §2.8), case-state mutation records carrying mutationSource / verificationLevel (Kernel §5.4, ADR 0080), iteration records (Kernel §4.10/foreach), and verification certificates (formerly the runtime half of `wos-verification-report`). Facts-tier semantics are normative in the kernel and live in the merged `wos-workflow.schema.json` $defs (ADR 0076 step 5 promotion: FactsTierRecord, MutationSource, VerificationLevel, CaseFileSnapshot, CapabilityInvocationRecord). Higher tiers reuse the same envelope with `auditLayer` set accordingly. This schema validates the post-append export shape -- not unstamped in-memory constructors.",
  "type": "object",
  "required": [
    "$wosProvenanceLog",
    "provenanceLog"
  ],
  "additionalProperties": false,
  "properties": {
    "$wosProvenanceLog": {
      "type": "string",
      "const": "1.0",
      "description": "Top-level marker identifying this object as a WOS Provenance Log runtime artifact, pinned to the 1.0 line. Required per ADR 0063 §2.3 so the lint parser detects runtime artifacts uniformly with author-time documents.",
      "examples": [
        "1.0"
      ]
    },
    "provenanceLog": {
      "type": "array",
      "description": "Ordered sequence of persisted provenance records emitted during a workflow run. Records are append-only and their order matches emission order; consumers MUST preserve ordering when re-exporting.",
      "examples": [
        [
          {
            "id": "sba-poc_prov_01jqrpd32jf8xtx9qxkkv3rqsd",
            "recordKind": "stateTransition",
            "timestamp": "2026-04-19T12:00:00Z",
            "auditLayer": "facts",
            "actorId": "caseworker",
            "actorType": "human",
            "fromState": "review",
            "toState": "decided",
            "event": "decide",
            "definitionVersion": "1.0.0",
            "lifecycleState": "review",
            "transitionTags": [
              "determination"
            ],
            "caseFileSnapshot": {
              "value": {
                "income": 17500,
                "eligible": true
              },
              "jcsCanonical": "{\"eligible\":true,\"income\":17500}",
              "sha256": "b19f000c0cd497b52c4a78e50641651e4b1e96931a1b1558984d69e722f73f5e"
            }
          }
        ]
      ],
      "items": {
        "allOf": [
          {
            "$ref": "https://wos-spec.org/schemas/wos-workflow.schema.json#/$defs/FactsTierRecord"
          },
          {
            "$ref": "#/$defs/CaseCreatedRecord"
          },
          {
            "$ref": "#/$defs/IntakeAcceptedRecord"
          },
          {
            "$ref": "#/$defs/IntakeRejectedRecord"
          },
          {
            "$ref": "#/$defs/IntakeDeferredRecord"
          },
          {
            "$ref": "#/$defs/SignatureAffirmationRecord"
          }
        ]
      }
    }
  },
  "$defs": {
    "CaseCreatedRecord": {
      "type": "object",
      "description": "Shape constraint layered on Facts-tier provenance records that mark the governed-case boundary. The kernel reserves the `caseCreated` kind and the canonical event literal `case.created`, and it requires the created governed-case reference in `data.caseRef`. The kernel does not freeze the rest of the binding-specific `data` keys; bindings may carry different evidence references inside `data` as long as the record still identifies the created governed case.",
      "examples": [
        {
          "id": "sba-poc_prov_01jqrpd32jf8xtx9qxkkv3rqsd",
          "recordKind": "caseCreated",
          "timestamp": "2026-04-23T12:00:00Z",
          "auditLayer": "facts",
          "event": "case.created",
          "definitionVersion": "1.0.0",
          "inputs": [
            "handoff-public-2026-0001"
          ],
          "outputs": [
            "sba-poc_case_01jqrpd32jf8xtx9qxkkv3rqsc"
          ],
          "data": {
            "caseRef": "sba-poc_case_01jqrpd32jf8xtx9qxkkv3rqsc",
            "initiationMode": "publicIntake"
          }
        }
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "recordKind": {
                "const": "caseCreated"
              }
            },
            "required": [
              "recordKind"
            ]
          },
          "then": {
            "required": [
              "event",
              "data",
              "outputs"
            ],
            "properties": {
              "event": {
                "const": "case.created"
              },
              "outputs": {
                "type": "array",
                "minItems": 1
              },
              "data": {
                "$ref": "#/$defs/CaseCreatedData"
              }
            }
          }
        }
      ]
    },
    "IntakeAcceptedRecord": {
      "type": "object",
      "description": "Shape constraint layered on Facts-tier provenance records emitted when runtime intake acceptance succeeds. Accepted intake creates or updates governed-case handling, so the record MUST carry the canonical event literal `case.intake.accepted`, binding/intake context in `data`, the accepted case disposition, the canonical governed-case reference, and at least one governed-case output reference.",
      "examples": [
        {
          "id": "sba-poc_prov_01jqt0f0wm8f4b7n1j6m2r3k4p",
          "recordKind": "intakeAccepted",
          "timestamp": "2026-04-23T12:00:00Z",
          "auditLayer": "facts",
          "event": "case.intake.accepted",
          "definitionVersion": "1.0.0",
          "inputs": [
            "handoff-public-2026-0001"
          ],
          "outputs": [
            "sba-poc_case_01jqrpd32jf8xtx9qxkkv3rqsc"
          ],
          "data": {
            "binding": "formspec",
            "intakeId": "handoff-public-2026-0001",
            "caseIntent": "requestGovernedCaseCreation",
            "caseDisposition": "createGovernedCase",
            "caseRef": "sba-poc_case_01jqrpd32jf8xtx9qxkkv3rqsc"
          }
        }
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "recordKind": {
                "const": "intakeAccepted"
              }
            },
            "required": [
              "recordKind"
            ]
          },
          "then": {
            "required": [
              "event",
              "data",
              "outputs"
            ],
            "properties": {
              "event": {
                "const": "case.intake.accepted"
              },
              "outputs": {
                "type": "array",
                "minItems": 1
              },
              "data": {
                "$ref": "#/$defs/IntakeAcceptedData"
              }
            }
          }
        }
      ]
    },
    "IntakeRejectedRecord": {
      "type": "object",
      "description": "Shape constraint layered on Facts-tier provenance records emitted when runtime intake acceptance rejects a handoff. Rejection records remain detached from governed case mutation and therefore do not require governed-case outputs.",
      "examples": [
        {
          "id": "sba-poc_prov_01jqt0f0wm8f4b7n1j6m2r3k4p",
          "recordKind": "intakeRejected",
          "timestamp": "2026-04-23T12:00:00Z",
          "auditLayer": "facts",
          "event": "case.intake.rejected",
          "definitionVersion": "1.0.0",
          "inputs": [
            "handoff-public-2026-0001"
          ],
          "data": {
            "binding": "formspec",
            "intakeId": "handoff-public-2026-0001",
            "caseIntent": "requestGovernedCaseCreation",
            "code": "publicIntakeDisabled"
          }
        }
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "recordKind": {
                "const": "intakeRejected"
              }
            },
            "required": [
              "recordKind"
            ]
          },
          "then": {
            "required": [
              "event",
              "data"
            ],
            "properties": {
              "event": {
                "const": "case.intake.rejected"
              },
              "data": {
                "$ref": "#/$defs/IntakeDecisionData"
              }
            }
          }
        }
      ]
    },
    "IntakeDeferredRecord": {
      "type": "object",
      "description": "Shape constraint layered on Facts-tier provenance records emitted when runtime intake acceptance defers a handoff. Deferred records preserve intake context and reason code without creating or updating governed case state.",
      "examples": [
        {
          "id": "sba-poc_prov_01jqt0f0wm8f4b7n1j6m2r3k4p",
          "recordKind": "intakeDeferred",
          "timestamp": "2026-04-23T12:00:00Z",
          "auditLayer": "facts",
          "event": "case.intake.deferred",
          "definitionVersion": "1.0.0",
          "inputs": [
            "handoff-public-2026-0001"
          ],
          "data": {
            "binding": "formspec",
            "intakeId": "handoff-public-2026-0001",
            "caseIntent": "requestGovernedCaseCreation",
            "code": "manualReviewRequired"
          }
        }
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "recordKind": {
                "const": "intakeDeferred"
              }
            },
            "required": [
              "recordKind"
            ]
          },
          "then": {
            "required": [
              "event",
              "data"
            ],
            "properties": {
              "event": {
                "const": "case.intake.deferred"
              },
              "data": {
                "$ref": "#/$defs/IntakeDecisionData"
              }
            }
          }
        }
      ]
    },
    "CaseCreatedData": {
      "type": "object",
      "description": "Kernel-owned minimum payload for a governed-case boundary record. `caseRef` identifies the created governed case; bindings may add their own evidence references alongside it.",
      "required": [
        "caseRef"
      ],
      "additionalProperties": true,
      "properties": {
        "caseRef": {
          "type": "string",
          "minLength": 1,
          "description": "Governed-case reference created or acknowledged by the boundary event.",
          "examples": [
            "sba-poc_case_01jqrpd32jf8xtx9qxkkv3rqsc"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          }
        }
      }
    },
    "IntakeDecisionData": {
      "type": "object",
      "description": "Minimum runtime-owned payload for non-accepted intake decision provenance. The kernel fixes the intake identity, binding discriminator, and case intent fields so exports and offline verifiers can trace the rejection or deferral back to a concrete handoff. Bindings or host profiles may add more fields.",
      "required": [
        "binding",
        "intakeId",
        "caseIntent"
      ],
      "additionalProperties": true,
      "properties": {
        "binding": {
          "type": "string",
          "minLength": 1,
          "description": "Binding discriminator that interpreted the handoff, such as `formspec`.",
          "examples": [
            "formspec"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          }
        },
        "intakeId": {
          "type": "string",
          "minLength": 1,
          "description": "Stable intake identity used for replay and provenance correlation.",
          "examples": [
            "handoff-public-2026-0001"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          }
        },
        "caseIntent": {
          "type": "string",
          "enum": [
            "attachToExistingCase",
            "requestGovernedCaseCreation"
          ],
          "description": "Binding-derived intent before host policy chose attach, create, reject, or defer.",
          "examples": [
            "requestGovernedCaseCreation"
          ]
        },
        "code": {
          "type": "string",
          "minLength": 1,
          "description": "Machine-readable rejection or deferral code when intake was not accepted.",
          "examples": [
            "publicIntakeDisabled",
            "manualReviewRequired"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          }
        }
      }
    },
    "IntakeAcceptedData": {
      "allOf": [
        {
          "$ref": "#/$defs/IntakeDecisionData"
        }
      ],
      "type": "object",
      "description": "Kernel-owned minimum payload for an accepted intake decision. Accepted intake records MUST identify the runtime's final case disposition and canonical governed-case reference so exports and offline verifiers can bind the intake handoff to the governed case that was created or attached.",
      "required": [
        "binding",
        "intakeId",
        "caseIntent",
        "caseDisposition",
        "caseRef"
      ],
      "additionalProperties": true,
      "properties": {
        "caseDisposition": {
          "type": "string",
          "enum": [
            "attachToExistingCase",
            "createGovernedCase"
          ],
          "description": "Final accepted case disposition when the runtime accepted the handoff.",
          "examples": [
            "createGovernedCase"
          ]
        },
        "caseRef": {
          "type": "string",
          "minLength": 1,
          "description": "Governed-case reference selected by the runtime when acceptance attaches or creates a case.",
          "examples": [
            "sba-poc_case_01jqrpd32jf8xtx9qxkkv3rqsc"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          }
        },
        "definitionUrl": {
          "type": "string",
          "format": "uri",
          "description": "Kernel definition URL used when acceptance created a governed case.",
          "examples": [
            "https://example.gov/wos/benefits-intake"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          },
          "minLength": 1
        },
        "definitionVersion": {
          "type": "string",
          "minLength": 1,
          "description": "Kernel definition version used when acceptance created a governed case.",
          "examples": [
            "1.0.0"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          }
        }
      }
    },
    "SignatureAffirmationRecord": {
      "type": "object",
      "description": "Shape constraint layered on Facts-tier provenance records emitted by the Signature Profile. A `recordKind == \"signatureAffirmation\"` record MUST carry the signer, role, document, source signature id, signed-payload digest, signing intent, timestamp, identity-binding, consent, provider, ceremony, profile, source response/evidence reference, and custody eligibility fields required by Signature Profile §2.8.",
      "examples": [
        {
          "id": "sba-poc_prov_01jqrpd32jf8xtx9qxkkv3rqsd",
          "recordKind": "signatureAffirmation",
          "timestamp": "2026-04-22T14:30:00Z",
          "auditLayer": "facts",
          "definitionVersion": "1.0.0",
          "data": {
            "signerId": "applicant",
            "roleId": "applicantSigner",
            "role": "signer",
            "documentId": "benefitsApplication",
            "documentHash": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
            "documentHashAlgorithm": "sha-256",
            "sourceSignatureSystem": "formspec",
            "sourceSignatureId": "sig-2026-0001",
            "signedPayloadDigest": "abcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcd",
            "signedPayloadDigestAlgorithm": "sha-256",
            "signingIntent": "urn:wos:signing-intent:applicant-signature",
            "signedAt": "2026-04-22T14:30:00Z",
            "identityBinding": {
              "method": "email-otp",
              "assuranceLevel": "standard",
              "providerRef": "urn:agency.gov:identity:providers:email-otp"
            },
            "consentReference": {
              "consentTextRef": "urn:agency.gov:consent:esign-benefits:v1",
              "consentVersion": "1.0.0",
              "acceptedAtPath": "response.signature.acceptedAt",
              "affirmationPath": "response.signature.affirmed"
            },
            "signatureProvider": "urn:agency.gov:signature:providers:formspec",
            "ceremonyId": "ceremony-2026-0001",
            "profileRef": "urn:agency.gov:wos:signature-profile:benefits:v1",
            "sourceResponseRef": "urn:agency.gov:formspec:responses:benefits:case-2026-0001",
            "custodyHookEligible": true
          }
        }
      ],
      "properties": {
        "recordKind": {
          "type": "string",
          "description": "`signatureAffirmation` selects records emitted when a Signature Profile signing act is accepted.",
          "examples": [
            "signatureAffirmation"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          },
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "recordKind": {
                "const": "signatureAffirmation"
              }
            },
            "required": [
              "recordKind"
            ]
          },
          "then": {
            "required": [
              "data"
            ],
            "properties": {
              "data": {
                "$ref": "#/$defs/SignatureAffirmationData"
              }
            }
          }
        }
      ]
    },
    "SignatureAffirmationData": {
      "type": "object",
      "description": "Required payload for a Signature Profile affirmation provenance record. Source signature identity and signed-payload digest fields identify the verified signature evidence that WOS accepted; identity-binding and consent-reference shapes remain provider-neutral so Formspec and external ceremony adapters can map into the same WOS evidence record.",
      "additionalProperties": false,
      "required": [
        "signerId",
        "roleId",
        "role",
        "documentId",
        "documentHash",
        "documentHashAlgorithm",
        "sourceSignatureSystem",
        "sourceSignatureId",
        "signedPayloadDigest",
        "signedPayloadDigestAlgorithm",
        "signingIntent",
        "signedAt",
        "identityBinding",
        "consentReference",
        "signatureProvider",
        "ceremonyId",
        "sourceResponseRef",
        "custodyHookEligible"
      ],
      "oneOf": [
        {
          "required": [
            "profileRef"
          ],
          "not": {
            "required": [
              "profileKey"
            ]
          }
        },
        {
          "required": [
            "profileKey"
          ],
          "not": {
            "required": [
              "profileRef"
            ]
          }
        }
      ],
      "properties": {
        "signerId": {
          "type": "string",
          "minLength": 1,
          "description": "Stable signer identifier from the ceremony context or assigned WOS actor.",
          "examples": [
            "applicant"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          }
        },
        "roleId": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
          "description": "Signature Profile role id that was satisfied by this accepted signing act.",
          "examples": [
            "applicantSigner"
          ]
        },
        "role": {
          "type": "string",
          "enum": [
            "signer",
            "in-person-signer",
            "certified-recipient",
            "witness",
            "notary",
            "approver",
            "form-filler",
            "viewer"
          ],
          "description": "Signature Profile role literal that defines the signer ceremony semantics.",
          "examples": [
            "signer"
          ]
        },
        "documentId": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
          "description": "Signature Profile document id whose declared digest was affirmed by the signer.",
          "examples": [
            "benefitsApplication"
          ]
        },
        "documentHash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64,128}$",
          "description": "Digest of the document bytes that the signer affirmed during the ceremony.",
          "examples": [
            "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
          ]
        },
        "documentHashAlgorithm": {
          "type": "string",
          "pattern": "^(sha-256|sha-384|sha-512|x-[a-z0-9][a-z0-9-]*)$",
          "description": "Digest algorithm used to compute documentHash for the affirmed document.",
          "examples": [
            "sha-256"
          ]
        },
        "sourceSignatureSystem": {
          "type": "string",
          "minLength": 1,
          "description": "Binding or provider family that supplied the verified signature evidence.",
          "examples": [
            "formspec"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          }
        },
        "sourceSignatureId": {
          "type": "string",
          "minLength": 1,
          "description": "Source-system signature identifier accepted into this WOS governance affirmation.",
          "examples": [
            "sig-2026-0001"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          }
        },
        "signedPayloadDigest": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64,128}$",
          "description": "Source signature evidence digest for the signer-assented payload. This is distinct from any transferred response-envelope hash.",
          "examples": [
            "abcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcd"
          ],
          "x-wos": {
            "openStringKind": "hash"
          }
        },
        "signedPayloadDigestAlgorithm": {
          "type": "string",
          "pattern": "^(sha-256|sha-384|sha-512|x-[a-z0-9][a-z0-9-]*)$",
          "description": "Digest algorithm used to compute signedPayloadDigest for the signer-assented source payload.",
          "examples": [
            "sha-256"
          ]
        },
        "signingIntent": {
          "type": "string",
          "format": "uri",
          "description": "WOS signing-intent URI accepted for this affirmation; it MUST equal the consumed source signature evidence intent.",
          "examples": [
            "urn:wos:signing-intent:applicant-signature"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          },
          "minLength": 1
        },
        "signedAt": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 timestamp when the signer accepted the signing act and consent.",
          "examples": [
            "2026-04-22T14:30:00Z"
          ],
          "x-wos": {
            "openStringKind": "timestamp"
          },
          "minLength": 1
        },
        "identityBinding": {
          "$ref": "#/$defs/SignatureIdentityBinding"
        },
        "consentReference": {
          "$ref": "#/$defs/SignatureConsentReference"
        },
        "signatureProvider": {
          "type": "string",
          "minLength": 1,
          "description": "Provider or adapter that supplied the signing ceremony evidence.",
          "examples": [
            "urn:agency.gov:signature:providers:formspec"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          }
        },
        "ceremonyId": {
          "type": "string",
          "minLength": 1,
          "description": "Provider or adapter ceremony identifier for the accepted signing session.",
          "examples": [
            "ceremony-2026-0001"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          }
        },
        "profileRef": {
          "type": "string",
          "format": "uri",
          "description": "URI reference to the Signature Profile used for this signing act.",
          "examples": [
            "urn:agency.gov:wos:signature-profile:benefits:v1"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          },
          "minLength": 1
        },
        "profileKey": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
          "description": "Package-local Signature Profile key used for this signing act.",
          "examples": [
            "benefitsSignature"
          ]
        },
        "sourceResponseRef": {
          "type": "string",
          "format": "uri",
          "description": "URI reference to the canonical source response or evidence artifact that supplied signature evidence.",
          "examples": [
            "urn:agency.gov:formspec:responses:benefits:case-2026-0001"
          ],
          "x-wos": {
            "openStringKind": "identifier"
          },
          "minLength": 1
        },
        "signerAuthority": {
          "$ref": "#/$defs/SignatureSignerAuthority"
        },
        "custodyHookEligible": {
          "type": "boolean",
          "const": true,
          "description": "SignatureAffirmation records are eligible for WOS custodyHook admission.",
          "examples": [
            true
          ]
        }
      }
    },
    "SignatureSignerAuthority": {
      "type": "object",
      "description": "WOS signer-authority claim required for signing intents whose authority floor is not self.",
      "required": [
        "class"
      ],
      "additionalProperties": false,
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "self",
            "witness",
            "notary-commissioned",
            "as-attorney-in-fact",
            "as-officer-of"
          ],
          "description": "Signer-authority class accepted by the WOS Signature Profile.",
          "examples": [
            "witness"
          ]
        },
        "principal": {
          "type": "string",
