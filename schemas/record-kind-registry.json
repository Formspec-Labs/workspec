{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wos.standard/schemas/record-kind-registry.json",
  "title": "WOS Record Kind Registry",
  "description": "Canonical registry of all ProvenanceKind variants. 132 total — 22 carry schema-validated payload shapes (if/then guards or prov-log $def overlays), 110 are flat Facts-tier records. Every literal maps 1:1 to a ProvenanceKind Rust enum variant (crate::provenance::kind) under serde(rename_all=\"camelCase\"). Both the kernel FactsTierRecord.recordKind enum and the API FactsRecordKind taxonomy derive from this registry. See specs/provenance-registry.md for governance policy on adding/removing record kinds.",
  "type": "object",
  "properties": {
    "registryVersion": {
      "type": "string",
      "description": "Semantic version. Minor bump when record kinds are added. Major bump when a kind is removed (breaking API change)."
    },
    "lastAudited": {
      "type": "string",
      "format": "date"
    },
    "totalCount": {
      "type": "integer",
      "description": "Total ProvenanceKind variants in the Rust enum at last audit."
    },
    "schemaValidatedCount": {
      "type": "integer",
      "description": "Variants carrying schema-validated payload shapes (if/then or $def overlay)."
    },
    "sources": {
      "type": "object",
      "properties": {
        "rustEnum": { "type": "string" },
        "kernelSchema": { "type": "string" },
        "apiProvenanceSchema": { "type": "string" },
        "parityScript": { "type": "string" },
        "adrs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "recordKinds": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "literal": { "type": "string" },
          "rustVariant": { "type": "string" },
          "category": { "type": "string" },
          "schemaValidated": { "type": "boolean" },
          "eventLiteral": {
            "type": "string",
            "description": "Optional F-13 custody/export event literal when this record kind has a ratified WOS-owned event type. The event literal is the authoritative dispatch key for migrated overlays; `literal` remains the inner ProvenanceKind wire name until D26 removes recordKind dispatch globally."
          },
          "specReference": { "type": "string" }
        },
        "required": ["literal", "rustVariant", "category"]
      }
    }
  },
  "registryVersion": "1.0.0",
  "lastAudited": "2026-05-07",
  "totalCount": 132,
