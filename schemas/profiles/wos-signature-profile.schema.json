{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wos-spec.org/schemas/signature-profile/1.0",
  "title": "WOS Signature Profile Document",
  "description": "A WOS Signature Profile Document per the WOS Signature Profile specification v1.0. Declares signer roles, signing flow, document binding, consent evidence, identity-binding requirements, and policy hooks for signature workflows. WOS governs the workflow semantics and emits SignatureAffirmation provenance; Trellis owns anchoring and certificate/export composition.",
  "type": "object",
  "required": [
    "$wosSignatureProfile",
    "targetWorkflow",
    "roles",
    "documents",
    "signingFlow",
    "evidence"
  ],
  "patternProperties": {
    "^x-": {
      "$comment": "Vendor extensions per Kernel spec §10.6"
    }
  },
  "additionalProperties": false,
  "properties": {
    "$wosSignatureProfile": {
      "type": "string",
      "const": "1.0",
      "description": "WOS Signature Profile document marker and version pin. Processors use this field to identify the document as a Signature Profile and to reject incompatible signature workflow semantics before runtime execution begins.",
      "examples": [
        "1.0",
        "1.0"
      ],
      "x-lm": {
        "critical": true,
        "intent": "Document type marker and version pin for WOS Signature Profile documents"
      }
    },
    "$schema": {
      "$ref": "#/$defs/JsonSchemaUri"
    },
    "targetWorkflow": {
      "$ref": "#/$defs/TargetWorkflow",
      "description": "The WOS Kernel Document this signature profile targets."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Version of this Signature Profile Document. SemVer is RECOMMENDED.",
      "examples": [
        "1.0.0"
      ]
    },
    "title": {
      "type": "string",
      "description": "Human-readable title for this signature profile, suitable for authoring tools and validation reports.",
      "examples": [
        "Benefits Attestation Signature Profile"
      ]
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the signature workflow and the signing ceremony it governs.",
      "examples": [
        "Single-signer attestation for benefits application certification."
      ]
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/SignatureRole"
      },
      "description": "Signature roles bound to kernel human actors."
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/SignatureDocument"
      },
      "description": "Documents that can be signed under this profile."
    },
    "signingFlow": {
      "$ref": "#/$defs/SigningFlow",
      "description": "Signing flow declaration."
    },
    "evidence": {
      "$ref": "#/$defs/SignatureEvidence",
      "description": "Evidence inputs required before WOS emits SignatureAffirmation."
    },
    "authenticationPolicies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AuthenticationPolicy"
      },
      "description": "Named authentication policies referenced by signature roles."
    },
    "reminders": {
      "$ref": "#/$defs/ReminderPolicy"
    },
    "expiryPolicy": {
      "$ref": "#/$defs/ExpiryPolicy"
    },
    "declinePolicy": {
      "$ref": "#/$defs/DeclinePolicy"
    },
    "voidPolicy": {
      "$ref": "#/$defs/VoidPolicy"
    },
    "reassignmentPolicy": {
      "$ref": "#/$defs/ReassignmentPolicy"
    },
    "extensions": {
      "$ref": "#/$defs/ExtensionsMap"
    }
  },
  "$defs": {
    "TargetWorkflow": {
      "type": "object",
      "required": [
        "url"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Canonical URI of the target WOS Kernel Document that this Signature Profile augments.",
          "examples": [
            "https://agency.gov/workflows/benefits-adjudication"
          ]
        },
        "compatibleVersions": {
          "type": "string",
          "description": "SemVer range expression for compatible kernel document versions.",
          "examples": [
            ">=1.0.0 <2.0.0"
          ]
        }
      }
    },
    "SignatureRole": {
      "type": "object",
      "required": [
        "id",
        "role",
        "actorId"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/Identifier"
        },
        "role": {
          "$ref": "#/$defs/SignerRole"
        },
        "actorId": {
          "$ref": "#/$defs/Identifier",
          "description": "Kernel actor id. Lint verifies the actor exists and is human."
        },
        "required": {
          "type": "boolean",
          "default": true,
          "description": "Whether this role must affirm for the configured signing-flow completion requirement to be satisfied.",
          "examples": [
            true
          ]
        },
        "authenticationPolicyKey": {
          "$ref": "#/$defs/Key",
          "description": "Key of a policy in authenticationPolicies."
        },
        "description": {
          "type": "string",
          "description": "Human-readable explanation of the signer role and why it participates in this profile.",
          "examples": [
            "Applicant signs the benefits application attestation."
          ]
        }
      }
    },
    "SignatureDocument": {
      "type": "object",
      "required": [
        "id",
        "documentRef",
        "documentHash",
        "documentHashAlgorithm"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/Identifier"
        },
        "documentRef": {
          "type": "string",
          "format": "uri",
          "description": "URI reference to the signable document artifact whose digest is bound to the signing evidence.",
          "examples": [
            "urn:agency.gov:documents:benefits-application:v1"
          ]
        },
        "documentHash": {
          "$ref": "#/$defs/HashValue",
          "description": "Digest of the signable document bytes."
        },
        "documentHashAlgorithm": {
          "$ref": "#/$defs/HashAlgorithm"
        },
        "renderingRef": {
          "type": "string",
          "format": "uri",
          "description": "Optional URI reference to rendered-document metadata or to the rendered artifact shown to signers.",
          "examples": [
            "urn:agency.gov:renderings:benefits-application:v1"
          ]
        },
        "formspecResponseRef": {
          "type": "string",
          "format": "uri",
          "description": "Optional URI reference to the canonical Formspec response that supplied signature evidence.",
          "examples": [
            "urn:agency.gov:formspec:responses:benefits:case-2026-0001"
          ]
        }
      }
    },
    "SigningFlow": {
      "type": "object",
      "required": [
        "type",
        "steps"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "sequential",
            "parallel",
            "routed",
            "free-for-all"
          ],
          "description": "Signing flow pattern used by the runtime to decide ordering, guard selection, and completion semantics.",
          "examples": [
            "sequential"
          ]
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/SigningStep"
          }
        },
        "completion": {
          "$ref": "#/$defs/CompletionRequirement"
        }
      }
    },
    "SigningStep": {
      "type": "object",
      "required": [
        "id",
        "roleId",
        "documentId"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/Identifier"
        },
        "roleId": {
          "$ref": "#/$defs/Identifier"
        },
        "documentId": {
          "$ref": "#/$defs/Identifier"
        },
        "guard": {
          "type": "string",
          "minLength": 1,
          "description": "FEL expression evaluated against case state to decide whether this routed signing step is selected.",
          "examples": [
            "caseFile.requiresNotary == true"
          ]
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Identifier"
          },
          "uniqueItems": true,
          "description": "Sibling signing-step ids that must complete before this step."
        },
        "required": {
          "type": "boolean",
          "default": true,
          "description": "Whether this signing step must affirm before the configured flow completion requirement can pass.",
          "examples": [
            true
          ]
        }
      }
    },
    "CompletionRequirement": {
      "type": "object",
      "required": [
        "type"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "all-required",
            "any-required",
            "count",
            "role-set"
          ],
          "description": "Completion rule used to decide when selected signing steps satisfy the overall signature flow.",
          "examples": [
            "all-required"
          ]
        },
        "count": {
          "type": "integer",
          "minimum": 1,
          "description": "Minimum number of selected signing steps that must affirm when the completion type is count.",
          "examples": [
            2
          ]
        },
        "roleIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Identifier"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "count"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "count"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "role-set"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "roleIds"
            ]
          }
        }
      ]
    },
    "AuthenticationPolicy": {
      "type": "object",
      "required": [
        "key",
        "method",
        "assuranceLevel"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "key": {
          "$ref": "#/$defs/Key"
        },
        "method": {
          "$ref": "#/$defs/AuthenticationMethod"
        },
        "assuranceLevel": {
          "$ref": "#/$defs/AssuranceLevel"
        },
        "providerRef": {
          "type": "string",
          "format": "uri",
          "description": "URI reference to the identity provider or signature ceremony provider used by this policy.",
          "examples": [
            "urn:agency.gov:identity:providers:email-otp"
          ]
        },
        "requiresInPerson": {
          "type": "boolean",
          "default": false,
          "description": "Whether this authentication policy requires evidence from an in-person or notary ceremony.",
          "examples": [
            false
          ]
        },
        "requiresCredentialEvidence": {
          "type": "boolean",
          "default": false,
          "description": "Whether this authentication policy requires credential evidence from the ceremony provider.",
          "examples": [
            true
          ]
        }
      }
    },
    "ConsentReference": {
      "type": "object",
      "required": [
        "consentTextRef",
        "consentVersion",
        "acceptedAtPath",
        "affirmationPath"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "consentTextRef": {
          "type": "string",
          "format": "uri",
          "description": "URI reference to the consent text that the signer accepted as part of the signing ceremony.",
          "examples": [
            "urn:agency.gov:consent:esign-benefits:v1"
          ]
        },
        "consentVersion": {
          "type": "string",
          "minLength": 1,
          "description": "Version of the consent text accepted by the signer and recorded in signature evidence.",
          "examples": [
            "1.0.0"
          ]
        },
        "acceptedAtPath": {
          "$ref": "#/$defs/CasePath",
          "description": "Path to timestamp evidence in the Formspec response or case file."
        },
        "affirmationPath": {
          "$ref": "#/$defs/CasePath",
          "description": "Path to explicit affirmation evidence."
        }
      }
    },
    "IdentityBindingRequirement": {
      "type": "object",
      "required": [
        "method",
        "assuranceLevel"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "method": {
          "$ref": "#/$defs/AuthenticationMethod"
        },
        "assuranceLevel": {
          "$ref": "#/$defs/AssuranceLevel"
        },
        "providerRef": {
          "type": "string",
          "format": "uri",
          "description": "URI reference to the identity or signature provider required for this identity binding.",
          "examples": [
            "urn:agency.gov:identity:providers:email-otp"
          ]
        },
        "externalAttestationRef": {
          "type": "string",
          "format": "uri",
          "description": "URI reference to an external identity attestation that supports this signature evidence.",
          "examples": [
            "urn:agency.gov:identity:attestations:notary:case-2026-0042"
          ]
        }
      }
    },
    "SignatureEvidence": {
      "type": "object",
      "required": [
        "recordKind",
        "requiredFields",
        "consentReference",
        "identityBinding",
        "custodyHookEligible"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "recordKind": {
          "type": "string",
          "const": "signatureAffirmation",
          "description": "Required provenance record kind emitted by WOS when all signature evidence requirements pass.",
          "examples": [
            "signatureAffirmation"
          ]
        },
        "requiredFields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/CasePath"
          }
        },
        "consentReference": {
          "$ref": "#/$defs/ConsentReference"
        },
        "identityBinding": {
          "$ref": "#/$defs/IdentityBindingRequirement"
        },
        "custodyHookEligible": {
          "type": "boolean",
          "const": true,
          "description": "Whether resulting SignatureAffirmation records are eligible for WOS custodyHook admission.",
          "examples": [
            true
          ]
        }
      }
    },
    "ReminderPolicy": {
      "type": "object",
      "required": [
        "eventName",
        "schedule"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "eventName": {
          "$ref": "#/$defs/EventName"
        },
        "schedule": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Duration"
          }
        },
        "templateKey": {
          "$ref": "#/$defs/Key"
        }
      }
    },
    "ExpiryPolicy": {
      "type": "object",
      "required": [
        "eventName",
        "after"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "eventName": {
          "$ref": "#/$defs/EventName"
        },
        "after": {
          "$ref": "#/$defs/Duration"
        },
        "transitionId": {
          "$ref": "#/$defs/Identifier"
        }
      }
    },
    "DeclinePolicy": {
      "type": "object",
      "required": [
        "transitionId"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "transitionId": {
          "$ref": "#/$defs/EventName",
          "description": "Lifecycle event name emitted when a signer declines the signature ceremony."
        },
        "reasonRequired": {
          "type": "boolean",
          "default": true,
          "description": "Whether a signer decline must include a non-empty reason before the runtime accepts it.",
          "examples": [
            true
          ]
        }
      }
    },
    "VoidPolicy": {
      "type": "object",
      "required": [
        "authorizedActorIds"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "authorizedActorIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Identifier"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "reasonRequired": {
          "type": "boolean",
          "default": true,
          "description": "Whether an authorized void operation must include a non-empty reason before it is accepted.",
          "examples": [
            true
          ]
        }
      }
    },
    "ReassignmentPolicy": {
      "type": "object",
      "required": [
        "authorizedActorIds",
        "accountability"
      ],
      "patternProperties": {
        "^x-": {
          "$comment": "Vendor extensions per Kernel spec §10.6"
        }
      },
      "additionalProperties": false,
      "properties": {
        "authorizedActorIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Identifier"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "accountability": {
          "type": "string",
          "const": "preserve-original-assignment",
          "description": "Accountability mode for reassignment; WOS preserves original and new signer evidence.",
          "examples": [
            "preserve-original-assignment"
          ]
        },
        "reasonRequired": {
          "type": "boolean",
          "default": true,
          "description": "Whether reassignment must include a non-empty reason before the runtime accepts it.",
          "examples": [
            true
          ]
        }
      }
    },
    "SignerRole": {
      "type": "string",
      "enum": [
        "signer",
        "in-person-signer",
        "certified-recipient",
        "witness",
        "notary",
        "approver",
        "form-filler",
        "viewer"
      ],
      "description": "Closed set of signer roles understood by WOS Signature Profile runtime semantics.",
      "examples": [
        "signer"
      ]
    },
    "AuthenticationMethod": {
      "type": "string",
      "pattern": "^(none|email-otp|sms-otp|knowledge-based|oidc|webauthn|credential|in-person|notary|x-[a-z0-9][a-z0-9-]*)$",
      "description": "Closed WOS authentication methods plus vendor x-* methods for identity binding evidence.",
      "examples": [
        "email-otp"
      ]
    },
    "AssuranceLevel": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "standard",
        "high",
        "very-high"
      ],
      "description": "Ordered assurance strength reached by the identity-binding evidence for a signing act.",
      "examples": [
        "standard"
      ]
    },
    "HashAlgorithm": {
      "type": "string",
      "pattern": "^(sha-256|sha-384|sha-512|x-[a-z0-9][a-z0-9-]*)$",
      "description": "Digest algorithm used to bind a signable document to its signature evidence record.",
      "examples": [
        "sha-256"
      ]
    },
    "HashValue": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64,128}$",
      "description": "Hex-encoded digest value for the signable document bytes shown or represented to the signer.",
      "examples": [
        "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
      ]
    },
    "Identifier": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
      "description": "Local id for a sibling object within the Signature Profile document.",
      "examples": [
        "applicantSigner"
      ]
    },
    "Key": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
      "description": "Package-local key for maps and catalogs; keys are not URI cross-artifact references.",
      "examples": [
        "emailOtp"
      ]
    },
    "EventName": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_.:-]*$",
      "description": "Lifecycle or timer event name emitted by WOS runtime for signature policy actions.",
      "examples": [
        "signature.expired"
      ]
    },
    "CasePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z_$][A-Za-z0-9_$.\\[\\]-]*$",
      "description": "Path to evidence in a Formspec response, case file, or profile-supported evidence source.",
      "examples": [
        "response.signature.acceptedAt"
      ]
    },
    "Duration": {
      "type": "string",
      "pattern": "^P(?!$)(?:\\d+D|T(?:\\d+H)?(?:\\d+M)?(?:\\d+S)?|\\d+DT(?:\\d+H)?(?:\\d+M)?(?:\\d+S)?)$",
      "description": "ISO 8601 duration used for reminder schedules and signature expiry policy timing.",
      "examples": [
        "P7D"
      ]
    },
    "ExtensionsMap": {
      "type": "object",
      "description": "Vendor extension data attached to this node. All keys MUST start with x-.",
      "propertyNames": {
        "pattern": "^x-"
      },
      "additionalProperties": {},
      "examples": [
        {
          "x-vendor-ceremony": {
            "mode": "embedded"
          }
        }
      ]
    },
    "JsonSchemaUri": {
      "type": "string",
      "format": "uri",
      "description": "Optional JSON Schema URI enabling editor validation, type generation, and autocompletion.",
      "examples": [
        "https://wos-spec.org/schemas/signature-profile/1.0"
      ]
    }
  }
}
