{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wos-spec.org/schemas/studio-readiness/1.0",
  "title": "WOS Studio (Authoring) \u2014 Readiness (ValidationFinding + Rule Registry)",
  "description": "Studio readiness shapes per studio-authoring/specs/readiness-validation.md. Top-level kind discriminator selects ValidationFinding (single finding) or RuleRegistry (catalog of rules) or ValidationReport (collection of findings for a workspace/workflow). ValidationFinding carries tier (S1-S6), ruleId, severity \u2208 {info|warn|error|block}, subjectRef, message, suggestedFix, lifecycleState (open|acknowledged|waived|resolved), waivedBy, waivedRationale.",
  "$comment": "Promotion status (Stage-3, 2026-05-01): MVP shape; rule registry is Stage-4 territory but schema accepts the shape so the registry can be authored as data.",
  "type": "object",
  "required": [
    "$wosStudioReadiness",
    "kind"
  ],
  "additionalProperties": false,
  "patternProperties": {
    "^(\\$|x-)": {}
  },
  "properties": {
    "$wosStudioReadiness": {
      "type": "string",
      "const": "1.0",
      "examples": [
        "1.0"
      ],
      "x-lm": {
        "critical": true,
        "intent": "Document type marker for Studio readiness artifacts"
      },
      "description": "Document marker pinning this artifact to the Studio Readiness 1.0 schema family."
    },
    "kind": {
      "type": "string",
      "enum": [
        "ValidationFinding",
        "ValidationReport",
        "RuleRegistry"
      ],
      "description": "Readiness artifact discriminator.",
      "examples": [
        "ValidationReport",
        "RuleRegistry"
      ]
    },
    "id": {
      "type": "string"
    },
    "workspaceId": {
      "type": "string"
    },
    "workflowIntentRef": {
      "type": "string"
    },
    "finding": {
      "$ref": "#/$defs/ValidationFinding"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ValidationFinding"
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/RuleRegistryEntry"
      }
    },
    "tierSummary": {
      "type": "object",
      "description": "Per-tier roll-up (S1-S6) for ValidationReport.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "open": {
            "type": "integer"
          },
          "acknowledged": {
            "type": "integer"
          },
          "waived": {
            "type": "integer"
          },
          "blocking": {
            "type": "integer"
          }
        }
      }
    }
  },
  "$defs": {
    "ValidationFinding": {
      "type": "object",
      "required": [
        "id",
        "ruleId",
        "severity",
        "subjectRef"
      ],
      "additionalProperties": true,
      "patternProperties": {
        "^(\\$|x-)": {}
      },
      "properties": {
        "id": {
          "type": "string"
        },
        "ruleId": {
          "type": "string",
          "description": "Rule identifier from the readiness rule registry. Studio rules use SA-MUST/SA-SHOULD prefixes; cross-cutting rules use family prefixes (EFF/AI/CMP/EQ/ACC/JUR/ID/COMP/CHAIN/TERM); WOS-side rules use their parent ids (K-/G-/AI-/SIG-).",
          "examples": [
            "WF-LINT-001",
            "EQ-LINT-003",
            "K-051"
          ]
        },
        "tier": {
          "type": "string",
          "enum": [
            "S1",
            "S2",
            "S3",
            "S4",
            "S5",
            "S6"
          ],
          "description": "Readiness tier this finding belongs to (per readiness-validation.md)."
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warn",
            "error",
            "block"
          ],
          "description": "Severity. `block` cannot be advanced past without explicit waiver.",
          "examples": [
            "warn",
            "block"
          ],
          "x-lm": {
            "critical": true,
            "intent": "Severity drives whether the finding blocks advancement \u2014 load-bearing for tier gates"
          }
        },
        "subjectRef": {
          "type": "string"
        },
        "subjectKind": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "suggestedFix": {
          "type": "string"
        },
        "lifecycleState": {
          "type": "string",
          "enum": [
            "open",
            "acknowledged",
            "waived",
            "resolved"
          ]
        },
        "waivedBy": {
          "type": "string"
        },
        "waivedRationale": {
          "type": "string"
        },
        "waivedAt": {
          "type": "string",
          "format": "date-time"
        },
        "openedAt": {
          "type": "string",
          "format": "date-time"
        },
        "resolvedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "RuleRegistryEntry": {
      "type": "object",
      "required": [
        "id",
        "summary"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "tier": {
          "type": "string",
          "enum": [
            "S1",
            "S2",
            "S3",
            "S4",
            "S5",
            "S6"
          ]
        },
        "category": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "graduation": {
          "type": "string",
          "enum": [
            "draft",
            "tested",
            "stable",
            "load_bearing"
          ]
        },
        "specRef": {
          "type": "string"
        },
        "suggestedFix": {
          "type": "string"
        },
        "fixtures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "patternProperties": {
        "^(\\$|x-)": {}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "ValidationFinding"
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "required": [
          "finding"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "ValidationReport"
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "properties": {
          "findings": {
            "type": "array",
            "description": "ValidationReport MUST carry a findings collection (may be empty if no issues)."
          }
        },
        "required": [
          "findings"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "RuleRegistry"
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "properties": {
          "rules": {
            "type": "array",
            "minItems": 1,
            "description": "RuleRegistry MUST list at least one rule."
          }
        },
        "required": [
          "rules"
        ]
      }
    }
  ]
}
