{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wos-spec.org/schemas/studio-workflow-intent/1.0",
  "title": "WOS Studio (Authoring) \u2014 Workflow Intent",
  "description": "Studio WorkflowIntent per studio-authoring/specs/workflow-intent.md. The user-facing draft that compiles to a `$wosWorkflow` artifact (per compiler-contract.md). Carries 16 user-facing element kinds (phase / step / decision / review / notice / deadline / appeal / exception / hold / data-collection / evidence-request / system-check / AI-assistance / manual-override / completion-outcome / phase-end), each with a bridge field that names the kernel construct produced. Bridge.kernelKind is INFERRED for 14 unambiguous kinds (per workflow-intent.md 'Bridge inference rules', SA-MUST-wfi-005); REQUIRED only on the 2 ambiguous kinds (`step`, `system-check`). The 6 bridge construct kinds (WorkflowStepMapping, LifecycleTagMapping, TransitionMapping, TimerMapping, TaskMapping, CaseFileMapping) are co-located here per CM \u00a76.1 corrected pattern (2026-05-01) \u2014 they're products of bridge-inference compilation, not author-written PolicyObjects.",
  "$comment": "Promotion status (Stage-3, 2026-05-01): MVP shape; element body shapes are illustrative-and-flexible. Per-kind body validation lives in Stage-4 lint rules.",
  "type": "object",
  "required": [
    "$wosStudioWorkflowIntent",
    "id",
    "workspaceId",
    "title",
    "impactLevel",
    "lifecycleState",
    "elements"
  ],
  "additionalProperties": false,
  "patternProperties": {
    "^(\\$|x-)": {}
  },
  "properties": {
    "$wosStudioWorkflowIntent": {
      "type": "string",
      "const": "1.0",
      "examples": [
        "1.0"
      ],
      "x-lm": {
        "critical": true,
        "intent": "Document type marker for the Studio WorkflowIntent"
      },
      "description": "Document marker pinning this artifact to the Studio WorkflowIntent 1.0 schema."
    },
    "id": {
      "type": "string",
      "examples": [
        "wfi-snap-redetermination-tx"
      ]
    },
    "workspaceId": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "impactLevel": {
      "type": "string",
      "enum": [
        "rights-impacting",
        "safety-impacting",
        "informational",
        "operational",
        "other"
      ],
      "description": "Impact classification per parent kernel/spec.md \u00a76. Drives WOS embedded-block conditionality at compile time per substrate-choice (CM \u00a75).",
      "examples": [
        "rights-impacting",
        "operational"
      ],
      "x-lm": {
        "critical": true,
        "intent": "Risk-profile classifier \u2014 drives substrate-side embedded-block conditional emission per CM \u00a75"
      }
    },
    "lifecycleState": {
      "type": "string",
      "enum": [
        "draft",
        "mapped",
        "validationReady",
        "scenarioTested",
        "approved",
        "published",
        "deprecated"
      ]
    },
    "wosVersionPin": {
      "type": "string",
      "description": "WOS version claim string per parent RELEASE-STREAMS.md. Required at lifecycle 'mapped' or later.",
      "examples": [
        "kernel@1.0, governance@1.0, ai@0.5, signature@1.0, custody@1.0, advanced@0.3, assurance@1.0"
      ]
    },
    "effectivenessRef": {
      "type": "string",
      "description": "Workflow-level Effectiveness ref (jurisdictional + temporal scope). Element-level effectivenessRef on individual WorkflowElements narrows further."
    },
    "version": {
      "type": [
        "string",
        "integer"
      ]
    },
    "parentVersion": {
      "type": [
        "string",
        "integer",
        "null"
      ]
    },
    "policyObjectRefs": {
      "type": "array",
      "description": "PolicyObjects this intent is derived from.",
      "items": {
        "type": "string"
      }
    },
    "mappingRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bindingRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "elements": {
      "type": "array",
      "description": "WorkflowElements (16 user-facing kinds). Each carries `kind` + body + bridge.",
      "items": {
        "$ref": "#/$defs/WorkflowElement"
      }
    },
    "compiledArtifactRef": {
      "type": "string"
    },
    "expertModeView": {
      "type": "object",
      "description": "Mapping from intent elements to compiled $wosWorkflow JSON paths.",
      "additionalProperties": true
    },
    "provenance": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "$comment_bridge_inference": {
      "type": "string"
    }
  },
  "$defs": {
    "WorkflowElement": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "name",
        "bridge"
      ],
      "additionalProperties": true,
      "patternProperties": {
        "^(\\$|x-)": {}
      },
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "phase",
            "step",
            "decision",
            "review",
            "notice",
            "deadline",
            "appeal",
            "exception",
            "hold",
            "data-collection",
            "evidence-request",
            "system-check",
            "AI-assistance",
            "manual-override",
            "completion-outcome",
            "phase-end"
          ],
          "description": "User-facing element kind. The bridge.kernelKind is INFERRED from this for 14 of 16 kinds; REQUIRED on `step` + `system-check` (per workflow-intent.md 'Bridge inference rules').",
          "examples": [
            "phase",
            "decision",
            "notice",
            "appeal"
          ],
          "x-lm": {
            "critical": true,
            "intent": "Element kind drives bridge inference (kernelKind) and body shape \u2014 load-bearing for compilation routing"
          }
        },
        "name": {
          "type": "string"
        },
        "body": {
          "type": "object",
          "description": "Kind-specific body. The `allOf` clauses below enforce required fields per element `kind`. Body remains `additionalProperties: true` so authors may extend per-kind shapes; Stage-4 lint rules layer deeper validation (cross-document refs to PolicyObjects, FEL syntax, etc.).",
          "additionalProperties": true
        },
        "position": {
          "type": [
            "string",
            "object",
            "null"
          ],
          "description": "Structural placement (phase id, sequence index, parent step ref)."
        },
        "policyObjectRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "citations": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "object"
            ]
          }
        },
        "bridge": {
          "$ref": "#/$defs/BridgeAssertion"
        },
        "effectivenessRef": {
          "type": "string"
        },
        "reviewState": {
          "type": "string",
          "enum": [
            "draft",
            "reviewed",
            "approved"
          ]
        },
        "workspaceId": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "phase"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Phase body. Required: contains[] (refs to inner element ids). Recommended: description.",
                "required": [
                  "contains"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "step"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Step body. Recommended: description, performedBy (ActorMapping ref), expectedDurationHint, blockingOrInformational."
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "decision"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Decision body. Recommended: question, decisionRuleRef (DecisionRule|DecisionTable PolicyObject ref), possibleOutcomes[]."
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "review"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Review body. Required: reviewer (ActorMapping ref). Recommended: scope[] (caseFile paths or decision refs), outcomeWhen (e.g., 'adverse').",
                "required": [
                  "reviewer"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "notice"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Notice body. Required: noticeRequirementRef (NoticeRequirement PolicyObject ref). Recommended: deliveryBindingRef.",
                "required": [
                  "noticeRequirementRef"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "deadline"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Deadline body. Required: deadlinePolicyObjectRef, attachedTo (the WorkflowElement id this deadline is anchored to). Recommended: expiryAction.",
                "required": [
                  "deadlinePolicyObjectRef",
                  "attachedTo"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "appeal"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Appeal body. Required: appealRightRef (AppealRight PolicyObject ref), branchEntryPoint (WorkflowElement id where the appeal branch enters). Recommended: deadlineRef.",
                "required": [
                  "appealRightRef",
                  "branchEntryPoint"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "exception"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Exception body. Required: exceptionRuleRef, divertsFrom (default WorkflowElement id), divertsTo (alternate WorkflowElement id). Recommended: conditionRef.",
                "required": [
                  "exceptionRuleRef",
                  "divertsFrom",
                  "divertsTo"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "hold"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Hold body. Required: holdReason, releaseCondition (Condition ref or event ref). Recommended: maxDuration, escalation.",
                "required": [
                  "holdReason",
                  "releaseCondition"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "data-collection"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Data-collection body. Required: collected[] (DataElement refs). Recommended: formRef (Formspec form id), requiredFields, optionalFields.",
                "required": [
                  "collected"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "evidence-request"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Evidence-request body. Required: evidenceRequirementRef. Recommended: deadlineRef.",
                "required": [
                  "evidenceRequirementRef"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "system-check"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "System-check body. Required: checkPurpose (free-text description of what's being verified). Recommended: serviceBindingRef (when delivered via API).",
                "required": [
                  "checkPurpose"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "AI-assistance"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "AI-assistance body. Required: aiUsePolicyObjectRef (AI Use PolicyObject ref), fallbackRef (the WorkflowElement id this falls back to when confidence is low or escalation triggers). Per parent CLAUDE.md fallback chain MUST terminate in human review. Recommended: actorMappingRef, confidenceFloor.",
                "required": [
                  "aiUsePolicyObjectRef",
                  "fallbackRef"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "manual-override"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Manual-override body. Required: overridingActor (ActorMapping ref with override authority), defaultPath (default WorkflowElement id), overridePath (alternate WorkflowElement id). Recommended: justificationRequired, recordRationale, scopeLimit.",
                "required": [
                  "overridingActor",
                  "defaultPath",
                  "overridePath"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "completion-outcome"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Completion-outcome body. Required: outcomeRef (Outcome PolicyObject ref). Recommended: polarity (favorable | adverse | neutral), postClosureActions[], triggersDueProcess.",
                "required": [
                  "outcomeRef"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "phase-end"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Phase-end body. Recommended: phaseRef, nextPhaseRef OR terminalRef (one of)."
              }
            }
          }
        }
      ]
    },
    "BridgeAssertion": {
      "type": "object",
      "description": "Bridge from element to kernel construct. `kernelKind` is OPTIONAL \u2014 inferred from element.kind for unambiguous cases per workflow-intent.md 'Bridge inference rules' (SA-MUST-wfi-005). REQUIRED on ambiguous kinds (`step`, `system-check`). Body fields name the specific kernel construct: `stateName` (compound/atomic/terminal state), `taskRef`, `transitionId`, `timerRef`, `noticeId`, `subFlowEntry`, `agentRef`, `guardRef`. The 6 bridge construct kinds (WorkflowStepMapping, LifecycleTagMapping, TransitionMapping, TimerMapping, TaskMapping, CaseFileMapping) are products of bridge-inference and live as projection records, not as separate authoring objects.",
      "additionalProperties": true,
      "patternProperties": {
        "^(\\$|x-)": {}
      },
      "properties": {
        "kernelKind": {
          "type": "string",
          "enum": [
            "compound-state",
            "atomic-state",
            "terminal-state",
            "transition",
            "transition-guard",
            "alternate-transition",
            "task",
            "timer",
            "sub-flow",
            "governance-notice",
            "agent"
          ],
          "description": "Kernel construct discriminant. OPTIONAL when element.kind is unambiguous (inferred per workflow-intent.md 'Bridge inference rules'); REQUIRED on `step` (atomic-state | task) and `system-check` (task | transition-guard).",
          "examples": [
            "task",
            "transition-guard"
          ]
        },
        "stateName": {
          "type": "string"
        },
        "taskRef": {
          "type": "string"
        },
        "transitionId": {
          "type": "string"
        },
        "timerRef": {
          "type": "string"
        },
        "noticeId": {
          "type": "string"
        },
        "subFlowEntry": {
          "type": "string"
        },
        "agentRef": {
          "type": "string"
        },
        "guardRef": {
          "type": "string"
        },
        "guardKind": {
          "type": "string",
          "description": "Guard form (FEL string vs decisionTable per parent Kernel \u00a74.5.1).",
          "examples": [
            "fel",
            "decisionTable",
            "actor-authority + documented-disruption"
          ]
        },
        "signatureGated": {
          "type": "boolean"
        },
        "signatureRequirement": {
          "type": "string"
        },
        "linkedNoticeRef": {
          "type": "string"
        },
        "linkedAppealRef": {
          "type": "string"
        }
      }
    }
  }
}
