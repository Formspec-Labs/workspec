        },
        "required": [
          "body"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "Permission"
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "properties": {
          "body": {
            "type": "object",
            "additionalProperties": true,
            "patternProperties": {
              "^(\\$|x-)": {}
            },
            "description": "Deontic Permission body (lrml:Permission). Same shape as Obligation.",
            "required": [
              "description"
            ]
          }
        },
        "required": [
          "body"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "Prohibition"
          }
        },
