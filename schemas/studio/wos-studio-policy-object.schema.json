            "type": "object",
            "additionalProperties": true,
            "patternProperties": {
              "^(\\$|x-)": {}
            },
            "description": "Assumption body. Required: narrative (what is assumed). Recommended: rationale, scope, severity, alternativesConsidered, policyPermissibilityAttestation.",
            "required": [
              "narrative"
            ]
          }
        },
        "required": [
          "body"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "OpenQuestion"
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "properties": {
          "body": {
            "type": "object",
            "additionalProperties": true,
            "patternProperties": {
              "^(\\$|x-)": {}
            },
            "description": "Open-question body. Required: question. Recommended: possibleAnswers[], suggestedReviewer.",
            "required": [
              "question"
            ]
          }
        },
        "required": [
          "body"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "Requirement"
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "properties": {
          "body": {
            "type": "object",
            "additionalProperties": true,
            "patternProperties": {
              "^(\\$|x-)": {}
            },
            "description": "Generic-requirement body. Required: description (what must be satisfied). Recommended: conditions[], applicability.",
            "required": [
              "description"
            ]
          }
        },
        "required": [
          "body"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "Obligation"
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "properties": {
          "body": {
            "type": "object",
            "additionalProperties": true,
            "patternProperties": {
              "^(\\$|x-)": {}
            },
            "description": "Deontic Obligation body (OASIS LegalRuleML lrml:Obligation). Required: description. Recommended: defeasible (boolean), holder, action, conditions, legalRuleML (lrml:* JSON-LD terms).",
            "required": [
              "description"
            ]
