    "RetentionPolicy": {
      "description": "Typed retention policy per ADR-0083 r2. Closed shape; vendor extensions go under ^(\\$|x-) patternProperties. Either declared inline at EvidenceRequirement.body.retentionPolicy OR inherited from Workspace.policy.retentionPolicies[<DPV-IRI>] with field-by-field override (scalars replace; regulatoryBasis[] merges).",
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^(\\$|x-)": {}
      },
      "required": [
        "disposalAction"
      ],
      "properties": {
        "duration": {
          "type": "string",
          "description": "ISO-8601 duration (e.g., P7Y, P30D). REQUIRED unless mode = indefinite. Forbidden when mode = indefinite (enforced by the if/then below).",
          "examples": [
            "P7Y",
            "P30D",
            "P5Y6M"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "bounded",
            "indefinite"
          ],
          "description": "Default 'bounded'. When 'indefinite', duration MUST be absent."
        },
        "disposalAction": {
          "type": "string",
          "enum": [
            "archive",
            "cryptoErase",
            "redact",
            "purge"
          ],
          "description": "Terminal disposition action when retention expires. No default — every contract names its disposition. 'transfer' is reserved (out-of-scope for v1).",
          "x-lm": {
            "critical": true,
            "intent": "Disposal action — load-bearing for retention contract semantics"
          }
        },
        "triggerEvent": {
          "type": "string",
          "enum": [
            "caseClosure",
            "lastInteraction",
            "evidenceCollection",
            "outcomeFinalization"
          ],
          "description": "Event that starts the disposal clock. Default caseClosure. Vendor-specific triggers go under ^x- patternProperties."
        },
        "respectsLegalHold": {
          "type": "boolean",
          "description": "Default true. Delegation flag: when true, an active kernel holdType: legal-hold per workflow-governance.md §7.15 (1) suspends the disposal clock and (2) rejects disposalAction execution with the hold reference recorded in rejection provenance. When false, the EvidenceRequirement disclaims kernel delegation and MUST carry regulatoryBasis[]."
        },
        "regulatoryBasis": {
          "type": "array",
          "minItems": 1,
          "description": "Cited authority documenting the regulatory basis. REQUIRED on the resolved (post-merge) policy when respectsLegalHold = false.",
          "items": {
            "type": [
              "string",
              "object"
            ],
            "description": "Either a SourceCitation id (string) or an inline citation object."
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "indefinite"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "not": {
              "required": [
                "duration"
              ]
            }
          }
        },
        {
          "if": {
            "anyOf": [
              {
                "not": {
                  "required": [
                    "mode"
                  ]
                }
              },
              {
                "properties": {
                  "mode": {
                    "const": "bounded"
                  }
                },
                "required": [
                  "mode"
                ]
              }
            ]
          },
          "then": {
            "required": [
              "duration"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "respectsLegalHold": {
                "const": false
              }
            },
            "required": [
              "respectsLegalHold"
            ]
          },
          "then": {
            "required": [
              "regulatoryBasis"
            ]
          }
        }
      ]
    }
