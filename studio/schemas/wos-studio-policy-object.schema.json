{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wos-spec.org/schemas/studio-policy-object/1.0",
  "title": "WOS Studio (Authoring) — Policy Object (polymorphic)",
  "description": "Polymorphic Studio PolicyObject schema covering all author-time PolicyObject kinds per studio/specs/policy-object-model.md and the composition table in CONCEPT-MODEL.md §6.1. Discriminated by `kind`. Carries the StudioMetadataEnvelope inline (id, workspaceId, version, citations[], provenance, originClass, lifecycleState, mappingState, etc.). Body shape is per-kind: WOS-projecting kinds (NoticeRequirement, AppealRight, ExplanationRequirement, Deadline, ActorMapping, EvidenceRequirement, Outcome, DecisionRule, ContinuationOfServicesRequirement, CounterfactualRequirement) project to WOS via `wosTarget` JSONPath. Studio-only kinds (PolicySource, AuthorityRank, ApplicabilityScope, EffectivePeriod, Supersession, Conflict, Assumption, OpenQuestion, ProtectedCategory) define body shapes inline. Deontic kinds (Requirement, Obligation, Permission, Prohibition, Right, Condition, ExceptionRule, DataElement) carry `defeasible: boolean` for OASIS LegalRuleML interop. Stage-3 enforces envelope + kind discriminator strictly; per-kind body shapes are loosely validated (flexible body with documented field expectations); deeper per-field validation lives in Stage-4 lint rules.",
  "$comment": "Promotion status (Stage-3, 2026-05-01): MVP shape; envelope + kind enum are load-bearing; per-kind body shapes are illustrative-and-flexible. Per CM §6.1 corrected pattern (2026-05-01), most kinds inline body with `wosTarget`/`wosShapeRef` documenting projection rather than $ref-composing absent WOS $defs.",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "$wosStudioPolicyObject",
        "id",
        "kind",
        "lifecycleState",
        "originClass"
      ],
      "additionalProperties": false,
      "patternProperties": {
        "^(\\$|x-)": {}
      },
      "properties": {
        "$wosStudioPolicyObject": {
          "type": "string",
          "const": "1.0",
          "description": "Document marker.",
          "examples": [
            "1.0"
          ],
          "x-lm": {
            "critical": true,
            "intent": "Document type marker for the polymorphic Studio PolicyObject"
          }
        },
        "id": {
          "type": "string",
          "examples": [
            "pol-notice-adverse-action",
            "pol-appeal-right-fair-hearing",
            "pol-decision-table-eligibility"
          ]
        },
        "workspaceId": {
          "type": "string",
          "description": "Workspace this PolicyObject belongs to. RECOMMENDED on every standalone PolicyObject document. MAY be omitted when the PolicyObject is serialized inside a collection wrapper (e.g., `{workspaceId: ws-X, policyObjects: [...]}`) where workspaceId is implicit from the wrapper. Stage-4 lint rule SHOULD reject standalone documents without workspaceId."
        },
        "kind": {
          "type": "string",
          "enum": [
            "NoticeRequirement",
            "AppealRight",
            "ExplanationRequirement",
            "ContinuationOfServicesRequirement",
            "CounterfactualRequirement",
            "Deadline",
            "ActorMapping",
            "EvidenceRequirement",
            "Outcome",
            "DecisionRule",
            "Requirement",
            "Obligation",
            "Permission",
            "Prohibition",
            "Right",
            "Condition",
            "ExceptionRule",
            "DataElement",
            "PolicySource",
            "AuthorityRank",
            "ApplicabilityScope",
            "EffectivePeriod",
            "Supersession",
            "Conflict",
            "Assumption",
            "OpenQuestion",
            "ProtectedCategory"
          ],
          "description": "Discriminator naming the PolicyObject kind. The `body` shape varies per kind (illustrative shapes documented inline; deeper validation via Stage-4 lint).",
          "examples": [
            "NoticeRequirement",
            "AppealRight",
            "Deadline",
            "Supersession"
          ],
          "x-lm": {
            "critical": true,
            "intent": "Polymorphism discriminator — load-bearing for routing to the right body shape and projection target"
          }
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "integer"
          ]
        },
        "parentVersion": {
          "type": [
            "string",
            "integer",
            "null"
          ]
        },
        "lifecycleState": {
          "$ref": "https://wos-spec.org/schemas/studio-common/1.0#/$defs/PolicyObjectLifecycleState",
          "description": "PolicyObject lifecycle state per policy-object-model.md. Enum lives in wos-studio-common.schema.json #/$defs/PolicyObjectLifecycleState.",
          "examples": [
            "draft",
            "approved"
          ]
        },
        "reviewState": {
          "type": "string"
        },
        "originClass": {
          "$ref": "https://wos-spec.org/schemas/studio-common/1.0#/$defs/OriginClass",
          "description": "Where this PolicyObject came from. Every approved PolicyObject MUST carry exactly one originClass per authoring-provenance.md. Enum lives in wos-studio-common.schema.json #/$defs/OriginClass.",
          "examples": [
            "source",
            "approved-interpretation"
          ],
          "x-lm": {
            "critical": true,
            "intent": "Origin classification — load-bearing for tier-S2 readiness and reviewer attestation requirements"
          }
        },
        "citations": {
          "type": "array",
          "description": "SourceCitation references grounding this PolicyObject. Per source-vault.md every approved PolicyObject MUST have at least one citation OR be backed by an Assumption.",
          "items": {
            "type": [
              "string",
              "object"
            ]
          }
        },
        "provenance": {
          "type": "array",
          "description": "AuthoringProvenanceRecord references. Append-only audit trail.",
          "items": {
            "description": "Either a SourceCitation/AuthoringProvenanceRecord reference (string id) OR a full inlined AuthoringProvenanceRecord object validated against wos-studio-provenance.schema.json#/$defs/AuthoringProvenanceRecord (G2 fix: was previously [string, object] with no shape constraint, so embedded records bypassed the per-record validation contract).",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "$ref": "https://wos-spec.org/schemas/studio-provenance/1.0#/$defs/AuthoringProvenanceRecord"
              }
            ]
          }
        },
        "mappingRef": {
          "type": "string"
        },
        "mappingState": {
          "$ref": "https://wos-spec.org/schemas/studio-common/1.0#/$defs/MappingState",
          "description": "How this PolicyObject relates to the WOS substrate. Required on approved objects; optional on draft. Enum lives in wos-studio-common.schema.json #/$defs/MappingState.",
          "examples": [
            "mapsToWos",
            "authoringOnly"
          ],
          "x-lm": {
            "critical": true,
            "intent": "Mapping disposition — load-bearing for compilation routing"
          }
        },
        "wosTarget": {
          "type": "string"
        },
        "wosShapeRef": {
          "type": "string"
        },
        "canonicalTermRef": {
          "type": "string"
        },
        "effectivenessRef": {
          "type": "string"
        },
        "authorityGrantsApplied": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "unmappedRationale": {
          "type": "string",
          "description": "Optional inline rationale (when mappingState = unmappedButApproved). Authoritative copy lives on the StudioToWosMapping; this is a reviewer-readability denormalization."
        },
        "body": {
          "type": "object",
          "description": "Kind-specific body. The `allOf` clauses below enforce required fields per `kind`. Body remains `additionalProperties: true` so authors may extend per-kind shapes; Stage-4 lint rules layer deeper per-field validation (FEL syntax, cross-document refs, etc.). For DecisionRule with body.form='table' (DecisionTable), body.rows[] / body.hitPolicy / body.completenessRequirement project to parent kernel decisionTables[*] per Kernel §4.5.1 (lossless round-trip).",
          "additionalProperties": true,
          "examples": [
            {
              "trigger": {
                "outcomeRef": "pol-outcome-denial"
              },
              "audience": "applicant",
              "content": [
                "reasonForAdverseAction",
                "appealRightAndDeadline"
              ],
              "deliveryMethod": [
                "mail"
              ],
              "language": [
                "en-US",
                "es-US"
              ]
            },
            {
              "deadline": {
                "calendarDaysFromNoticeDate": 90
              },
              "requestMethods": [
                "written",
                "phone",
                "in-person"
              ]
            },
            {
              "form": "table",
              "inputs": [
                {
                  "name": "income",
                  "type": "number"
                },
                {
                  "name": "householdSize",
                  "type": "integer"
                }
              ],
              "outputs": [
                {
                  "name": "eligible",
                  "type": "boolean"
                }
              ],
              "rows": [
                {
                  "id": "r1",
                  "inputCells": [
                    "income <= 1473",
                    "householdSize == 1"
                  ],
                  "outputCells": [
                    "true"
                  ]
                }
              ],
              "hitPolicy": "first"
            }
          ]
        },
        "linkedPolicyObjectRefs": {
          "type": "array",
          "description": "Cross-references to other PolicyObjects (e.g., AppealRight.linkedNoticeRef, Deadline.linkedAppealRightRef).",
          "items": {
            "type": "string"
          }
        }
      },
      "allOf": [
        {
          "$ref": "#/$defs/PolicyObjectKindRules"
        }
      ]
    },
    {
      "type": "object",
      "required": [
        "workspaceId",
        "policyObjects"
      ],
      "additionalProperties": false,
      "patternProperties": {
        "^(\\$|x-)": {}
      },
      "properties": {
        "workspaceId": {
          "type": "string",
          "description": "Workspace id; inherited by every child PolicyObject in the wrapper."
        },
        "policyObjects": {
          "type": "array",
          "minItems": 1,
          "description": "Collection-form PolicyObjects. Each child is validated against the same per-kind body rules as a standalone $wosStudioPolicyObject document via the shared $defs.PolicyObjectKindRules — including DecisionTable's hitPolicy/completenessRequirement, deontic body shapes, etc. The wrapper's workspaceId is implicit from the per-host envelope contract.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "kind",
              "lifecycleState",
              "originClass"
            ],
            "additionalProperties": true,
            "patternProperties": {
              "^(\\$|x-)": {}
            },
            "allOf": [
              {
                "$ref": "#/$defs/PolicyObjectKindRules"
              }
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "PolicyObjectKindRules": {
      "description": "Per-kind body shape rules. Shared between single-form (oneOf[0]) and collection-form items (oneOf[1].properties.policyObjects.items) so that DecisionTable hitPolicy/completenessRequirement, deontic body shapes, and other per-kind conditionals fire for collection-form children too. (G2 fix.)",
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "NoticeRequirement"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Notice body. Required: audience (who the notice goes to), content[] (the elements that MUST appear, e.g., reasonForAdverseAction, appealRightAndDeadline). Recommended: trigger, deliveryMethod[], timing, language[].",
                "required": [
                  "audience",
                  "content"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "AppealRight"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Appeal-right body. Required: deadline (calendar days), requestMethods[] (acceptable channels: written | phone | in-person | online). Recommended: hearingTimingDeadline, continuationOfServicesElection, linkedNoticeRef.",
                "required": [
                  "deadline",
                  "requestMethods"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "ExplanationRequirement"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Explanation body. Required: explanationLevel (e.g., individualized | aggregated). May carry includesCounterfactual flag, scope.",
                "required": [
                  "explanationLevel"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "ContinuationOfServicesRequirement"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Continuation-of-services body. Required: applicableTo (which adverse outcomes trigger continuation). May carry gracePeriod, optInRequired.",
                "required": [
                  "applicableTo"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "CounterfactualRequirement"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Counterfactual body. Required: polarity (positive | negative). May carry when (which decision contexts), constraints.",
                "required": [
                  "polarity"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "Deadline"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Deadline body. Required: trigger (event triggering the clock), expiryAction (notify | escalate | auto-decide | terminate). Time field: ONE OF calendarDaysFromTrigger, businessDaysFromTrigger, absoluteDeadline. Recommended: name, linkedAppealRightRef.",
                "required": [
                  "trigger",
                  "expiryAction"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "ActorMapping"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Actor body. Required: actorRole (e.g., caseworker, supervisor, fair-hearing-officer). Recommended: actorKind (human | agent | service), actorAuthority (deontic constraints on what this actor MAY/MUST do).",
                "required": [
                  "actorRole"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "EvidenceRequirement"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Evidence body. Required: evidenceType. Recommended: caseFileFieldRef, deadlineRef. Optional: retentionPolicy (typed, per ADR-0083 r2 — replaces the historical singular retentionPeriod field; lint emits SA-WARN-pom-MIGRATE-RETENTION if the legacy field is present).",
                "required": [
                  "evidenceType"
                ],
                "properties": {
                  "retentionPolicy": {
                    "$ref": "#/$defs/RetentionPolicy"
                  }
                }
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "Outcome"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Outcome body. Required: polarity (favorable | adverse | neutral). Recommended: label, triggersDueProcess, postClosureActions[].",
                "required": [
                  "polarity"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "DecisionRule"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "DecisionRule body. Required: form ('single' | 'table'). Single-form requires: condition (FEL), outcome. Table-form (DecisionTable) requires: inputs[], outputs[], rows[], hitPolicy, completenessRequirement (per SA-MUST-bind-040). Per Kernel §4.5.1, table-form projects to parent decisionTables[*].",
                "required": [
                  "form"
                ],
                "allOf": [
                  {
                    "$comment": "SA-MUST-bind-040: table-form DecisionRule MUST declare hitPolicy + completenessRequirement.",
                    "if": {
                      "properties": {
                        "form": {
                          "const": "table"
                        }
                      },
                      "required": [
                        "form"
                      ]
                    },
                    "then": {
                      "required": [
                        "hitPolicy",
                        "completenessRequirement"
                      ],
                      "properties": {
                        "hitPolicy": {
                          "type": "string",
                          "enum": [
                            "first-match",
                            "priority",
                            "unique",
                            "output-merge"
                          ]
                        },
                        "completenessRequirement": {
                          "type": "string",
                          "enum": [
                            "all-inputs-covered",
                            "partial-allowed-with-default"
                          ]
                        }
                      }
                    }
                  }
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "DataElement"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "DataElement body. Required: name, dataType (FEL type). Recommended: sensitivity (DPV IRI), unit, definition, canonicalTermRef (cross-workspace identity).",
                "required": [
                  "name",
                  "dataType"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "ProtectedCategory"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Protected-category body for equity monitoring. Required: dimensionName (e.g., 'language-spoken', 'race-ethnicity'). Recommended: legalBasis, monitoringMethod, disparityThreshold, dpvSensitivity.",
                "required": [
                  "dimensionName"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "PolicySource"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Source-and-authority body. Required: sourceDocumentRef. Recommended: name, authority (issuing body), canonicalSourceRef.",
                "required": [
                  "sourceDocumentRef"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "AuthorityRank"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Authority-rank body. Required: rankings[] = [{kind, rank, rationale}] establishing precedence among PolicySources. Recommended: applicableTo (scope of these rankings).",
                "required": [
                  "rankings"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "ApplicabilityScope"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Applicability-scope body. Recommended: programs[], jurisdictions[], dateRanges, caseFilters, effectivenessRef. (Composes with the workflow's effectivenessRef.)"
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "EffectivePeriod"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Effective-period body. Recommended: name, intervals[], retroactiveFrom, sunsetAt."
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "Supersession"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Supersession body. Required: superseder (the newer authority), superseded (the older). Recommended: effectiveAt, scope, supersessionRationale.",
                "required": [
                  "superseder",
                  "superseded"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "Conflict"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Conflict body. Required: conflictingObjects[] (refs to the conflicting PolicyObjects/Sources). Recommended: narrative, resolution (ReviewerResolution ref or inline).",
                "required": [
                  "conflictingObjects"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "Assumption"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "body": {
                "type": "object",
                "additionalProperties": true,
                "patternProperties": {
                  "^(\\$|x-)": {}
                },
                "description": "Assumption body. Required: narrative (what is assumed). Recommended: rationale, scope, severity, alternativesConsidered, policyPermissibilityAttestation.",
                "required": [
                  "narrative"
                ]
              }
            },
            "required": [
              "body"
            ]
          }
        },
        {
          "if": {
