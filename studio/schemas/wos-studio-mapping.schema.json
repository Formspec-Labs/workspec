{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wos-spec.org/schemas/studio-mapping/1.0",
  "title": "WOS Studio (Authoring) \u2014 Studio-to-WOS Mapping",
  "description": "StudioToWosMapping records per studio/specs/studio-to-wos-mapping.md and CONCEPT-MODEL.md \u00a71.11. Each mapping declares one of the four mapping states (mapsToWos | authoringOnly | requiresSpecExtension | unmappedButApproved) for a PolicyObject. The four states encode the authoring-vocabulary-vs-substrate split named in CM \u00a75 'WOS as canonical substrate'. Top-level document MAY carry one mapping or a `mappings[]` collection.",
  "$comment": "Promotion status (Stage-3, 2026-05-01): MVP shape; the `targets[]` shape (for mapsToWos state) and `extensionRecord` shape (for requiresSpecExtension state) are illustrative \u2014 Stage-4 lint enforces precedence + per-state required fields.",
  "type": "object",
  "required": [
    "$wosStudioMapping"
  ],
  "additionalProperties": false,
  "patternProperties": {
    "^(\\$|x-)": {}
  },
  "properties": {
    "$wosStudioMapping": {
      "type": "string",
      "const": "1.0",
      "description": "Document marker pinning this artifact to the Studio Mapping 1.0 schema.",
      "examples": [
        "1.0"
      ],
      "x-lm": {
        "critical": true,
        "intent": "Document type marker for Studio-to-WOS Mapping artifacts"
      }
    },
    "workspaceId": {
      "type": "string",
      "description": "Workspace this mapping (or mapping collection) belongs to."
    },
    "mappings": {
      "type": "array",
      "description": "Collection form: many StudioToWosMapping records.",
      "items": {
        "$ref": "#/$defs/StudioToWosMapping"
      }
    },
    "mapping": {
      "$ref": "#/$defs/StudioToWosMapping",
      "description": "Single-mapping form."
    }
  },
  "$defs": {
    "StudioToWosMapping": {
      "type": "object",
      "required": [
        "id",
        "subjectPolicyObjectRef",
        "mappingState"
      ],
      "additionalProperties": true,
      "patternProperties": {
        "^(\\$|x-)": {}
      },
      "properties": {
        "id": {
          "type": "string",
          "examples": [
            "map-pol-notice-adverse-action"
          ]
        },
        "subjectPolicyObjectRef": {
          "type": "string",
          "description": "PolicyObject id this mapping applies to."
        },
        "mappingState": {
          "type": "string",
          "enum": [
            "mapsToWos",
            "authoringOnly",
            "requiresSpecExtension",
            "unmappedButApproved"
          ],
          "description": "How the PolicyObject relates to the WOS substrate. Precedence: mapsToWos > authoringOnly > requiresSpecExtension > unmappedButApproved.",
          "x-lm": {
            "critical": true,
            "intent": "Mapping state \u2014 load-bearing for compilation routing and reviewer attestation requirements"
          },
          "examples": [
            "mapsToWos",
            "authoringOnly"
          ]
        },
        "targets": {
          "type": "array",
          "description": "Target descriptors when mappingState = mapsToWos. Each carries wosJsonPath (projection target) + shapeRef (closest WOS $def or block path) + optional fieldBindings + reviewer rationale.",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "wosJsonPath": {
                "type": "string",
                "examples": [
                  "$.governance.notices[?(@.id=='notice-adverse-action')]",
                  "$.lifecycle.transitions[*].guard"
                ]
              },
              "shapeRef": {
                "type": "string",
                "description": "Citation of closest WOS $def or block path. May be an authoritative $ref URL when a $def exists, or prose path otherwise (per CM \u00a76.1 corrected pattern, 2026-05-01).",
                "examples": [
                  "wos-workflow.schema.json#/$defs/AppealMechanism",
                  "wos-workflow.schema.json#/$defs/DecisionTable"
                ]
              },
              "fieldBindings": {
                "type": "array",
                "description": "Per-field map from Studio body fields \u2192 WOS schema fields.",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "compilerNote": {
                "type": "string"
              },
              "mappingNotes": {
                "type": "string"
              },
              "reviewedBy": {
                "type": "string"
              },
              "reviewedAt": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        },
        "extensionRecord": {
          "type": "object",
          "description": "Required when mappingState = requiresSpecExtension. Captures the candidate WOS-side extension proposal.",
          "additionalProperties": true,
          "properties": {
            "id": {
              "type": "string"
            },
            "candidateConceptName": {
              "type": "string"
            },
            "motivatingPolicyObjectRefs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "proposedSeam": {
              "type": "string",
              "description": "Which of the six canonical kernel seams (per parent ADR-0077) this extension would attach to. Per studio-to-wos-mapping.md SA-MUST-map-020.",
              "enum": [
                "actorExtension",
                "contractHook",
                "provenanceLayer",
                "lifecycleHook",
                "custodyHook",
                "extensions"
              ],
              "examples": [
                "actorExtension",
                "contractHook",
                "extensions"
              ]
            },
            "proposedSemantics": {
              "type": "string",
              "minLength": 200,
              "description": "Substantive prose (at least 200 characters) per studio-to-wos-mapping.md SA-MUST-map-022."
            },
            "proposedSchemaSketch": {
              "type": "string",
              "minLength": 1,
              "description": "Non-empty informal schema sketch per studio-to-wos-mapping.md SA-MUST-map-022."
            },
            "evidenceCitations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "lifecycleState": {
              "type": "string"
            }
          }
        },
        "extensionsApplied": {
          "type": "array",
          "description": "Extension keys (e.g., x-canonical-term, x-dpv-sensitivity) applied during projection per ADR-0077 patternProperties.",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "extensionKey": {
                "type": "string"
              },
              "value": {}
            }
          }
        },
        "unmappedRationale": {
          "type": "string",
          "description": "Required when mappingState = unmappedButApproved. Documented reason the PolicyObject is acceptable without a WOS counterpart."
        },
        "approvedBy": {
          "type": "string"
        },
        "approvedAt": {
          "type": "string",
          "format": "date-time"
        },
        "lifecycleState": {
          "type": "string",
          "enum": [
            "draft",
            "reviewed",
            "approved",
            "published",
            "superseded"
          ]
        },
        "workspaceId": {
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "integer"
          ]
        },
        "extensionRecordRef": {
          "type": "string",
          "description": "Alternative to inline extensionRecord \u2014 refers to an externally-stored ExtensionRecord by id. Authoritative when present."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mappingState": {
                "const": "mapsToWos"
              }
            },
            "required": [
              "mappingState"
            ]
          },
          "then": {
            "properties": {
              "targets": {
                "type": "array",
                "minItems": 1,
                "description": "mapsToWos requires at least one target descriptor."
              }
            },
            "required": [
              "targets"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "mappingState": {
                "const": "requiresSpecExtension"
              }
            },
            "required": [
              "mappingState"
            ]
          },
          "then": {
            "anyOf": [
              {
                "required": [
                  "extensionRecord"
                ]
              },
              {
                "required": [
                  "extensionRecordRef"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "mappingState": {
                "const": "unmappedButApproved"
              }
            },
            "required": [
              "mappingState"
            ]
          },
          "then": {
            "required": [
              "unmappedRationale"
            ]
          }
        }
      ]
    }
  }
}
