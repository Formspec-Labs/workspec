{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wos-spec.org/schemas/studio-provenance/1.0",
  "title": "WOS Studio (Authoring) \u2014 Authoring Provenance Record",
  "description": "AuthoringProvenanceRecord per studio/specs/authoring-provenance.md. Append-only audit trail for every state transition on every Studio object. Carries hashChain (composes parent custodyHook 4-field encoding per PLN-0385 for cryptographic anchoring), AI-extraction subtype (with full aiLineage: modelId/modelVersion/promptTemplateRef/temperature/seed/inputContextHash/humanApprover/humanRationale per SA-MUST-prov-070-074), and audit event-type tags (composes parent PLN-0384 wos-event-types.md `wos.authoring.*` namespace per SA-MUST-prov-100-103).",
  "$comment": "Promotion status (Stage-3, 2026-05-01): MVP shape; eventKind enum is closed-but-extensible.",
  "type": "object",
  "required": [
    "$wosStudioProvenance"
  ],
  "additionalProperties": false,
  "patternProperties": {
    "^(\\$|x-)": {}
  },
  "properties": {
    "$wosStudioProvenance": {
      "type": "string",
      "const": "1.0",
      "examples": [
        "1.0"
      ],
      "x-lm": {
        "critical": true,
        "intent": "Document type marker for AuthoringProvenance records (or record collection)"
      },
      "description": "Document marker pinning this artifact to the Studio AuthoringProvenance 1.0 schema."
    },
    "workspaceId": {
      "type": "string"
    },
    "records": {
      "type": "array",
      "description": "Collection form: many records.",
      "items": {
        "$ref": "#/$defs/AuthoringProvenanceRecord"
      }
    },
    "record": {
      "$ref": "#/$defs/AuthoringProvenanceRecord"
    }
  },
  "$defs": {
    "AuthoringProvenanceRecord": {
      "type": "object",
      "required": [
        "id",
        "eventKind",
        "subjectRef",
        "recordedAt",
        "recordedBy",
        "role",
        "originClass"
      ],
      "additionalProperties": true,
      "patternProperties": {
        "^(\\$|x-)": {}
      },
      "properties": {
        "id": {
          "type": "string"
        },
        "eventKind": {
          "type": "string",
          "enum": [
            "extracted",
            "normalized",
            "promoted",
            "edited",
            "approved",
            "rejected",
            "merged",
            "split",
            "demoted",
            "superseded",
            "mapped",
            "unmapped",
            "scenario-generated",
            "scenario-passed",
            "scenario-failed",
            "compiled",
            "published",
            "republished",
            "deprecated",
            "bridge-override",
            "manualOverrideRecorded",
            "waived"
          ],
          "description": "Event kind. Extends to cover all authoring lifecycle transitions.",
          "examples": [
            "extracted",
            "approved",
            "compiled"
          ],
          "x-lm": {
            "critical": true,
            "intent": "Provenance event kind \u2014 load-bearing for tier-S2 readiness rule selection and audit-event-type-tag projection"
          }
        },
        "eventSubtype": {
          "type": "string",
          "description": "Subtype refinement (e.g., 'ai-assisted' for extracted, 'bridge-override' rationale).",
          "examples": [
            "ai-assisted",
            "human-only",
            "fast-track"
          ]
        },
        "subjectRef": {
          "type": "string",
          "description": "Object this record is about (PolicyObject id, WorkflowIntent id, etc.)."
        },
        "subjectKind": {
          "type": "string",
          "examples": [
            "PolicyObject",
            "WorkflowIntent",
            "Scenario",
            "ApprovalDecision"
          ]
        },
        "recordedAt": {
          "type": "string",
          "format": "date-time"
        },
        "recordedBy": {
          "type": "string",
          "description": "IdentitySubject who emitted this record (or `subj-system` / `subj-ai-claim-extractor` for non-human emitters)."
        },
        "role": {
          "type": "string",
          "examples": [
            "agent",
            "workflow-owner",
            "compliance-reviewer",
            "legal-reviewer",
            "system"
          ]
        },
        "originClass": {
          "$ref": "https://wos-spec.org/schemas/studio-common/1.0#/$defs/OriginClass"
        },
        "rationale": {
          "type": "string"
        },
        "aiLineage": {
          "type": "object",
          "description": "AI-extraction subtype lineage (per SA-MUST-prov-070-074). REQUIRED when eventKind in {extracted, normalized} and eventSubtype = ai-assisted. When present, modelId/modelVersion/promptTemplateRef/promptTemplateVersion/inputContextHash are REQUIRED per SA-MUST-prov-071.",
          "additionalProperties": true,
          "required": [
            "modelId",
            "modelVersion",
            "promptTemplateRef",
            "promptTemplateVersion",
            "inputContextHash"
          ],
          "properties": {
            "modelId": {
              "type": "string"
            },
            "modelVersion": {
              "type": "string"
            },
            "modelVersionPolicy": {
              "type": "string",
              "enum": [
                "pinned",
                "rolling",
                "latest"
              ]
            },
            "promptTemplateRef": {
              "type": "string"
            },
            "promptTemplateVersion": {
              "type": "string"
            },
            "temperature": {
              "type": "number"
            },
            "seed": {
              "type": [
                "integer",
                "string",
                "null"
              ]
            },
            "inputContextHash": {
              "type": "string"
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "humanApprover": {
              "type": "string",
              "description": "REQUIRED before promotion past `extracted`. AI-only promotion is disallowed."
            },
            "humanApprovedAt": {
              "type": "string",
              "format": "date-time"
            },
            "humanRationale": {
              "type": "string"
            }
          }
        },
        "hashChain": {
          "type": "object",
          "description": "Cryptographic chain anchoring (composes parent custodyHook 4-field encoding per PLN-0385). Per SA-MUST-prov-080-083. prevRecordHash and selfHash are REQUIRED.",
          "additionalProperties": true,
          "required": [
            "prevRecordHash",
            "selfHash"
          ],
          "properties": {
            "prevRecordHash": {
              "type": "string",
              "examples": [
                "sha256:0a1b2c..."
              ]
            },
            "selfHash": {
              "type": "string",
              "examples": [
                "sha256:1b2c3d..."
              ]
            },
            "anchoredAt": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            },
            "custodyAppendReceiptRef": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "auditEventTypeTag": {
          "type": "string",
          "description": "Optional audit event-type tag from the `wos.authoring.*` namespace per parent PLN-0384 wos-event-types.md.",
          "examples": [
            "wos.authoring.claim-extracted",
            "wos.authoring.requirement-approved",
            "wos.authoring.workflow-published"
          ]
        },
        "mappingState": {
          "type": "string",
          "description": "When eventKind = mapped, the assigned mappingState per SA-MUST-prov-022."
        },
        "targets": {
          "type": "array",
          "description": "When eventKind = mapped and mappingState = mapsToWos, the target list per SA-MUST-prov-022.",
          "items": {
            "type": [
              "string",
              "object"
            ]
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "eventKind": {
                "const": "mapped"
              }
            },
            "required": [
              "eventKind"
            ]
          },
          "then": {
            "required": [
              "mappingState"
            ],
            "$comment": "Per SA-MUST-prov-022: every mapped event MUST carry the assigned mappingState."
          }
        },
        {
          "if": {
            "properties": {
              "eventSubtype": {
                "const": "ai-assisted"
              }
            },
            "required": [
              "eventSubtype"
            ]
          },
          "then": {
            "required": [
              "aiLineage"
            ],
            "$comment": "Per SA-MUST-prov-070/071: when eventSubtype=ai-assisted, the aiLineage block MUST be present (with its own required fields enforced by the aiLineage object definition: modelId, modelVersion, promptTemplateRef, promptTemplateVersion, inputContextHash)."
          }
        }
      ]
    }
  }
}
