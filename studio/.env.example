# GEMINI_API_KEY: Required for AI chat features.
# The server proxies requests to the Gemini API — the key never reaches the client.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# API_TOKEN: Bearer token for /api/ routes.
# When set, all /api/ endpoints require `Authorization: Bearer <token>`.
# Leave unset to disable auth (dev mode).
# API_TOKEN=""

# CORS_ORIGIN: Allowed origin for CORS headers. Defaults to "*".
# CORS_ORIGIN="https://your-domain.example"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
