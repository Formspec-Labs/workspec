{
  "$wosWorkflow": "1.0",
  "version": "1.0.0",
  "title": "Due Process Governance Test",
  "url": "https://example.test/migrated-fixture",
  "impactLevel": "operational",
  "actors": [
    {
      "id": "system",
      "type": "system"
    }
  ],
  "lifecycle": {
    "initialState": "start",
    "states": {
      "start": {
        "type": "atomic",
        "transitions": [
          {
            "target": "done"
          }
        ]
      },
      "done": {
        "type": "final"
      }
    }
  },
  "governance": {
    "dueProcess": {
      "adverseDecisionPolicy": {
        "noticeRequired": true,
        "noticeTiming": "beforeEffective",
        "noticeGracePeriod": "P30D",
        "noticeTemplateKey": "adverseDecisionNotice",
        "explanationLevel": "individualized",
        "counterfactualRequired": true,
        "appealMechanism": {
          "enabled": true,
          "appealWindow": "P30D",
          "reviewerConstraint": "independentFromOriginal",
          "reviewerRoles": [
            "appealReviewer"
          ],
          "continuationOfServices": true,
          "continuationScope": "currentLevel"
        }
      }
    },
    "reviewProtocols": [
      {
        "tags": [
          "appeal"
        ],
        "protocols": [
          "independentFirst",
          "considerOpposite"
        ],
        "description": "Appeal uses independent-first protocol"
      }
    ],
    "qualityControls": {
      "reviewSampling": {
        "rate": 0.1,
        "method": "random",
        "scope": "workflow"
      },
      "separationOfDuties": {
        "scope": "sameInstance"
      },
      "overrideAuthority": {
        "requireStructuredRationale": true,
        "requireSupportingEvidence": true,
        "requireAuthorityVerification": true
      }
    }
  }
}
