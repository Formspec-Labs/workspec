{
  "$wosWorkflow": "1.0",
  "version": "1.0.0",
  "title": "Triage Agent Configuration",
  "url": "https://example.test/migrated-fixture",
  "impactLevel": "operational",
  "actors": [
    {
      "id": "system",
      "type": "system"
    }
  ],
  "lifecycle": {
    "initialState": "start",
    "states": {
      "start": {
        "type": "atomic",
        "transitions": [
          {
            "target": "done"
          }
        ]
      },
      "done": {
        "type": "final"
      }
    }
  },
  "agents": [
    {
      "id": "triageAgent",
      "targetIntegration": "https://test.wos-spec.org/ai/autonomy-caps",
      "calibration": {
        "required": true,
        "frequency": "P90D",
        "minimumSamples": 50,
        "method": "binning"
      },
      "autonomyPolicy": {
        "escalation": [
          {
            "condition": "agent.consecutiveSuccesses >= 50 and agent.calibration.recency < 30",
            "targetLevel": "autonomous",
            "escalationExpiry": "P30D",
            "description": "Promote to autonomous after consistent performance"
          }
        ],
        "demotion": [
          {
            "id": "demoteOnLowAccuracyOrViolation",
            "condition": "agent.calibration.accuracy < 0.85 or agent.recentViolations > 0",
            "targetLevel": "assistive",
            "pendingRecalibration": true,
            "description": "Demote on confidence floor violation, deontic violation, or human override"
          }
        ],
        "maxAutonomy": "autonomous"
      }
    }
  ]
}
