{
  "$wosWorkflow": "1.0",
  "version": "1.0.0",
  "title": "Triage Agent Configuration Overlay",
  "description": "Per-agent configuration overlay (autonomy policy + calibration). Conformance-fixture transport wrapper: the conformance engine extracts the `agents` block and embeds it under the kernel workflow at runtime. Per ADR 0063 \u00a72.1, embedded agent declarations govern the enclosing envelope and carry no independent identity.",
  "url": "https://test.wos-spec.org/workflows/autonomy-caps",
  "impactLevel": "rights-impacting",
  "actors": [
    {
      "id": "triageAgent",
      "type": "agent"
    }
  ],
  "lifecycle": {
    "initialState": "start",
    "states": {
      "start": {
        "type": "atomic",
        "transitions": [
          {
            "target": "done"
          }
        ]
      },
      "done": {
        "type": "final"
      }
    }
  },
  "agents": [
    {
      "id": "triageAgent",
      "calibration": {
        "required": true,
        "frequency": "P90D",
        "minimumSamples": 50,
        "method": "binning"
      },
      "autonomyPolicy": {
        "escalation": [
          {
            "condition": "agent.consecutiveSuccesses >= 50 and agent.calibration.recency < 30",
            "targetLevel": "autonomous",
            "escalationExpiry": "P30D",
            "description": "Promote to autonomous after consistent performance"
          }
        ],
        "demotion": [
          {
            "id": "demoteOnLowAccuracyOrViolation",
            "condition": "agent.calibration.accuracy < 0.85 or agent.recentViolations > 0",
            "targetLevel": "assistive",
            "pendingRecalibration": true,
            "description": "Demote on confidence floor violation, deontic violation, or human override"
          }
        ],
        "maxAutonomy": "autonomous"
      }
    }
  ],
  "governance": {
    "dueProcess": {}
  },
  "custody": {
    "trustProfileRef": "urn:trellis:trust-profile/dev"
  }
}
