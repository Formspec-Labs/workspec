{
  "$wosWorkflow": "1.0",
  "version": "1.0.0",
  "title": "Autonomy Caps AI Integration Overlay",
  "description": "AI integration overlay for testing autonomy level caps, escalation/demotion, and calibration expiry. Conformance-fixture transport wrapper: the conformance engine extracts the `aiOversight` block and embeds it under the kernel workflow at runtime. Per ADR 0063 §2.1, embedded blocks govern the enclosing envelope; the engine wires aiOversight.agents into the kernel's agents[].",
  "url": "https://test.wos-spec.org/workflows/autonomy-caps",
  "impactLevel": "rights-impacting",
  "actors": [
    {
      "id": "triageAgent",
      "type": "agent"
    }
  ],
  "lifecycle": {
    "initialState": "start",
    "states": {
      "start": {
        "type": "atomic",
        "transitions": [
          {
            "target": "done"
          }
        ]
      },
      "done": {
        "type": "final"
      }
    }
  },
  "aiOversight": {
    "defaultAutonomy": "assistive",
    "agents": [
      {
        "id": "triageAgent",
        "type": "agent",
        "agentType": "generative",
        "modelIdentifier": "test-model",
        "modelVersion": "1.0",
        "description": "Triage agent with escalation and demotion rules",
        "capabilities": [
          {
            "id": "triage",
            "description": "Categorize and prioritize cases",
            "outputContractRef": "urn:formspec:test:triage:1.0.0"
          }
        ],
        "deonticConstraints": {
          "permissions": [
            {
              "id": "perm-triage-only",
              "bounds": "output.action = 'categorize' or output.action = 'prioritize'",
              "onViolation": "escalateToHuman"
            }
          ]
        },
        "fallbackChain": [
          {
            "action": "retry",
            "maxRetries": 1,
            "backoff": "fixed",
            "initialInterval": "PT1S"
          },
          {
            "action": "escalateToHuman",
            "taskRef": "manualTriage",
            "assignTo": "caseworker"
          }
        ]
      }
    ]
  }
}