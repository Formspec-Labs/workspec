{
  "$wosAgentConfig": "1.0",
  "$schema": "https://wos-spec.org/schemas/agent-config/1.0",
  "targetAgent": "documentExtractor",
  "targetIntegration": "https://agency.gov/ai/benefits-adjudication-ai",
  "version": "1.0.0",
  "title": "Document Extractor Agent Configuration",

  "endpoint": {
    "url": "https://ai.agency.gov/agents/doc-extractor/v2",
    "credentialRef": "vault://agents/doc-extractor/api-key",
    "timeout": "PT30S",
    "healthCheckUrl": "https://ai.agency.gov/agents/doc-extractor/health"
  },

  "approvedVersions": ["2025-05-14"],

  "calibration": {
    "required": true,
    "frequency": "P30D",
    "minimumSamples": 100,
    "method": "binning"
  },

  "autonomyPolicy": {
    "escalation": [
      {
        "condition": "agent.calibration.accuracy >= 0.97",
        "targetLevel": "supervisory",
        "description": "Escalate to supervisory when accuracy exceeds 97% in calibration"
      }
    ],
    "demotion": [
      {
        "id": "demoteToManualOnLowAccuracy",
        "condition": "agent.calibration.accuracy < 0.90",
        "targetLevel": "manual",
        "pendingRecalibration": true,
        "description": "Demote to manual when accuracy drops below 90%"
      },
      {
        "id": "demoteToAssistiveOnDegradedAccuracy",
        "condition": "agent.calibration.accuracy < 0.95",
        "targetLevel": "assistive",
        "pendingRecalibration": false,
        "description": "Demote to assistive when accuracy drops below 95%"
      }
    ],
    "maxAutonomy": "supervisory"
  },

  "actionOverrides": [
    {
      "actionRef": "incomeVerification.invokeDocExtractor",
      "autonomy": "assistive",
      "reviewWindow": "PT4H",
      "confidenceFloor": 0.85
    }
  ]
}
