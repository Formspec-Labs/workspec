{
  "$wosDelivery": "1.0",
  "targetWorkflow": "https://agency.gov/workflows/benefits-adjudication",
  "correspondence": {
    "$schema": "https://wos-spec.org/schemas/correspondence-metadata/1.0",
    "version": "1.0.0",
    "title": "Benefits Adjudication Correspondence Metadata",
    "description": "Correspondence metadata for the benefits adjudication workflow. Defines templates for all inbound and outbound communications tracked in the case record.",
    "correspondenceField": "caseFile.correspondence",
    "entryTemplates": [
      {
        "id": "inboundMail",
        "description": "Physical mail received from applicant or authorized representative",
        "channel": "mail",
        "direction": "inbound",
        "actorType": "applicant",
        "requiredFields": [
          "contentRef"
        ]
      },
      {
        "id": "inboundEmail",
        "description": "Email received from applicant via secure messaging",
        "channel": "email",
        "direction": "inbound",
        "actorType": "applicant"
      },
      {
        "id": "inboundPortal",
        "description": "Document or message submitted through the self-service portal",
        "channel": "portal",
        "direction": "inbound",
        "actorType": "applicant",
        "requiredFields": [
          "contentRef"
        ]
      },
      {
        "id": "inboundThirdParty",
        "description": "Documentation received from third party (employer, medical provider, etc.)",
        "channel": "mail",
        "direction": "inbound",
        "actorType": "third-party",
        "requiredFields": [
          "contentRef"
        ]
      },
      {
        "id": "phoneContact",
        "description": "Phone call with applicant or representative",
        "channel": "phone",
        "direction": "inbound",
        "actorType": "applicant"
      },
      {
        "id": "inPersonVisit",
        "description": "In-person visit at agency office",
        "channel": "in-person",
        "direction": "inbound",
        "actorType": "applicant"
      },
      {
        "id": "outboundNotice",
        "description": "Official notice mailed to applicant (adverse decision, request for information, etc.)",
        "channel": "mail",
        "direction": "outbound",
        "actorType": "agency",
        "requiredFields": [
          "contentRef",
          "relatedTaskRef"
        ]
      },
      {
        "id": "outboundEmail",
        "description": "Email sent to applicant from caseworker or system",
        "channel": "email",
        "direction": "outbound",
        "actorType": "agency"
      },
      {
        "id": "systemNotification",
        "description": "Automated system-generated notification (portal alert, status update)",
        "channel": "portal",
        "direction": "outbound",
        "actorType": "system"
      }
    ]
  }
}