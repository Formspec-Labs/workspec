{
  "$wosKernel": "1.0",
  "$schema": "https://wos-spec.org/schemas/kernel/1.0",
  "url": "https://test.wos-spec.org/workflows/timer-tolerance-violation",
  "version": "1.0.0",
  "title": "Timer Tolerance Violation",
  "description": "Minimal workflow with a short timer (PT5S). Tests that firing the timer far beyond its tolerance window (Runtime S7.2: under 1h = 1s tolerance) produces a conformance violation diagnostic (LCD S6.6).",
  "status": "active",
  "impactLevel": "operational",

  "actors": [
    { "id": "system", "type": "system", "description": "System actor" }
  ],

  "lifecycle": {
    "initialState": "waiting",
    "states": {
      "waiting": {
        "type": "atomic",
        "onEntry": [
          {
            "action": "startTimer",
            "timerId": "shortTimer",
            "duration": "PT5S",
            "event": "$timeout.state"
          }
        ],
        "transitions": [
          {
            "event": "$timeout.state",
            "target": "done"
          }
        ]
      },
      "done": { "type": "final" }
    }
  },

  "caseFile": {
    "fields": {}
  },

  "execution": {
    "workflowTimeout": "P1D",
    "instanceVersioning": "pinned"
  }
}
