{
  "$wosWorkflow": "1.0",
  "$schema": "https://wos-spec.org/schemas/workflow/1.0",
  "url": "https://agency.gov/workflows/benefits-appeal",
  "version": "1.0.0",
  "title": "Benefits Appeal Workflow",
  "description": "An appeal case that is a child of the original benefits adjudication case. Demonstrates case relationships (Kernel S5.5): the appeal case declares a parent/child relationship to the original case. Cross-case interaction uses correlationKey -- when the appeal enters determination, it emits an event that the original case receives via correlation.",
  "status": "active",
  "impactLevel": "rights-impacting",
  "actors": [
    {
      "id": "appellant",
      "type": "human",
      "description": "Individual filing the appeal"
    },
    {
      "id": "appealAdjudicator",
      "type": "human",
      "description": "Independent adjudicator reviewing the appeal"
    },
    {
      "id": "notificationSystem",
      "type": "system",
      "description": "Sends notices to involved parties"
    }
  ],
  "lifecycle": {
    "initialState": "filed",
    "states": {
      "filed": {
        "type": "atomic",
        "tags": [
          "intake",
          "appeal"
        ],
        "onEntry": [
          {
            "action": "log",
            "message": "Appeal filed against original determination",
            "data": {
              "parentCase": "${caseFile.parentCaseRef}",
              "appealBasis": "${caseFile.appealBasis}"
            }
          }
        ],
        "transitions": [
          {
            "event": {
              "kind": "message",
              "name": "assignedForReview"
            },
            "target": "underReview"
          }
        ]
      },
      "underReview": {
        "type": "atomic",
        "tags": [
          "review"
        ],
        "onEntry": [
          {
            "action": "createTask",
            "taskRef": "appealReview",
            "assignTo": "appealAdjudicator"
          }
        ],
        "transitions": [
          {
            "event": {
              "kind": "message",
              "name": "appealGranted"
            },
            "target": "granted",
            "tags": [
              "determination"
            ]
          },
          {
            "event": {
              "kind": "message",
              "name": "appealDenied"
            },
            "target": "denied",
            "tags": [
              "determination",
              "adverse-decision"
            ]
          },
          {
            "event": {
              "kind": "message",
              "name": "remanded"
            },
            "target": "remanded",
            "tags": [
              "determination"
            ]
          }
        ]
      },
      "granted": {
        "type": "atomic",
        "tags": [
          "notification"
        ],
        "onEntry": [
          {
            "action": "emitEvent",
            "eventType": "appealResolved",
            "data": {
              "outcome": "granted",
              "parentCaseRef": "${caseFile.parentCaseRef}"
            }
          },
          {
            "action": "invokeService",
            "serviceRef": "notificationSystem",
            "idempotencyKey": "${instance.id}-granted-notice"
          }
        ],
        "transitions": [
          {
            "event": {
              "kind": "message",
              "name": "acknowledged"
            },
            "target": "closed"
          }
        ]
      },
      "denied": {
        "type": "atomic",
        "tags": [
          "notification",
          "adverse-decision"
        ],
        "onEntry": [
          {
            "action": "emitEvent",
            "eventType": "appealResolved",
            "data": {
              "outcome": "denied",
              "parentCaseRef": "${caseFile.parentCaseRef}"
            }
          },
          {
            "action": "invokeService",
            "serviceRef": "notificationSystem",
            "idempotencyKey": "${instance.id}-denied-notice"
          }
        ],
        "transitions": [
          {
            "event": {
              "kind": "message",
              "name": "acknowledged"
            },
            "target": "closed"
          }
        ]
      },
      "remanded": {
        "type": "atomic",
        "tags": [
          "notification"
        ],
        "onEntry": [
          {
            "action": "emitEvent",
            "eventType": "appealRemanded",
            "data": {
              "instructions": "${caseFile.remandInstructions}",
              "parentCaseRef": "${caseFile.parentCaseRef}"
            }
          }
        ],
        "transitions": [
          {
            "event": {
              "kind": "message",
              "name": "remandComplete"
            },
            "target": "underReview",
            "description": "Original case completed remand instructions -- return to appeal review"
          }
        ]
      },
      "closed": {
        "type": "final"
      }
    }
  },
  "caseFile": {
    "fields": {
      "parentCaseRef": {
        "type": "string",
        "description": "URI of the original case being appealed"
      },
      "appealBasis": {
        "type": "string",
        "description": "Legal basis for the appeal"
      },
      "originalDetermination": {
        "type": "object",
        "description": "Copy of the original adverse determination being appealed"
      },
      "appealDecision": {
        "type": "object",
        "description": "The appeal adjudicator's decision"
      },
      "remandInstructions": {
        "type": "string",
        "description": "Instructions for the original case if remanded"
      }
    },
    "relationships": [
      {
        "type": "child",
        "targetCase": "urn:wos:agency.gov:cases:BA-2026-001",
        "relationship": "appeal-of",
        "bidirectional": true
      }
    ]
  },
  "execution": {
    "workflowTimeout": "P180D",
    "defaultTaskTimeout": "P30D",
    "defaultServiceTimeout": "PT30S",
    "instanceVersioning": "pinned"
  },
  "governance": {
    "dueProcess": {
      "noticeRequirements": {
        "minDaysBeforeDecision": 10
      },
      "appealProcess": {
        "independentReviewRequired": true
      }
    }
  },
  "custody": {
    "trustProfileRef": "urn:trellis:trust-profile/dev"
  }
}
