{
  "$wosKernel": "1.0",
  "$schema": "https://wos-spec.org/schemas/kernel/1.0",
  "url": "https://test.wos-spec.org/workflows/dcr-zone",
  "version": "1.0.0",
  "title": "DCR Constraint Zone Test",
  "description": "Minimal workflow with a compound state referencing a constraint zone. Tests DCR marking state: equity guardrails (AG-001), exclude-pending error (AG-002), zone satisfaction (AG-003), and proven-unsafe gating (AG-015).",
  "status": "active",
  "impactLevel": "rights-impacting",

  "actors": [
    { "id": "investigator", "type": "human", "description": "Case investigator" },
    { "id": "supervisor", "type": "human", "description": "Supervisor" }
  ],

  "lifecycle": {
    "initialState": "investigation",
    "states": {
      "investigation": {
        "type": "compound",
        "initialState": "evidenceGathering",
        "extensions": {
          "x-constraintZoneRef": "investigationZone"
        },
        "states": {
          "evidenceGathering": {
            "type": "atomic",
            "tags": ["investigation"],
            "transitions": [
              { "event": "evidenceCollected", "target": "analysisReady" }
            ]
          },
          "analysisReady": {
            "type": "atomic",
            "transitions": [
              { "event": "analyzed", "target": "investigationDone" }
            ]
          },
          "investigationDone": { "type": "final" }
        },
        "transitions": [
          {
            "event": "constraintZone.satisfied",
            "target": "determination",
            "tags": ["determination"]
          }
        ]
      },
      "determination": {
        "type": "atomic",
        "tags": ["determination"],
        "transitions": [
          { "event": "decided", "target": "complete" }
        ]
      },
      "complete": { "type": "final" }
    }
  },

  "caseFile": {
    "fields": {
      "evidence": { "type": "array" },
      "analysis": { "type": "object" }
    }
  },

  "execution": {
    "workflowTimeout": "P180D",
    "instanceVersioning": "pinned"
  }
}
