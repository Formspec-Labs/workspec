{
  "description": "Expected rejections for invalid WOS Workflow documents (`$wosWorkflow` 1.0). Each entry is minimal except the intentional defect. Diagnostics quoted in `expectedError` match jsonschema Draft 2020-12 (`validators['$wosWorkflow'].iter_errors(document)`) for schema-expressible cases.",
  "invalidDocuments": [
    {
      "id": "missing-lifecycle",
      "description": "Workflow document with `$wosWorkflow` and other required core leaves but no `lifecycle` object",
      "expectedError": "'lifecycle' is a required property",
      "document": {
        "$wosWorkflow": "1.0",
        "url": "https://wos-spec.example/fixtures/kernel/invalid/missing-lifecycle",
        "version": "1.0.0",
        "title": "Missing lifecycle",
        "impactLevel": "operational",
        "actors": [
          {
            "id": "a1",
            "type": "human"
          }
        ]
      }
    },
    {
      "id": "missing-document-marker",
      "description": "Object shaped like a workflow body but missing the required `$wosWorkflow` version marker",
      "expectedError": "'$wosWorkflow' is a required property",
      "document": {
        "url": "https://wos-spec.example/fixtures/kernel/invalid/missing-document-marker",
        "version": "1.0.0",
        "title": "Missing marker",
        "impactLevel": "operational",
        "actors": [
          {
            "id": "a1",
            "type": "human"
          }
        ],
        "lifecycle": {
          "initialState": "start",
          "states": {
            "start": {
              "type": "atomic"
            },
            "end": {
              "type": "final"
            }
          }
        }
      }
    },
    {
      "id": "wrong-version",
      "description": "`$wosWorkflow` must be the const string \"1.0\" for this schema line",
      "expectedError": "'1.0' was expected",
      "document": {
        "$wosWorkflow": "2.0",
        "url": "https://wos-spec.example/fixtures/kernel/invalid/wrong-version",
        "version": "1.0.0",
        "title": "Wrong version marker",
        "impactLevel": "operational",
        "actors": [
          {
            "id": "a1",
            "type": "human"
          }
        ],
        "lifecycle": {
          "initialState": "start",
          "states": {
            "start": {
              "type": "atomic"
            },
            "end": {
              "type": "final"
            }
          }
        }
      }
    },
    {
      "id": "invalid-impact-level",
      "description": "`impactLevel` not in the closed enum enforced by `wos-workflow.schema.json`",
      "expectedError": "'critical' is not one of ['informational', 'operational', 'rights-impacting', 'safety-impacting']",
      "document": {
        "$wosWorkflow": "1.0",
        "url": "https://wos-spec.example/fixtures/kernel/invalid/invalid-impact-level",
        "version": "1.0.0",
        "title": "Invalid impact level",
        "impactLevel": "critical",
        "actors": [
          {
            "id": "a1",
            "type": "human"
          }
        ],
        "lifecycle": {
          "initialState": "start",
          "states": {
            "start": {
              "type": "atomic"
            },
            "end": {
              "type": "final"
            }
          }
        }
      }
    },
    {
      "id": "invalid-actor-type",
      "description": "Any `actors[].type` of `agent` triggers the schema `allOf` rule that requires an `agents` array; omitting `agents` fails validation",
      "expectedError": "'agents' is a required property",
      "document": {
        "$wosWorkflow": "1.0",
        "url": "https://wos-spec.example/fixtures/kernel/invalid/invalid-actor-type",
        "version": "1.0.0",
        "title": "Agent actor without agents block",
        "impactLevel": "operational",
        "actors": [
          {
            "id": "bot",
            "type": "agent"
          }
        ],
        "lifecycle": {
          "initialState": "start",
          "states": {
            "start": {
              "type": "atomic"
            },
            "end": {
              "type": "final"
            }
          }
        }
      }
    },
    {
      "id": "invalid-state-type",
      "description": "`lifecycle.states[*].type` must be one of the State discriminator enum values",
      "expectedError": "'bogus' is not one of ['atomic', 'compound', 'parallel', 'foreach', 'final']",
      "document": {
        "$wosWorkflow": "1.0",
        "url": "https://wos-spec.example/fixtures/kernel/invalid/invalid-state-type",
        "version": "1.0.0",
        "title": "Invalid state type",
        "impactLevel": "operational",
        "actors": [
          {
            "id": "a1",
            "type": "human"
          }
        ],
        "lifecycle": {
          "initialState": "start",
          "states": {
            "start": {
              "type": "bogus"
            },
            "end": {
              "type": "final"
            }
          }
        }
      }
    },
    {
      "id": "final-state-with-transitions",
      "description": "Final state with outgoing transitions (semantically invalid — not expressible as a single JSON Schema constraint on this schema)",
      "expectedError": "Final states MUST NOT have outgoing transitions",
      "note": "Semantic constraint. Schema validation alone does not reject this; a complete processor or lint pass MUST reject it.",
      "document": {
        "$wosWorkflow": "1.0",
        "url": "https://wos-spec.example/fixtures/kernel/invalid/final-state-with-transitions",
        "version": "1.0.0",
        "title": "Final state with transitions",
        "impactLevel": "operational",
        "actors": [
          {
            "id": "a1",
            "type": "human"
          }
        ],
        "lifecycle": {
          "initialState": "start",
          "states": {
            "start": {
              "type": "atomic",
              "transitions": [
                {
                  "target": "end"
                }
              ]
            },
            "end": {
              "type": "final",
              "transitions": [
                {
                  "target": "start"
                }
              ]
            }
          }
        }
      }
    },
    {
      "id": "additional-properties",
      "description": "Top-level property not declared on the workflow envelope (`additionalProperties` / `patternProperties` only allow declared keys and `x-*` vendor keys)",
      "expectedError": "'deonticConstraints' does not match any of the regexes: '^x-'",
      "document": {
        "$wosWorkflow": "1.0",
        "url": "https://wos-spec.example/fixtures/kernel/invalid/additional-properties",
        "version": "1.0.0",
        "title": "Undeclared top-level property",
        "impactLevel": "operational",
        "actors": [
          {
            "id": "a1",
            "type": "human"
          }
        ],
        "deonticConstraints": {},
        "lifecycle": {
          "initialState": "start",
          "states": {
            "start": {
              "type": "atomic"
            },
            "end": {
              "type": "final"
            }
          }
        }
      }
    }
  ]
}
