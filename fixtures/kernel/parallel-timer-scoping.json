{
  "$wosWorkflow": "1.0",
  "$schema": "https://wos-spec.org/schemas/kernel/1.0",
  "url": "https://test.wos-spec.org/workflows/parallel-timer-scoping",
  "version": "1.0.0",
  "title": "Parallel Timer Region Scoping",
  "description": "Minimal parallel state with two regions, each starting a timer. Tests that timer events are routed to the creating region only (LCD S6.5).",
  "status": "active",
  "impactLevel": "operational",
  "actors": [
    {
      "id": "system",
      "type": "system",
      "description": "System actor"
    },
    {
      "id": "operator",
      "type": "human",
      "description": "Operator"
    }
  ],
  "lifecycle": {
    "initialState": "processing",
    "states": {
      "processing": {
        "type": "parallel",
        "cancellationPolicy": "wait-all",
        "regions": {
          "regionA": {
            "initialState": "waitingA",
            "states": {
              "waitingA": {
                "type": "atomic",
                "onEntry": [
                  {
                    "action": "startTimer",
                    "timerId": "timerA",
                    "duration": "PT10S",
                    "event": {
                      "kind": "timer",
                      "timerId": "regionA",
                      "source": "custom"
                    }
                  }
                ],
                "transitions": [
                  {
                    "event": {
                      "kind": "timer",
                      "timerId": "regionA",
                      "source": "custom"
                    },
                    "target": "doneA"
                  }
                ]
              },
              "doneA": {
                "type": "final"
              }
            }
          },
          "regionB": {
            "initialState": "waitingB",
            "states": {
              "waitingB": {
                "type": "atomic",
                "onEntry": [
                  {
                    "action": "startTimer",
                    "timerId": "timerB",
                    "duration": "PT30S",
                    "event": {
                      "kind": "timer",
                      "timerId": "regionB",
                      "source": "custom"
                    }
                  }
                ],
                "transitions": [
                  {
                    "event": {
                      "kind": "timer",
                      "timerId": "regionB",
                      "source": "custom"
                    },
                    "target": "doneB"
                  }
                ]
              },
              "doneB": {
                "type": "final"
              }
            }
          }
        },
        "transitions": [
          {
            "event": {
              "kind": "signal",
              "name": "$join",
              "scope": "instance"
            },
            "target": "completed"
          }
        ]
      },
      "completed": {
        "type": "final"
      }
    }
  },
  "caseFile": {
    "fields": {}
  },
  "execution": {
    "workflowTimeout": "P1D",
    "instanceVersioning": "pinned"
  }
}
