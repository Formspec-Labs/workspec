{
  "$wosWorkflow": "1.0",
  "url": "https://example.test/migrated-fixture",
  "version": "1.0.0",
  "title": "Migrated Fixture",
  "impactLevel": "operational",
  "actors": [
    {
      "id": "system",
      "type": "system"
    }
  ],
  "lifecycle": {
    "initial": "start",
    "states": {
      "start": {
        "type": "atomic",
        "transitions": [
          {
            "to": "done"
          }
        ]
      },
      "done": {
        "type": "final"
      }
    }
  },
  "signature": {
    "targetWorkflow": {
      "url": "urn:test:signature-runtime"
    },
    "roles": [
      {
        "id": "applicantSigner",
        "role": "signer",
        "actorId": "applicant",
        "authenticationPolicyKey": "emailOtp"
      },
      {
        "id": "agencyApprover",
        "role": "approver",
        "actorId": "agency",
        "authenticationPolicyKey": "credentialAuth"
      }
    ],
    "documents": [
      {
        "id": "application",
        "documentRef": "urn:test:document:application",
        "documentHash": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
        "documentHashAlgorithm": "sha-256",
        "formspecResponseRef": "urn:test:formspec-response:application"
      }
    ],
    "authenticationPolicies": [
      {
        "key": "emailOtp",
        "method": "email-otp",
        "assuranceLevel": "standard"
      },
      {
        "key": "credentialAuth",
        "method": "credential",
        "assuranceLevel": "high"
      }
    ],
    "signingFlow": {
      "type": "free-for-all",
      "steps": [
        {
          "id": "applicantSigns",
          "roleId": "applicantSigner",
          "documentId": "application"
        },
        {
          "id": "agencyApproves",
          "roleId": "agencyApprover",
          "documentId": "application"
        }
      ],
      "completion": {
        "type": "all-required"
      }
    },
    "evidence": {
      "recordKind": "signatureAffirmation",
      "requiredFields": [
        "response.signature.acceptedAt",
        "response.signature.affirmed",
        "response.signature.documentHash"
      ],
      "consentReference": {
        "consentTextRef": "urn:test:consent:esign",
        "consentVersion": "1.0.0",
        "acceptedAtPath": "response.signature.acceptedAt",
        "affirmationPath": "response.signature.affirmed"
      },
      "identityBinding": {
        "method": "credential",
        "assuranceLevel": "high"
      },
      "custodyHookEligible": true
    }
  }
}