{
  "$wosWorkflow": "1.0",
  "version": "1.0.0",
  "title": "signature-runtime-free-for-all",
  "url": "https://example.test/fixtures/signature-runtime-free-for-all",
  "signature": {
    "roles": [
      {
        "id": "applicantSigner",
        "role": "signer",
        "actorId": "applicant",
        "authenticationPolicyKey": "emailOtp"
      },
      {
        "id": "agencyApprover",
        "role": "approver",
        "actorId": "agency",
        "authenticationPolicyKey": "credentialAuth"
      }
    ],
    "documents": [
      {
        "id": "application",
        "documentRef": "urn:test:document:application",
        "documentHash": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
        "documentHashAlgorithm": "sha-256",
        "sourceResponseRef": "urn:test:formspec-response:application"
      }
    ],
    "authenticationPolicies": [
      {
        "key": "emailOtp",
        "method": "email-otp",
        "assuranceLevel": "standard"
      },
      {
        "key": "credentialAuth",
        "method": "credential",
        "assuranceLevel": "high"
      }
    ],
    "signingFlow": {
      "type": "free-for-all",
      "steps": [
        {
          "id": "applicantSigns",
          "roleId": "applicantSigner",
          "documentId": "application",
          "signingIntent": "urn:wos:signing-intent:applicant-signature"
        },
        {
          "id": "agencyApproves",
          "roleId": "agencyApprover",
          "documentId": "application",
          "signingIntent": "urn:wos:signing-intent:approval"
        }
      ],
      "completion": {
        "type": "all-required"
      }
    },
    "evidence": {
      "recordKind": "signatureAffirmation",
      "requiredFields": [
        "response.signature.acceptedAt",
        "response.signature.affirmed",
        "response.signature.documentHash"
      ],
      "consentReference": {
        "consentTextRef": "urn:test:consent:esign",
        "consentVersion": "1.0.0",
        "acceptedAtPath": "response.signature.acceptedAt",
        "affirmationPath": "response.signature.affirmed"
      },
      "identityBinding": {
        "method": "credential",
        "assuranceLevel": "high"
      },
      "custodyHookEligible": true
    }
  },
  "impactLevel": "operational",
  "actors": [
    {
      "id": "applicant",
      "type": "human"
    }
  ],
  "lifecycle": {
    "initialState": "_s",
    "states": {
      "_s": {
        "type": "atomic",
        "transitions": [
          {
            "target": "_f"
          }
        ]
      },
      "_f": {
        "type": "final"
      }
    }
  }
}
