{
  "$wosWorkflow": "1.0",
  "url": "https://example.org/wf/timeoff",
  "version": "1.0.0",
  "title": "Time-Off Request",
  "description": "Forms+ tier. Employee submits a time-off request; manager approves or rejects. Forms-style intake plus a thin two-step approval. No governance, no agents, no signature. ~30 lines.",
  "impactLevel": "operational",
  "intake": {
    "contractRef": "https://example.org/forms/timeoff.formspec.json",
    "mode": "workflowInitiated"
  },
  "caseFile": {
    "contractRef": "https://example.org/forms/timeoff.formspec.json"
  },
  "actors": [
    {
      "id": "submitter",
      "type": "human",
      "role": "employee"
    },
    {
      "id": "manager",
      "type": "human",
      "role": "approver"
    }
  ],
  "lifecycle": {
    "initialState": "submitted",
    "states": {
      "submitted": {
        "type": "atomic",
        "transitions": [
          {
            "target": "approved",
            "actor": "manager",
            "guard": "$caseFile.totalDays <= 10"
          },
          {
            "target": "approved",
            "actor": "manager",
            "tags": [
              "overrideRequired"
            ],
            "guard": "$caseFile.totalDays > 10"
          },
          {
            "target": "rejected",
            "actor": "manager"
          }
        ]
      },
      "approved": {
        "type": "final",
        "outcomeCode": "approved"
      },
      "rejected": {
        "type": "final",
        "outcomeCode": "rejected"
      }
    }
  }
}