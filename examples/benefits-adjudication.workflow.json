{
  "$wosWorkflow": "1.0",
  "url": "https://agency.gov/workflows/benefits-adjudication",
  "version": "1.0.0",
  "title": "Benefits Adjudication",
  "description": "Case-management tier. Multi-stage adjudication of a rights-impacting benefits decision with AI-assisted eligibility review, dual-blind human review, due process (notice + hearing + appeal), statutory deadlines, equity monitoring, and signed determination. Demonstrates every embedded block: governance, agents, aiOversight, signature, advanced, assurance. ~600 lines, abbreviated in places to show shape rather than exhaustively populate sub-blocks.",
  "impactLevel": "rightsImpacting",
  "status": "active",

  "intake": {
    "contractRef": "https://agency.gov/forms/benefits-application.formspec.json",
    "mode": "publicIntake"
  },

  "caseFile": {
    "fields": {
      "applicantId":          { "type": "string",   "required": true },
      "applicationDate":      { "type": "datetime", "required": true },
      "programCode":          { "type": "string",   "required": true },
      "householdSize":        { "type": "integer",  "required": true },
      "monthlyIncome":        { "type": "number",   "required": true },
      "documentedAssets":     { "type": "number",   "required": false },
      "supportingEvidence":   { "type": "array",    "required": false },
      "eligibilityScore":     { "type": "number",   "required": false },
      "eligibilityRationale": { "type": "string",   "required": false },
      "reviewer1Decision":    { "type": "string",   "required": false },
      "reviewer2Decision":    { "type": "string",   "required": false },
      "supervisorDecision":   { "type": "string",   "required": false },
      "determination":        { "type": "string",   "required": false },
      "determinationDate":    { "type": "datetime", "required": false },
      "appealDeadline":       { "type": "datetime", "required": false }
    }
  },

  "actors": [
    { "id": "applicant",         "type": "human",  "role": "respondent" },
    { "id": "intakeClerk",       "type": "human",  "role": "intakeReview" },
    { "id": "eligibilityAgent",  "type": "agent",  "role": "preliminaryAssessment" },
    { "id": "reviewer1",         "type": "human",  "role": "primaryReview" },
    { "id": "reviewer2",         "type": "human",  "role": "independentReview" },
    { "id": "supervisor",        "type": "human",  "role": "determinationAuthority" },
    { "id": "appealOfficer",     "type": "human",  "role": "appellateReview" },
    { "id": "caseSystem",        "type": "system", "role": "automationSurface" }
  ],

  "lifecycle": {
    "initial": "intake",
    "states": {
      "intake": {
        "type": "atomic",
        "tags": ["intakeStart"],
        "stateTimeout": "P5D",
        "transitions": [
          { "to": "preliminaryReview", "actor": "intakeClerk", "tags": ["intakeAccepted"] },
          { "to": "intakeRejected",    "actor": "intakeClerk", "tags": ["adverseAction"] }
        ]
      },
      "preliminaryReview": {
        "type": "atomic",
        "stateTimeout": "P3D",
        "transitions": [
          { "to": "dualReview", "on": { "kind": "completion", "actorId": "eligibilityAgent" } }
        ]
      },
      "dualReview": {
        "type": "parallel",
        "tags": ["independentReview", "dualBlind"],
        "regions": {
          "primary": {
            "initial": "reviewer1Pending",
            "states": {
              "reviewer1Pending": {
                "type": "atomic",
                "stateTimeout": "P10D",
                "transitions": [
                  { "to": "reviewer1Done", "actor": "reviewer1", "tags": ["primaryDecision"] }
                ]
              },
              "reviewer1Done": { "type": "final" }
            }
          },
          "independent": {
            "initial": "reviewer2Pending",
            "states": {
              "reviewer2Pending": {
                "type": "atomic",
                "stateTimeout": "P10D",
                "transitions": [
                  { "to": "reviewer2Done", "actor": "reviewer2", "tags": ["independentDecision"] }
                ]
              },
              "reviewer2Done": { "type": "final" }
            }
          }
        },
        "transitions": [
          { "to": "reconciliation", "on": { "kind": "completion" }, "guard": "$caseFile.reviewer1Decision == $caseFile.reviewer2Decision" },
          { "to": "supervisorReview", "on": { "kind": "completion" }, "guard": "$caseFile.reviewer1Decision != $caseFile.reviewer2Decision", "tags": ["disagreement"] }
        ]
      },
      "reconciliation": {
        "type": "atomic",
        "transitions": [
          { "to": "determination", "actor": "caseSystem", "tags": ["dualBlindAgreed"] }
        ]
      },
      "supervisorReview": {
        "type": "atomic",
        "stateTimeout": "P5D",
        "transitions": [
          { "to": "determination", "actor": "supervisor", "tags": ["supervisorOverride"] }
        ]
      },
      "determination": {
        "type": "atomic",
        "tags": ["determinationDraft"],
        "transitions": [
          { "to": "noticeIssued", "on": { "kind": "signature", "actorId": "supervisor" }, "tags": ["determination", "signedDetermination"] }
        ]
      },
      "noticeIssued": {
        "type": "atomic",
        "tags": ["adverseDecisionNotice", "appealEligible"],
        "stateTimeout": "P30D",
        "transitions": [
          { "to": "appealUnderReview", "on": { "kind": "signal", "name": "appealFiled" }, "actor": "applicant" },
          { "to": "finalized",         "on": { "kind": "timer" }, "tags": ["appealWindowClosed"] }
        ]
      },
      "appealUnderReview": {
        "type": "atomic",
        "stateTimeout": "P30D",
        "transitions": [
          { "to": "finalized", "actor": "appealOfficer", "tags": ["appealResolved"] }
        ]
      },
      "intakeRejected": { "type": "final", "outcomeCode": "intakeRejected" },
      "finalized":      { "type": "final", "outcomeCode": "finalized", "tags": ["caseClosed"] }
    }
  },

  "contracts": {
    "eligibilityRules": {
      "contractRef": "https://agency.gov/contracts/eligibility-policy.json",
      "version": "2026.04"
    }
  },

  "bindings": [
    {
      "on": "preliminaryReview/eligibilityAgent.completion",
      "contractRef": "https://agency.gov/contracts/eligibility-output.schema.json",
      "writeScope": ["eligibilityScore", "eligibilityRationale"],
      "mutationSource": "agent-extracted",
      "verificationLevel": "corroborated"
    },
    {
      "on": "determination",
      "writeScope": ["determination", "determinationDate", "appealDeadline"],
      "mutationSource": "human-entered",
      "verificationLevel": "authoritative"
    }
  ],

  "provenance": { "tier": "full" },

  "governance": {
    "dueProcess": {
      "noticeRequired": true,
      "noticeTemplateRef": "https://agency.gov/templates/adverse-decision-notice.json",
      "opportunityToBeHeard": { "mode": "writtenSubmission", "deadline": "P30D" },
      "appealMechanism": {
        "deadline": "P30D",
        "appealOfficerActor": "appealOfficer",
        "stayOfDetermination": false
      },
      "adverseDecisionPolicy": {
        "tagsRequiringNotice": ["adverseAction", "intakeRejected", "determination"]
      }
    },
    "reviewProtocols": [
      { "id": "dualBlind", "appliesToTags": ["dualBlind"], "blindingRules": { "reviewerSeparation": true, "preliminaryAssessmentVisibility": "hidden" } },
      { "id": "independentFirst", "appliesToTags": ["independentReview"], "ordering": "independentBeforePrimary" }
    ],
    "pipelines": [
      {
        "id": "eligibility",
        "stages": [
          { "id": "intakeValidation",  "kind": "contractValidation", "contractRef": "https://agency.gov/contracts/intake.formspec.json" },
          { "id": "evidenceCheck",     "kind": "assertionGate", "expression": "size($caseFile.supportingEvidence) >= 1" },
          { "id": "policyEvaluation",  "kind": "decisionService", "serviceRef": "https://agency.gov/services/eligibility-decision" }
        ]
      }
    ],
    "taskCatalog": [
      { "id": "primaryReview",     "actorRole": "primaryReview",      "slaPerInstance": "P10D" },
      { "id": "independentReview", "actorRole": "independentReview",  "slaPerInstance": "P10D" },
      { "id": "supervisorReview",  "actorRole": "determinationAuthority", "slaPerInstance": "P5D" }
    ],
    "delegation": {
      "allowedFor": ["primaryReview", "independentReview"],
      "verificationLevel": "attested"
    },
    "holds": {
      "kinds": ["evidenceRequest", "litigation", "systemOutage"],
      "stopsClock": true
    },
    "policyParameters": {
      "businessCalendarRef": "https://agency.gov/calendars/federal-2026.json",
      "deadlinePolicy": "businessDays"
    },
    "escalationLevels": [
      { "level": 1, "trigger": "P3D", "to": "supervisor", "additionalEditableFields": ["overrideRationale"] },
      { "level": 2, "trigger": "P7D", "to": "regionalDirector" }
    ]
  },

  "agents": [
    {
      "id": "eligibilityAgent",
      "modelIdentifier": "gov-eligibility-classifier",
      "modelVersion": "3.2.0",
      "modelVersionPolicy": "minor-allowed",
      "autonomy": "assistive",
      "deonticConstraints": [
        { "kind": "prohibition", "expression": "@transition.tags includes 'determination'", "$comment": "Agent MUST NOT directly determine; only assist." },
        { "kind": "prohibition", "expression": "@transition.tags includes 'adverseAction'" },
        { "kind": "obligation",  "expression": "@output.eligibilityRationale != null && size(@output.eligibilityRationale) > 0" },
        { "kind": "permission",  "expression": "@transition.tags includes 'preliminaryAssessment'" }
      ],
      "confidenceFloor": 0.75,
      "confidenceDecay": { "halfLifeDays": 90 },
      "fallbackChain": ["reviewer1", "supervisor"],
      "capabilities": [
        {
          "id": "scoreEligibility",
          "writeScope": ["eligibilityScore", "eligibilityRationale"],
          "outputContractRef": "https://agency.gov/contracts/eligibility-output.schema.json"
        }
      ],
      "driftMonitoring": {
        "dimensions": ["acceptanceRate", "denialRationaleEntropy", "demographicParity"],
        "alertThresholds": { "demographicParity": 0.08 }
      }
    }
  ],

  "aiOversight": {
    "disclosure": {
      "applicantNotice": true,
      "noticeTemplateRef": "https://agency.gov/templates/ai-disclosure.json",
      "complianceRefs": ["EU-AI-Act-Art-13", "OMB-M-24-10"]
    },
    "driftDetection": {
      "globalDimensions": ["systemDriftScore", "modelChurn"],
      "demotionPolicy": "demoteToReadOnlyOnAlert"
    },
    "volumeConstraints": {
      "maxAgentDeterminationsPerDay": 0,
      "maxAgentAssistsPerDay": 5000
    },
    "narrativeTier": {
      "templateRef": "https://agency.gov/templates/narrative-explanation.json"
    }
  },

  "signature": {
    "order": "sequential",
    "signers": [
      {
        "actorId": "supervisor",
        "identityVerification": "idDocument",
        "consentText": "I attest that I have reviewed the case and the determination is consistent with applicable policy and statute.",
        "signingMethod": "certificate"
      }
    ],
    "auditCertificate": {
      "writeScope": ["determinationDate"],
      "mutationSource": "system-fetched",
      "verificationLevel": "authoritative"
    }
  },

  "advanced": {
    "equity": {
      "biasCaps": [
        { "dimension": "race",   "metric": "demographicParity", "threshold": 0.05 },
        { "dimension": "gender", "metric": "demographicParity", "threshold": 0.05 }
      ],
      "monitoringWindow": "P90D",
      "actionOnBreach": "suspendAgentDecisioning"
    },
    "verifiableConstraints": [
      {
        "id": "noDeterminationByAgent",
        "expression": "forall mutations m where m.path == 'determination': m.mutationSource != 'agent-extracted'",
        "verifier": "smt"
      },
      {
        "id": "appealAlwaysAvailableOnAdverse",
        "expression": "forall states s where s.tags includes 'adverseAction': exists transition t where t.on.name == 'appealFiled'",
        "verifier": "smt"
      }
    ],
    "circuitBreaker": {
      "triggers": ["agent.confidence.belowFloor", "drift.alert", "equity.breach"],
      "action": "haltNewAgentInvocations"
    }
  },

  "assurance": {
    "level": "high",
    "attestation": { "attesterRole": "agencyCIO", "cadence": "quarterly" },
    "subjectContinuity": { "applicantIdentityProof": "kbaPlusKnownPerson" }
  }
}
